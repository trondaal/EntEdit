@prefix entedit: <http://oslomet.no/abi/vocab#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdac: <http://rdaregistry.info/Elements/c/> .
@prefix rdaao: <http://rdaregistry.info/Elements/a/object/> .
@prefix rdawo: <http://rdaregistry.info/Elements/w/object/> .
@prefix rdaeo: <http://rdaregistry.info/Elements/e/object/> .
@prefix rdamo: <http://rdaregistry.info/Elements/m/object/> .
@prefix rdaio: <http://rdaregistry.info/Elements/i/object/> .
@prefix rdaad: <http://rdaregistry.info/Elements/a/datatype/> .
@prefix rdawd: <http://rdaregistry.info/Elements/w/datatype/> .
@prefix rdaed: <http://rdaregistry.info/Elements/e/datatype/> .
@prefix rdamd: <http://rdaregistry.info/Elements/m/datatype/> .
@prefix rdaid: <http://rdaregistry.info/Elements/i/datatype/> .

entedit:StatusLiteral a rdfs:Datatype ;
    owl:oneOf ("core wemi property" "data property" "object property" "class" "controlled property" "deprecated" "not used") .

entedit:status
    a owl:DatatypeProperty ;
    rdfs:range entedit:StatusLiteral ;
    rdfs:label "has status (literal)" .

entedit:order a owl:DatatypeProperty .

#Adding some classes for the vocabularies used ta facilitate filtering by range
entedit:Contenttype
  a owl:Class ;
  rdfs:label "Innholdstype"@no, "Content type"@en .

entedit:Carriertype
  a owl:Class ;
  rdfs:label "Bærertype"@no, "Carrier types"@en .

entedit:Mediatype
  a owl:Class ;
  rdfs:label "Medietype"@no, "Media type"@en .

entedit:Language
  a owl:Class ;
  rdfs:label "Språk"@no, "Language"@en .

entedit:Worktype
  a owl:Class ;
  rdfs:label "Kategori av verk"@no, "Category of work"@en .

entedit:Genretype
  a owl:Class ;
  rdfs:label  "Sjanger og form"@no, "Genre and form"@en .

entedit:P01
  a rdf:Property ;
  entedit:status "controlled property" ;
  rdfs:subPropertyOf rdawo:P10004 ;
  rdfs:domain <http://rdaregistry.info/Elements/c/C10001> ;
  rdfs:range entedit:Worktype ;
  rdfs:label "Verkskategori"@no, "Category of work"@en.

entedit:P02
  a rdf:Property ;
  entedit:status "controlled property" ;
  rdfs:subPropertyOf rdawo:P10004 ;
  rdfs:domain <http://rdaregistry.info/Elements/c/C10001> ;
  rdfs:range entedit:Genretype ;
  rdfs:label "Sjanger eller form"@no, "Genre or form"@en.

#All classes with status "class" are displayed in the entity browsers class display
rdac:C10002 entedit:order 1 ; entedit:status "class" .  # "Agent"@en .
rdac:C10004 entedit:order 2 ; entedit:status "class" .  # "Person"@en .
rdac:C10005 entedit:order 3 ; entedit:status "class" .  # "Corporate Body"@en .
#rdac:C10008 entedit:order 1 ; entedit:status "class" .  # "Family"@en .
rdac:C10001 entedit:order 4 ; entedit:status "class" .  # "Work"@en .
rdac:C10006 entedit:order 5 ; entedit:status "class" .  # "Expression"@en .
rdac:C10007 entedit:order 6 ; entedit:status "class" .  # "Manifestation"@en .
rdac:C10003 entedit:order 7 ; entedit:status "class" .  # "Item"@en .

