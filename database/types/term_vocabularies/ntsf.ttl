<https://id.nb.no/vocabulary/ntsf/1794> a skos:Concept ;
    dct:created "2022-11-15T09:41:28"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1658> ;
    skos:definition "Liten trykksak, ofte med kritisk, satirisk innhold (NAOB)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026053> ;
    skos:example """Letter from Sir Philip Francis, knight of the most honourable order of the Bath, to Earl Grey : on the policy of Great Britain and the Allies towards Norway, 1814.\r
https://www.nb.no/bibliografi/1814/show?id=30f29083b71c5d3faf2ab8541d84d534&bibliography=bib1814."""@nb,
        """Som man raaber i Skoven, faaer man Svar, eller aftvunget Forsvar i Anledning af en anonym Forfatters Critik over min Afhandling om Norges Odelsret / af Amtmand Falsen, 1815.\r
https://www.nb.no/bibliografi/1814/show?id=4d8126a6f5297646edc0f97f4ef2f91f&bibliography=bib1814."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Pamphlets"@en,
        "Pamfletter"@nb,
        "Pamflettar"@nn ;
    skos:scopeNote "Kortfattet uinnbundet publikasjon/trykk/trykksak om et aktuelt tema, ofte av politisk, religiøs eller moralsk karakter, gjerne holdt i en kritisk og polemisk stil."@nb .

<https://id.nb.no/vocabulary/ntsf/1797> a skos:Concept ;
    dct:created "2022-11-15T10:47:22"^^xsd:dateTime ;
    skos:altLabel "Charms"@en,
        "Conjuration"@en,
        "Incantation"@en,
        "Invocation"@en,
        "Magical formulas"@en,
        "Spells"@en,
        "Hekseformularer"@nb,
        "Trollformler"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/508> ;
    skos:definition "Rituelle anvisninger eller episke beretninger som blir brukt enten til å kaste trolldom over noen eller noe, eller verne mot sykdomsdemoner og onde krefter i tilværelsen."@nb ;
    skos:example """Enigmatic charms : medieval Arabic block printed amulets in American and European libraries and museums,\r
Ein Ritualbuch für Goldamulette und Totenbuch des Month-em-hat, Aspects of Anglo-Saxon magic."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Magic formulas"@en,
        "Magiske formler"@nb,
        "Magiske formlar"@nn .

<https://id.nb.no/vocabulary/ntsf/18> a skos:Concept ;
