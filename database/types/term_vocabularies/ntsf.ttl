<https://id.nb.no/vocabulary/ntsf/112> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-10-03T10:02:39"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Føljetong er i dag mest brukt om serier der konflikten eller fortellingen utvikler seg over flere episoder mot en endelig slutt, enten på TV eller radio, eller på strømmetjenester som Netflix og radiopodcaster. For å sikre at publikum følger med fra en episode til den neste, slutter ofte hver episode med en cliffhanger. Ordet føljetong ble tidligere benyttet om en fortsettelsesfortelling i en avis eller et ukeblad. De første føljetongene ble trykt i britiske og franske aviser tidlig på 1800-tallet (SNL)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026537> ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Serialized fiction"@en,
        "Føljetonger"@nb,
        "Føljetongar"@nn ;
    skos:scopeNote "Her brukt i betydningen 'fortsettelsesfortelling i en avis eller et ukeblad'."@nb .

<https://id.nb.no/vocabulary/ntsf/1140> a skos:Concept ;
    dct:created "2021-09-27T14:47:40"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "En biografisk film er en film som skildrer livet til en virkelig person eller personer. Biografiske filmer skiller seg fra filmer «basert på en sann historie» eller «historiske filmer» fordi de forsøker å fortelle hele hovedpersonens livshistorie på en forståelig måte, eller i det minste de viktigste årene i livet til hovedpersonen. (...) [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026089> ;
    skos:example "Astrup : flammer over Jølster (2019)."@nb,
        "Billie Eilish : the world's a little blurry (2021)."@nb,
        "The United States vs Billie Holiday (2021)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Biographical films"@en,
        "Biografiske filmer"@nb,
        "Biografiske filmar"@nn ;
    skos:scopeNote "Brukes på både dokumentarfilmer og drama (fiksjonsfilmer)."@nb .

<https://id.nb.no/vocabulary/ntsf/1143> a skos:Concept ;
    dct:created "2021-09-28T13:19:27"^^xsd:dateTime ;
    dct:modified "2021-09-28T13:19:56"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer om dans, tema foregår rundt dans, dans som virkemiddel [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026188> ;
    skos:example "Dirty dancing (1987)."@nb,
        "Nureyev (2018)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Dance films"@en,
        "Dansefilmer"@nb,
        "Dansefilmar"@nn ;
    skos:scopeNote "Brukes både på dokumentar og drama."@nb .

<https://id.nb.no/vocabulary/ntsf/1146> a skos:Concept ;
    dct:created "2021-09-28T13:45:37"^^xsd:dateTime ;
    dct:modified "2021-09-28T13:45:48"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "En seksuell film , også kjent som myk porno eller softporn , er en erotisk film i hvilken seksualitet står sentralt. Mens nakenhet er tilstede i erotiske filmer, simuleres eller presenteres sex på en slik måte at kjønnsorganene ikke er synlige, noe som er deres viktigste forskjell fra pornografiske filmer.Erotiske filmer forholder seg til det som er referert til som \"  myk pornografi  \" , mens pornografiske filmer faller inn under \"  hardpornografi  \" [no.frwiki]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026227> ;
    skos:example "Fifty shades of grey (2015)."@nb,
        "Nymphomaniac (2013)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Erotic films"@en,
        "Erotiske filmer"@nb,
        "Erotiske filmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1149> a skos:Concept ;
    dct:created "2021-09-28T15:23:15"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Fantasyfilm er en filmsjanger som omhandler fantastiske temaer som magi, mytologiske vesner, overnaturlige hendelser, og eksotiske og fremmede fantasiverdener [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026242> ;
    skos:example "Games of Thrones."@nb,
        "Harry Potter."@nb,
        "Ringenes herre."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Fantasy films"@en,
        "Fantasy (film)"@nb,
        "Fantasy (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/1150> a skos:Concept ;
    dct:created "2021-09-28T15:31:14"^^xsd:dateTime ;
    dct:modified "2021-09-28T15:31:46"^^xsd:dateTime ;
    skos:altLabel "Satiriske filmer"@nb,
        "Svarte komedier (film)"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Humoristiske filmer, filmer som er laget for å få publikum til å le[red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026147> ;
    skos:example "Alle elsker Mary."@nb,
        "Norske byggeklosser."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Comedy films"@en,
        "Komedier (film)"@nb,
        "Komediar (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/1156> a skos:Concept ;
    dct:created "2021-09-30T13:05:31"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer som skildrer krig og militære konflikter. Kan omhandle både soldatliv og sivilt liv under en krig [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026729> ;
    skos:example "Max Manus (2008)."@nb,
        "Redd menig Ryan (1998)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "War films"@en,
        "Krigsfilmer"@nb,
        "Krigsfilmar"@nn ;
    skos:scopeNote "Brukes i hovedsak på filmer som omhandler virkelige kriger."@nb .

<https://id.nb.no/vocabulary/ntsf/1157> a skos:Concept ;
    dct:created "2021-09-30T14:40:50"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1128> ;
    skos:definition "Actionfilmer som inneholder flere scener med kombinert kampsport, og disse danner som regel grunnlaget for handlingen [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026388> ;
    skos:example "Born a champion (2021)."@nb,
        "Hero (2002)."@nb,
        "Snikende tiger, skjult drage (2000)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Martial Arts Films"@en,
        "Martial arts (film)"@nb,
        "Martial arts (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/1160> a skos:Concept ;
    dct:created "2021-09-30T15:25:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Oversatt fra engelsk-En sportsfilm er en filmsjanger der en bestemt sport spiller en fremtredende rolle i filmens handling eller fungerer som dens sentrale tema. Det er en produksjon der en sport eller et sportsrelatert emne er fremtredende omtalt eller er et fokus for handlingen. Wikipedia (engelsk)"@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026601> ;
    skos:example "Aksel (2021)."@nb,
        "Borg (2017)."@nb,
        "Eddie the Eagle (2016)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Sport films"@en,
        "Sportsfilmer"@nb,
        "Sportsfilmar"@nn ;
    skos:scopeNote "Brukes på både dokumentarer og fiksjonsfilmer."@nb .

<https://id.nb.no/vocabulary/ntsf/1169> a skos:Concept ;
    dct:created "2021-10-01T12:39:26"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer med romantiske temaer, kjærlighetshistorier. Fokuserer på en \"sann\" og sterk kjærlighetsrelasjon, ofte truet av noe utenfor, for eksempel økonomi, krig, familie, sykdom. o.l. Hovedkarakterene overkommer som regel, men ikke alltid, hindrene, og lever lykkelig sammen. Lett underholdning, ofte kombinert med 'Komedier' [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026543> ;
    skos:example "Love actually (2003)."@nb,
        "Pretty woman (1990)."@nb,
        "Titanic (1997)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Romance films"@en,
        "Romantiske filmer"@nb,
        "Romantiske filmar"@nn .

<https://id.nb.no/vocabulary/ntsf/117> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-07T15:25:48"^^xsd:dateTime ;
    skos:altLabel "State constitutions"@en,
        "Forfatninger"@nb,
        "Konstitusjoner"@nb,
        "Statsforfatninger"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/438> ;
    skos:definition "Grunnlov er en lov som inneholder grunnleggende regler om et lands statsform og politiske system og regulerer særlig viktige sider ved hvordan det politiske systemet fungerer [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026167> ;
    skos:example "Kongeriget Norges Grundlov."@nb,
        """Kongeriget Norges grundlov af 17de mai 1814.\r
[kilde: 1814-bibliografi]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Constitutions"@en,
        "Grunnlover"@nb,
        "Grunnlovar"@nn ;
    skos:scopeNote "Brukes f.eks. på Norges grunnlov."@nb .

<https://id.nb.no/vocabulary/ntsf/1175> a skos:Concept ;
    dct:created "2021-10-01T13:10:50"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer hvor spioner er hovedpersonene og hvor spionasje er blant hovedelementene [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026604> ;
    skos:example "James Bond."@nb,
        "Mission impossible."@nb,
        "Muldvarpen (2011)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Spy films"@en,
        "Spionfilmer"@nb,
        "Spionfilmar"@nn ;
    skos:scopeNote "Spionasje mot militære/politiske forhold, industri og lignende er vesentlig for handlingen. Er ofte spennende og kan inneholde mord (Krim) og/eller kan være handlingsmettet (Action), men disse sjangrene brukes ikke sammen med Spion."@nb .

<https://id.nb.no/vocabulary/ntsf/118> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-11-14T15:43:13"^^xsd:dateTime ;
    skos:altLabel "Gotiske fortellinger"@nb,
        "Skrekklitteratur"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/578> ;
    skos:definition "Skjønnlitteratur hvor det primære målet er å skremme, skape skrekk eller engstelse [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026373> ;
    skos:example "De levende døde / Stephen King."@nb,
        "Frankenstein / Mary Shelley."@nb,
        "Iskalde grøss / R.L. Stine."@nb,
        "Marg & bein / Arne Svingen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Horror fiction"@en,
        "Grøssere"@nb,
        "Grøssarar"@nn .

<https://id.nb.no/vocabulary/ntsf/1181> a skos:Concept ;
    dct:created "2021-10-01T14:54:03"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Spenningsfilmer som ofte er psykologiske. Spenningen bygges gradvis opp, seeren engasjeres og identifiserer seg gjerne med hovedkarakteren. Ikke nødvendigvis en forbrytelse som skal oppklares, men et brudd på en normalsituasjon og hovedkarakterens forsøk på å gjenopprette denne [Bokbasen]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026692> ;
    skos:example "Bølgen (2015)."@nb,
        "Insomnia (1997)."@nb,
        "Runaway train (1985)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Thrillers (Motion pictures)"@en,
        "Thrillere (film)"@nb,
        "Thrillarar (film)"@nn ;
    skos:scopeNote "I motsetning til kriminalfilmer fokuseres det ikke oppklaring av forbrytelse, men stemningen rundt. Må ikke forveksles med sjangrene Grøssere eller Spenning."@nb .

<https://id.nb.no/vocabulary/ntsf/1184> a skos:Concept ;
    dct:created "2021-10-01T15:26:15"^^xsd:dateTime ;
    skos:altLabel "Westernfilmer"@nb,
        "Westernfilmar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer med tema fra \"Ville vesten\" (Nord-Amerika). Handlingen er som regel hentet fra 1800-tallet [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026735> ;
    skos:example "Deadwood (2019)."@nb,
        "Den gode, den onde og den grusomme (1966)."@nb,
        "True grit (2010)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Western films"@en,
        "Western (film)"@nb,
        "Western(film)"@nn ;
    skos:scopeNote "Brukes også på nye filmer."@nb .

<https://id.nb.no/vocabulary/ntsf/1191> a skos:Concept ;
    dct:created "2021-10-13T13:10:24"^^xsd:dateTime ;
    dct:modified "2021-10-13T13:10:38"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1188> ;
    skos:definition "Filmer hvor dårlige krefter har fått overtaket, for eksempel i form av diktatur, kriminalitet eller miljøsammenbrudd. Dette foregår ofte i et framtidssamfunn, men handlingen kan også foregå i en alternativ eller kontrafaktisk nåtid [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026217> ;
    skos:example "Metropolis."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Dystopian films"@en,
        "Dystopiske filmer"@nb,
        "Dystopiske filmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1199> a skos:Concept ;
    dct:created "2021-10-13T14:04:35"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1196> ;
    skos:definition "Film noir ble brukt av franske filmkritikere for å beskrive en type filmer som hovedsakelig hadde sin storhetstid i USA på 1940-tallet. Felles for disse filmene var en effektiv, men sparsom bruk av lys, såkalt low-key lyssetting som preges av markante skiller mellom lys og mørke (Wikipedia 02022022)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026257> ;
    skos:example "Angel face."@nb,
        "Touch of evil (1958)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Film noir"@en,
        "Film noir"@nb,
        "Film noir"@nn ;
    skos:scopeNote "Brukes om dystre kriminalfilmer fra storbymiljø produsert på 40- og 50-tallet."@nb .

<https://id.nb.no/vocabulary/ntsf/1213> a skos:Concept ;
    dct:created "2021-10-18T13:59:59"^^xsd:dateTime ;
    skos:altLabel "Dokudrama"@nb,
        "Kostymedrama"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer der historiske hendelser er brukt som som bakteppe. Tidsepoke og sted er viktig for handlingen, men mennesker, dialog og hendelser kan være oppdiktet [red.].."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026311> ;
    skos:example "Bridgerton (2020-)"@nb,
        "Fornuft og følelser (1995)."@nb,
        "Kongens nei (2016)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Historical films"@en,
        "Historiske filmer"@nb,
        "Historiske filmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1218> a skos:Concept ;
    dct:created "2021-10-18T14:17:10"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1209> ;
    skos:definition "TV-serie med få episoder [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026665> ;
    skos:example "Pretend it's a city (2021)."@nb,
        "UXA. Thomas Seltzers Amerika (2020)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Television mini series"@en,
        "Mini-serier"@nb,
        "Miniseriar"@nn ;
    skos:scopeNote "Brukt for avsluttede serier produsert for TV-/strømmetjenester med inntil 8 episoder."@nb .

<https://id.nb.no/vocabulary/ntsf/1221> a skos:Concept ;
    dct:created "2021-10-18T15:04:12"^^xsd:dateTime ;
    dct:modified "2022-02-18T14:54:53"^^xsd:dateTime ;
    skos:altLabel "Fiktive dokumentarfilmer"@nb,
        "Mockumentary (film)"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Fiksjon framstilt som dokumentar, ofte humoristisk [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026208> ;
    skos:example "Trolljegeren."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Documentary-style films"@en,
        "Mokumentarfilmer"@nb,
        "Mockumentary (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/1227> a skos:Concept ;
    dct:created "2021-10-19T10:03:26"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1205> ;
    skos:definition "TV programmer som dokumenterer virkelige situasjoner. Bruker ikke skuespillere, men personer som er seg selv, enten i sitt eget miljø, eller i konstruerte miljøer der de skal utføre ulike oppgaver, ofte som en del av en konkurranse [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026522> ;
    skos:example "Farmen (2001-)"@nb,
        "Paradise hotel (2009-)"@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Reality television programs"@en,
        "Reality (TV-programmer)"@nb,
        "Reality (TV-program)"@nn .

<https://id.nb.no/vocabulary/ntsf/1233> a skos:Concept ;
    dct:created "2021-10-19T10:38:59"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1205> ;
    skos:definition "Fiksjonsfilmer laget primært for fjernsynsdistribusjon [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026381> ;
    skos:example "Deadline Torp (2005) [Mavis 814625]."@nb,
        "Edvard Munch (1974) [Mavis 795408]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Made-for-TV-movies"@en,
        "TV-filmer"@nb,
        "TV-filmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1236> a skos:Concept ;
    dct:created "2021-10-19T11:49:37"^^xsd:dateTime ;
    dct:modified "2021-10-19T11:50:11"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1202> ;
    skos:definition "Dokumentarfilmer som har natur og dyr som tema [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026559> ;
    skos:example "The blue planet (2021)."@nb,
        "Under Hallingskarvet (2013)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Nature films"@en,
        "Naturfilmer"@nb,
        "Naturfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1237> a skos:Concept ;
    dct:created "2021-10-19T12:03:39"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1290> ;
    skos:definition "Opptak av operaer [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026428> ;
    skos:example "Carmen in 3D (2011)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Opera films"@en,
        "Operafilmer"@nb,
        "Operafilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1240> a skos:Concept ;
    dct:created "2021-10-19T12:36:13"^^xsd:dateTime ;
    skos:altLabel "Langfilmer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Hovedfilmen i et kinoprogram (SNL). 2.2.2022."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026247> ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Feature films"@en,
        "Spillefilmer"@nb,
        "Spelefilmar"@nn ;
    skos:scopeNote "Spillefilm er en fiksjonsfilm med spilletid i all hovedsak over én time. Som regel omlag 90 min, men definisjon med hensyn til lengde har variert."@nb .

<https://id.nb.no/vocabulary/ntsf/1246> a skos:Concept ;
    dct:created "2021-10-19T13:10:33"^^xsd:dateTime ;
    skos:altLabel "Chronicles"@en,
        "Op-eds"@en,
        "Aviskronikker"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "En kronikk er en artikkel i en avis eller tidsskrift om et emne eller et tema. Vanligvis skrives ikke kronikker av noen som er ansatt i publikasjonen, men av noen med særlig kjennskap til emnet. En kronikk er et partsinnlegg, og hevder ikke å fremlegge den hele og fulle sannhet [Wikipedia]."@nb ;
    skos:example """En debatt om alt og ingenting.\r
I: Tidsskrift for Norsk psykologforening (trykt utg.). Vol. 58, nr. 7 (2021)."""@nb,
        """Farmasistudenter gjennom pandemien.\r
I: Norsk farmaceutisk tidsskrift (Oslo : trykt utg.) |g Årg. 129, nr. 4 (2021)."""@nb,
        """Foreldre forstår ikke hvorfor barna deres blir tatt fra dem / Ellen Syrstad.\r
I: Fosterhjemskontakt. Årg. 38, nr. 6 (2019)."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Opinion pieces"@en,
        "Kronikker"@nb,
        "Kronikkar"@nn ;
    skos:scopeNote "Ofte brukt om innlegg i spalten Kronikk i en avis / tidsskrift (noen ganger felles med Debatt). Disse kan senere utgis i bokform, men med klar kildeangivelse fra avisen / tidsskriftet de var først utgitt."@nb .

<https://id.nb.no/vocabulary/ntsf/1248> a skos:Concept ;
    dct:created "2021-10-19T13:38:35"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Fagfellevurderte artikler"@nb,
        "Forskningsartikkel"@nb,
        "Forskningsartikler"@nb,
        "Vitenskapelig artikkel"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "En vitenskapelig artikkel (også kalt forkningsartikkel eller fagfellevurdert artikkel) er basert på forskning, og formålet med artikkelen er at en skal presentere ny forskning og gi ny innsikt i faglige problemstillinger [Nord universitet]."@nb ;
    skos:example """Fatal hjerneblødning etter covid-19-vaksine.\r
https://tidsskriftet.no/2021/04/kort-kasuistikk/fatal-hjerneblodning-etter-covid-19-vaksine"""@nb,
        """Utprøving av en tilpasset gruppebehandling for unge voksne.\r
https://psykologtidsskriftet.no/originalartikkel/2021/06/utproving-av-en-tilpasset-gruppebehandling-unge-voksne"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Peer reviewed articles"@en,
        "Vitenskapelige artikler"@nb,
        "Vitskaplege artiklar"@nn .

<https://id.nb.no/vocabulary/ntsf/125> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2020-06-23T10:57:23"^^xsd:dateTime ;
    skos:altLabel "Historisk litteratur"@nb,
        "Historiske romaner"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Undersjanger av romanen som ikke bare henter sine hendelser og personer fra historien, men i tillegg lar historiske hendelser og tidstypiske spørsmål prege hovedpersonene og den narrative fremstillingen (...) (Litteraturvitenskapelig leksikon)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026370> ;
    skos:example "Koke bjørn / Mikael Niemi."@nb,
        "Og bakom synger skogene / Trygve Gulbranssen."@nb,
        "Søsterklokkene / Lars Mytting."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Historical fiction"@en,
        "Historiske fortellinger"@nb,
        "Historiske forteljingar"@nn ;
    skos:scopeNote "Brukes for skjønnlitteratur der handlingen er lagt til fortiden (vanligvis før forfatterens levetid). Tidsperioden er en viktig del av historien og den skildrer tidsånden når det gjelder skikker og sosiale forhold."@nb .

<https://id.nb.no/vocabulary/ntsf/1252> a skos:Concept ;
    dct:created "2021-10-19T14:11:07"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/14> ;
    skos:definition "Anmeldelse av en musikalsk utgivelse, en konsert e.l. [NAOB]."@nb ;
    skos:example """Hyldest til kysten / Birger Aasland. \r
I: Viser : nytt nordisk musikkblad. Nr. 15 (2020)\r
Musikkanmeldelse av: Blått album / Per Gunnar Bjørholt."""@nb,
        """Kärleksfulla visor i olika stilar / Ivar Sjögren.\r
I: Viser : nytt nordisk musikkblad. Nr. 15 (2020)"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Music reviews"@en,
        "Musikkanmeldelser"@nb,
        "Musikkmeldingar"@nn ;
    skos:scopeNote "Brukes her for anmeldelser av musikalske verk, utgitt som plater."@nb .

<https://id.nb.no/vocabulary/ntsf/1255> a skos:Concept ;
    dct:created "2021-10-20T09:11:00"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/341> ;
    skos:definition "Musikal er en dramaform som kombinerer sang, dans og talt dialog. Den er nær beslektet med opera og operette. All musikk i en musikal bruker vanligvis å være nedskrevet i et partitur mens de talte replikkene finnes i et manus [Wikipedia]."@nb ;
    skos:example "Chess : the musical : by Benny Andersson, Tim Rice, Björn Ulvaeus."@nb,
        "Den syngende frøken detektiv : mysteriet på Grevly : en kriminalmusical av Klaus Hagerup og Nils Nordberg, musikk: Ingrid Bjørnov og Benedicte Adrian, regi: Hans Petter Thøgersen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Musical programs"@en,
        "Musikalprogrammer"@nb,
        "Musikalprogram"@nn .

<https://id.nb.no/vocabulary/ntsf/1258> a skos:Concept ;
    dct:created "2021-10-20T12:33:50"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1290> ;
    skos:definition "Musikalfilm er en filmsjanger hvor sanger sunget av rollefigurene er en del av historiefortellingen. Sjangeren er utviklet fra vanlig musikal [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026414> ;
    skos:example "La La Land (2016."@nb,
        "Mamma Mia (2008)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Musical films"@en,
        "Musikalfilmer"@nb,
        "Musikalfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/126> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-06T13:53:56"^^xsd:dateTime ;
    skos:altLabel "Post-graduate thesis"@en,
        "Diplomoppgaver"@nb,
        "Hovedfagsoppgaver"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/19> ;
    skos:definition """Større vitenskapelig arbeid som må leveres før (eller i forbindelse med) eksamen i hovedfag \r
 | jf. masteroppgave [NAOB]."""@nb ;
    skos:example """Tid, subjekt og repetisjon : Dag Solstads Professor Andersens natt / Hans Jørgen Støp.\r
Hovedoppgave i allmenn litteraturvitenskap - Norges teknisk-naturvitenskapelige universitet, 2006.\r
[kilde: Solstad-bibliografi]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Post-graduate theses"@en,
        "Hovedoppgaver"@nb,
        "Hovudoppgåver"@nn .

<https://id.nb.no/vocabulary/ntsf/1270> a skos:Concept ;
    dct:created "2021-12-08T15:01:35"^^xsd:dateTime ;
    dct:modified "2024-08-30T14:01:54"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1070> ;
    skos:definition "Kunstnerbok er et kunstverk i form av en bok. Boken kan for eksempel være håndlaget i ett eksemplar, eller trykket opp, da ofte i få eksemplarer. Det er imidlertid ingen regler for verken utseende, innhold eller opplag, annet enn at en kunstner bruker bokformen som medium for å lage kunst [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2017027220> ;
    skos:example """Scenes from the garden : an artist book by Kristine Øksendal.\r
https://static1.squarespace.com/static/53469a85e4b0f69e5c97f5d3/t/5d97af2c7723d90b81c38506/1570221916938/oksendal.katalog.03.pdf"""@nb,
        """So, how should I cut my hair if not like this: 31 suggestions by Erlend PK.\r
https://www.printedmatter.org/catalog/53322/"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Artists' books"@en,
        "Kunstnerbøker"@nb,
        "Kunstnarbøker"@nn ;
    skos:scopeNote "Kunstverk i bokform der kunstneren selv står for innhold, design og utforming."@nb .

<https://id.nb.no/vocabulary/ntsf/1274> a skos:Concept ;
    dct:created "2022-01-18T12:14:20"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/14> ;
    skos:definition "Tekst som refererer og/eller vurderer en operaforestilling [red.]."@nb ;
    skos:example """Da kommt noch wer :\r
Ein Mond aus kochender Milch / M. Fiedler. -\r
I: Opernglas, März 2003."""@nb,
        """Theatret. -\r
I: Andhrimner (trykt utg.). - 1851 Nr. 8. - Spalte 125-126\r
Skrevet av Henrik Ibsen.\r
Anmeldelse av Norma, Opera i 2 (4) a. av F. Romani, musikk av Bellini, overs. av Oehlenschläger med premiere på Christiania Theater 20/5 1851."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Opera recensions"@en,
        "Operaanmeldelser"@nb,
        "Operameldingar"@nn .

<https://id.nb.no/vocabulary/ntsf/1295> a skos:Concept ;
    dct:created "2022-02-18T15:04:41"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Film som fremstiller fiksjon (og derfor ikke søker å dokumentere virkeligheten)  til forskjell fra dokumentarfilm [red.]"@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026250> ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Fiction films"@en,
        "Fiksjonsfilmer"@nb,
        "Fiksjonsfilmar"@nn ;
    skos:scopeNote "Samlebetegnelse for fiksjonsfilmer. Brukes sammen med den spesifikke sjangeren, for eksempel Krim (film) hvis ønskelig."@nb .

<https://id.nb.no/vocabulary/ntsf/13> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/127> ;
    skos:definition "Anekdote, i eldre tid et skrift som bygger på muntlig fortelling. Nå kort, oftest spøkefull fortelling som illustrerer en sak eller har et klart poeng. Innslag av anekdotiske beretninger forekommer i mange romaner [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026044> ;
    skos:example """Anekdoter : [den kiedsommelig Prinds av Henin og den spøgefulde Greve]. -\r
I: Provinzialblade (trykt utg.). - Bergen : [Claus Fasting]. - B. 2(1779)No. 52. - S. 414."""@nb,
        """Prøysen anekdoter / ved K.Aa. -\r
I: Norden (Landbrukstidsskriftet Norden). - Bodø : Landbrukstidsskriftet Norden. - 63(1959)nr. 24. - S. 671."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Anecdotes"@en,
        "Anekdoter"@nb,
        "Anekdotar"@nn .

<https://id.nb.no/vocabulary/ntsf/1301> a skos:Concept ;
    dct:created "2022-02-20T08:59:49"^^xsd:dateTime ;
    skos:broadMatch <http://id.loc.gov/authorities/genreForms/gf2011026005> ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmsjanger som omfatter underholdende spillefilmer med eventyrlig, det vil si fantasifull og spennende, handling. Betegnelsen tilsvarer det engelske «adventure films». «Eventyrfilm» kan på norsk også brukes om filmer med handling fra folkeeventyr, men dekker bredere enn det som på norsk forståes som eventyr [Wikipedia]."@nb ;
    skos:example "Life of Pi (2012)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Adventure films"@en,
        "Eventyrfilmer"@nb,
        "Eventyrfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1307> a skos:Concept ;
    dct:created "2022-02-20T09:15:15"^^xsd:dateTime ;
    skos:altLabel "Private opptak"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Amatørfilm er en film laget av en person som ikke har filmproduksjon som levevei.  (Wikipedia)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026038> ;
    skos:example "[Carsten N. Wilskow. Private opptak] (1945) [mavis 19661031]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Amateur films"@en,
        "Amatørfilmer"@nb,
        "Amatørfilmar"@nn ;
    skos:scopeNote "Film-/videoopptak som viser private hendelser/forhold, knytta til person eller familie. Vanligvis tatt opp av amatører."@nb .

<https://id.nb.no/vocabulary/ntsf/131> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2020-02-11T10:13:23"^^xsd:dateTime ;
    skos:altLabel "Radioteater"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/280> ;
    skos:definition "Et drama som er skrevet eller bearbeidet for å spilles bare med stemmer og annen lyd. Hørespill ble opprinnelig laget for fremføring i radio, f.eks. NRK Radioteatret (SNL)."@nb ;
    skos:example "Dickie Dick Dickens."@nb,
        "Stompa."@nb,
        "Tordivelen flyr i skumringen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Radio plays"@en,
        "Hørespill"@nb,
        "Høyrespel"@nn .

<https://id.nb.no/vocabulary/ntsf/1311> a skos:Concept ;
    dct:created "2022-02-20T09:24:48"^^xsd:dateTime ;
    dct:modified "2022-02-20T09:25:28"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1135> ;
    skos:definition "Tegnefilm som har tegneseriesjangeren manga som stilistisk utgangspunkt (naob)."@nb ;
    skos:example "Chihiro og heksene (2001)."@nb,
        "Min nabo Tatoro (1988)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Anime"@en,
        "Anime (film)"@nb,
        "Anime"@nn .

<https://id.nb.no/vocabulary/ntsf/1312> a skos:Concept ;
    dct:created "2022-02-20T09:31:40"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1135> ;
    skos:closeMatch <http://id.loc.gov/authorities/genreForms/gf2011026370> ;
    skos:definition "Film som skaper en illusjon av bevegelse ved hjelp av tegninger, leire eller andre ikke-levende objekter ved hjelp av animasjonsteknikk. Brukes når det er snakk om enkeltsekvenser i et lengre verk med \"vanlige\" filmopptak, eller når det er blanding av live action og animasjon i samme bilde. Omfatter ikke enkel grafikk [red.]."@nb ;
    skos:example "Knerten gifter seg (2010) (Mavis 817339)"@nb,
        "Sørlandet i sommersol (1934) (Mavis 815867)"@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Live-action/animation films"@en,
        "Animasjonsinnslag"@nb,
        "Animasjonsinnslag"@nn .

<https://id.nb.no/vocabulary/ntsf/1316> a skos:Concept ;
    dct:created "2022-02-20T16:52:54"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Uredigerte film- og videoopptak som dokumenterer en hendelse, en person, et sted [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026712> ;
    skos:example "[Dykkere plukker søppel ved oljelagringstank] : [uredigert materiale] (1988) [mavis 160769]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Unedited footage"@en,
        "Dokumentasjonsopptak (film)"@nb,
        "Dokumentasjonsopptak (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/1319> a skos:Concept ;
    dct:created "2022-02-20T16:58:49"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Dramafilm er en filmsjanger som for det meste omhandler mellommenneskelige og følelsesmessige forhold. Tema som alkoholisme, narkomani, rasemessige fordommer, religiøs intoleranse, fattigdom, kriminalitet og korrupsjon kan være tema i dramafilmer, hvor rollefiguren gjennom én eller flere av disse kommer i konflikt med seg selv, andre eller samfunnet for øvrig (Wikipedia)."@nb ;
    skos:example "Ett glass til."@nb,
        "Fucking Åmål"@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Dramas (motion pictures)"@en,
        "Drama (film)"@nb,
        "Drama (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/1321> a skos:Concept ;
    dct:created "2022-02-20T17:05:41"^^xsd:dateTime ;
    dct:modified "2022-02-20T17:09:06"^^xsd:dateTime ;
    skos:altLabel "Avantgarde filmer"@nb,
        "Avantgardefilmer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Eksperimentell film, også kalt avant garde-film og kunstfilm, er film som utfordrer tekniske og/eller narrative konvensjoner innen filmproduksjon [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026235> ;
    skos:example "Abstrakt (1967) (mavis 16422307)."@nb,
        "Den hvite streken (1978) (Mavis 811632)."@nb,
        "Dogville (2003)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Experimental films"@en,
        "Eksperimentelle filmer"@nb,
        "Eksperimentelle filmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1330> a skos:Concept ;
    dct:created "2022-02-20T17:37:39"^^xsd:dateTime ;
    dct:modified "2022-05-06T06:45:44"^^xsd:dateTime ;
    skos:altLabel "TV-teater"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1205> ;
    skos:definition "Teaterforestilling produsert for fjernsyn [NAOB]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Television plays"@en,
        "Fjernsynsteater"@nb,
        "Fjernsynsteater"@nn ;
    skos:scopeNote "Viser til forestillingene fra Fjernsynsteatret, NRKs teater, som eksisterte i årene 1960-1991. Noen av dem har også blitt utgitt på DVD."@nb .

<https://id.nb.no/vocabulary/ntsf/1333> a skos:Concept ;
    dct:created "2022-02-20T17:45:13"^^xsd:dateTime ;
    dct:modified "2022-02-20T17:48:43"^^xsd:dateTime ;
    skos:altLabel "Horror (film)"@nb,
        "Skrekkfilmer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Skrekkfilm, gjerne med overnaturlige elementer. Skal vekke ubehag og skremme tilskueren [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026321> ;
    skos:example "Frankenstein."@nb,
        "Fritt vilt."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Horror films"@en,
        "Grøssere (film)"@nb,
        "Grøssarar (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/134> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:altLabel "Introduksjoner"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "En innledning forteller hva en bok eller artikkel handler om [red.]."@nb ;
    skos:example """Innledning / Eivind Tjønneland. -\r
I: Henrik Ibsens Kongs-Emnerne : teater, historie og resepsjon. - S. 7-[22]."""@nb,
        """Introdukshon / P.C. -\r
I: Nora su Kas di Pòpchi. - ['s Gravenhage : P. Comenencia], cop. 2016. - S. 5-6."""@nb,
        """Introduzione / di Giovanni Antonucci. -\r
I: I capolavori. - Roma : Newton Compton editori, 2016. - S. [VII]-XVI."""@nb,
        """When we dead awaken : introduction. -\r
I: The works of Henrik Ibsen. Little Eyolf ; John Gabriel Borkman ; When we dead awaken. - [S.l.] : [Read Books], [2011]. - S. 353-358.\r
Skrevet av William Archer."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Introductions"@en,
        "Innledninger"@nb,
        "Innleiingar"@nn ;
    skos:scopeNote "Brukes om innledninger til bøker."@nb .

<https://id.nb.no/vocabulary/ntsf/1344> a skos:Concept ;
    dct:created "2022-02-21T07:04:05"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1290> ;
    skos:definition "Opptak av livekonserter [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026161> ;
    skos:example "Roger Waters: The wall."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Concert films"@en,
        "Konsertfilmer"@nb,
        "Konsertfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1347> a skos:Concept ;
    dct:created "2022-02-21T07:12:14"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1205> ;
    skos:definition "Musikkvideo er en kortfilm ment for å representere en melodi eller sang visuelt. Musikkvideoer som ledsager låter spiller en stor rolle innen markedsføring av popmusikk. Musikkvideoer kan også sikte til langfilmer med hovedsakelig musikalsk innhold, og videoer (VHS/DVD) med konsertopptak, eller flere klipp med videoer av sanger, eller kombinasjon av disse [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026413> ;
    skos:example "Adjø Montebello (2017) )(Mavis 16422405)."@nb,
        "Romeo (1986) (Mavis 275638)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Music videos"@en,
        "Musikkvideoer"@nb,
        "Musikkvideoar"@nn .

<https://id.nb.no/vocabulary/ntsf/135> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:altLabel "Conversations"@en,
        "Dialogues"@en,
        "Portrettintervjuer"@nb,
        "Samtalebøker"@nb,
        "Samtaler"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/475> ;
    skos:definition "Intervju er en samtale mellom vanligvis en journalist, kalt intervjueren, og en annen person, ofte kalt intervjuobjektet, der journalisten spør objektet om en sak, om personen selv eller om meningene hans eller hennes, altså saksintervju eller portrettintervju. Intervju er også betegnelse på den ferdige teksten, avisartikkelen, radio- eller fjernsynsinnslaget fra en slik samtale. Intervju kan også bety forhør, spørreundersøkelse og jobbintervju. Intervju blir ofte brukt av journalister, forskere, arbeidsgivere og andre i arbeidsdagen [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026115> ;
    skos:example "Dag Solstad : uskrevne memoarer / Alf van der Hagen."@nb,
        "Det særegne ved å være nordmann : samtale med Dag Solstad / Jan Kjærstad."@nb,
        "På sporet av vår tid : [intervju med Dag Solstad] / Alf Marius Opsahl og Tzachi Itzchaki (illustrasjon)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Interviews"@en,
        "Intervjuer"@nb,
        "Intervju"@nn ;
    skos:scopeNote "Brukes både for intervjuer i aviser og tidsskrifter, og for bøker som er basert på intervjuer eller samtaler."@nb .

<https://id.nb.no/vocabulary/ntsf/1350> a skos:Concept ;
    dct:created "2022-02-21T07:28:15"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer produsert på oppdrag fra eksempelvis organisasjoner, det offentlige eller næringslivet. Vanligvis filmer som skal informere eller instruere seeren og som produseres etter oppdragsgiverens ønsker og behov. Omfatter ikke rene reklamefilmer [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026599> ;
    skos:example "Christiania Spigerverk : en tur gjennom avdelingene for ferdigfabrikata (1925) [mavis 5699)."@nb,
        "Elverum Energi 100 år (2008) [mavis 1010375]."@nb,
        "Grevebyen Larvik (1949) [mavis 56626]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Sponsored films"@en,
        "Oppdragsfilmer"@nb,
        "Oppdragsfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1353> a skos:Concept ;
    dct:created "2022-02-21T07:40:38"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:altLabel "Politisk propaganda (film)"@nb,
        "Valgfilmer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer som er laget for å påvirke politiske holdninger og adferd i et samfunn. For eksempel valgfilm [red.]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Political commercials (film)"@en,
        "Politisk reklame (film)"@nb,
        "Politisk reklame (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/137> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2020-04-15T11:02:25"^^xsd:dateTime ;
    skos:altLabel "Christmas comic books"@en,
        "Christmas comics"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Et julehefte er en publikasjon som utgis i forkant av jul. Siden julehefter ble vanlig på slutten av 1800-tallet, har det utkommet hefter med om lag 800 ulike titler og 20-30 000 ulike hefter. Mange har vært svært ulike i form, innhold og kvalitet. De fleste juleheftene som utkommer i dag, er tegneserier (Wikipedia)."@nb ;
    skos:example "Vangsgutane julen 2019 / av Nils Nordberg."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Christmas magazines"@en,
        "Julehefter"@nb,
        "Julehefte"@nn .

<https://id.nb.no/vocabulary/ntsf/1376> a skos:Concept ;
    dct:created "2022-06-27T12:32:53"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Film som inngir spenning [NAOB]."@nb ;
    skos:example "The beach (2000)."@nb,
        "Trio : Odins gull (2014)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Spenning (film)"@nb,
        "Spenning (film)"@nn ;
    skos:scopeNote "Brukes på spenningsfilmer som ikke passer inn under krim eller thriller. Særlig brukt for barn."@nb .

<https://id.nb.no/vocabulary/ntsf/1378> a skos:Concept ;
    dct:created "2022-06-27T12:38:07"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "[Film om] fiktiv karakter med overnaturlige krefter eller evner [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026621> ;
    skos:example "Black panther (2018)."@nb,
        "The dark knight (2008)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Superhero films"@en,
        "Superhelter (film)"@nb,
        "Superheltar (film)"@nn ;
    skos:scopeNote "Brukes om filmer om fiktive personer som av ulike årsaker har superkrefter."@nb .

<https://id.nb.no/vocabulary/ntsf/1381> a skos:Concept ;
    dct:created "2022-06-27T12:44:28"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/107> ;
    skos:definition "Bøker hvor leseren selv kan velge mellom alternativer for å endre fortellingens utfall [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026259> ;
    skos:example "Victor : Driblekongen / Lars Bøgeholt Pedersen )"@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Choose-your-own-stories"@en,
        "Interaktive fortellinger"@nb,
        "Interaktive forteljingar"@nn ;
    skos:scopeNote "For barn og ungdom."@nb .

<https://id.nb.no/vocabulary/ntsf/147> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2025-06-27T16:41:54"^^xsd:dateTime ;
    skos:altLabel "Kjærlighet"@nb,
        "Kjærlighetsromaner"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Skjønnlitteratur som skildrer kjærlighet og romanse mellom to personer, ofte med lykkelig slutt [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026516> ;
    skos:example "Et helt halvt år / Jojo Moyes."@nb,
        "Kjærlighetens ansikt / Sarah Jio."@nb,
        "Lykken smiler / Frid Ingulstad."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Romance fiction"@en,
        "Romantikk"@nb,
        "Romantikk"@nn ;
    skos:scopeNote "Ofte serielitteratur."@nb .

<https://id.nb.no/vocabulary/ntsf/1472> a skos:Concept ;
    dct:created "2022-08-24T13:23:19"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/17> ;
    skos:definition "En oversikt over folkegrupper organisert etter geografisk tilhørighet. Gyldigheten til en slik organisering av folkegrupper over tid er tvilsom [red.]."@nb ;
    skos:example "Atlante linguistico etnografico della Daunia / di Armistizio Matteo Melillo."@nb,
        "Atlas de afrodescendientes en América Latina / [idea original y textos: Ildefonso Gutiérrez Azopardo ; dirección cartográfica: Cándida Gago García]."@nb,
        "Atlas lingüístico-etnográfico de Colombia / José Joaquín Montes, Jennie Figueroa ... [et al.]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Ethnographic atlases"@en,
        "Etnografiske atlas"@nb,
        "Etnografiske atlas"@nn .

<https://id.nb.no/vocabulary/ntsf/1473> a skos:Concept ;
    dct:created "2022-08-24T13:28:56"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/17> ;
    skos:definition "Atlas over historiske områder, perioder, hendelser m.m. som tar for seg historisk geografi, hvordan grenser om land har endret seg over tid [red.]."@nb ;
    skos:example "A historical atlas of Tibet / Karl E. Ryavec."@nb,
        "Atlas histórico de España en la Edad Moderna / Porfirio Sanz Camañes."@nb,
        "Historisk atlas / ved Oddvar Bjørklund."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Historical atlases"@en,
        "Historiske atlas"@nb,
        "Historiske atlas"@nn .

<https://id.nb.no/vocabulary/ntsf/1474> a skos:Concept ;
    dct:created "2022-08-24T13:33:59"^^xsd:dateTime ;
    skos:altLabel "Atlases of languages"@en,
        "Dialect atlases"@en,
        "Linguistic atlases"@en,
        "Dialektatlas"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/17> ;
    skos:definition "Språkatlas er et kart som kan vise enten utbredelsen av forskjellige språk eller dialekter, eller utbredelsen av ord og språklige fenomener, særlig innenfor området til et hovedspråk [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026365> ;
    skos:example "Atlas of the world's languages / general editors R.E. Asher and Christopher Moseley."@nb,
        "The Atlas and survey of Pidgin and Creol languages / Susanne Maria Michaelis ... [et al.] ; in collaboration with Maleanie Revis, Bradley Taylor, and the APiCS Consortium."@nb,
        "Wortatlas der arabischen Dialekte. Bd. 1, Mensch, Natur, Fauna, Flora / Peter Behnstedt."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Language atlases"@en,
        "Språkatlas"@nb,
        "Språkatlas"@nn .

<https://id.nb.no/vocabulary/ntsf/148> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-07T13:36:13"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/425> ;
    skos:definition "Bøker med klaffer til å åpne eller dra i, oftest brukt på bøker for små barn [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026123> ;
    skos:example "Fantorangen gjemmer seg /  illustrasjoner: José Maria Cardona."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Lift-the-flap books"@en,
        "Klaffebøker"@nb,
        "Klaffebøker"@nn .

<https://id.nb.no/vocabulary/ntsf/15> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2025-12-11T14:23:35"^^xsd:dateTime ;
    skos:altLabel "Anthology"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "En antologi er en samling litterære tekster som gjerne er utgitt tidligere. Leseverk og lignende er egentlig antologier, men begrepet brukes oftest for samlinger av tekster fra en sjanger, periode, forfatter, retning eller et tema. Novelle- og diktantologier er de vanligste formene (SNL)."@nb ;
    skos:example "Amerika forteller / Gordon Hølmebakk (red.)."@nb,
        "Dikt fra antikken til vår tid / Jon Haarberg (red.)."@nb,
        "Vinternatt : norske kriminalnoveller / Nils Nordberg (red.)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Anthologies"@en,
        "Antologier"@nb,
        "Antologiar"@nn ;
    skos:scopeNote "Brukes om samlinger med skjønnlitterære tekster av flere forfattere."@nb .

<https://id.nb.no/vocabulary/ntsf/150> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-07T12:29:38"^^xsd:dateTime ;
    skos:altLabel "Cookery books"@en,
        "Food recipes"@en,
        "Kokebok"@nb,
        "Matoppskrifter"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Samlinger av matoppskrifter i bokform [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026169> ;
    skos:example "Oppskrifter enhver mann bør kunne / Susan Russo."@nb,
        "Opptur med sunne middagar / Linda Stuhaug."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Cookbooks"@en,
        "Kokebøker"@nb,
        "Kokebøker"@nn .

<https://id.nb.no/vocabulary/ntsf/1528> a skos:Concept ;
    dct:created "2022-08-31T10:55:47"^^xsd:dateTime ;
    skos:altLabel "Language classes"@en,
        "Language lessons"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Læremiddel til bruk i språkundervisning, ofte i flere deler og med lydvedlegg [UBO]."@nb ;
    skos:example "Viva! : portugisisk fremmedspråk - nivå 1 / Graciete Londrim ... [et al.]."@nb,
        "Voyage en France / Anne Bjørnebek, Tonelise Hustad."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Language courses"@en,
        "Språkkurs"@nb,
        "Språkkurs"@nn .

<https://id.nb.no/vocabulary/ntsf/1533> a skos:Concept ;
    dct:created "2022-08-31T11:04:04"^^xsd:dateTime ;
    skos:altLabel "Roleplaying games"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/479> ;
    skos:definition "(Brett- eller data)spill hvor hver deltager tildeles en rolleskikkelse med visse grunnleggende egenskaper som skal løse en rekke oppgaver og gjennomgå en rekke prøvelser for å nå et fastlagt mål i en oppdiktet verden [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2020026012> ;
    skos:example "Dragepust : et rollespill av Krogsrud-Strøm, Sollien og Stangeland. - 9788284010984."@nb,
        "Itras by : et surrealistisk rollespill av Giæver og Gudmundsen. - 9788284010311."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Role-playing games"@en,
        "Rollespill"@nb,
        "Rollespel"@nn ;
    skos:scopeNote "Brukt for litterære rollespill (LitRPG). Brukes for skjønnlitteratur som følger samme struktur som et tv-spill eller rollespill, eller har samme type utfordringer som man finner i alle typer spill, eller som foregår i et tv-spill, nettspill, rollespill, etc. Brukes med andre litterære termer."@nb .

<https://id.nb.no/vocabulary/ntsf/1547> a skos:Concept ;
    dct:created "2022-09-05T09:57:16"^^xsd:dateTime ;
    skos:altLabel "Publishers catalogues"@en,
        "Publishers' catalogs"@en,
        "Publishing catalogs"@en,
        "Publishing catalogues"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/356> ;
    skos:definition "Katalog over bøker og verker utgitt på et forlag [NAOB]."@nb ;
    skos:example "11 år med ellerströms."@nb,
        "Bøker 1868-1992 : ein forlagsbibliografi / Det norske Samlaget."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Publishers' catalogues"@en,
        "Forlagskataloger"@nb,
        "Forlagskatalogar"@nn .

<https://id.nb.no/vocabulary/ntsf/1554> a skos:Concept ;
    dct:created "2022-09-05T10:20:38"^^xsd:dateTime ;
    dct:modified "2022-09-05T10:20:50"^^xsd:dateTime ;
    skos:altLabel "National bibliography"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/29> ;
    skos:definition "Nasjonalbibliografi, fortegnelse over et lands eller språkområdes samlede litterære produksjon. [SNL]."@nb ;
    skos:example "Forsøg til en Fortegnelse over de udi Danmark og Norge fra Bogtrykkeriets Indførsel til 1789 Aars Udgang udkomne Danske Skrifter / samlede af Claus L. Fasting, Collega ved Bergens Cathedral-Skole."@nb,
        "Knjige u tisku : CIP - katalogizacija u publikaciji / Nacionalna i sveučilišna knjižnica u Zagrebu."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "National bibliographies"@en,
        "Nasjonalbibliografier"@nb,
        "Nasjonalbibliografiar"@nn .

<https://id.nb.no/vocabulary/ntsf/1559> a skos:Concept ;
    dct:created "2022-09-05T10:49:27"^^xsd:dateTime ;
    skos:altLabel "Union catalogs"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144> ;
    skos:definition "Katalog som samlet dekker adskilte dokumentsamlinger fra fortrinnsvis selvstendige bibliotek [Biblioterm]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026205> ;
    skos:example "British union-catalogue of periodicals."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Union catalogues"@en,
        "Samkataloger"@nb,
        "Samkatalogar"@nn .

<https://id.nb.no/vocabulary/ntsf/156> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:altLabel "Prosastykker"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Kortprosa er en skjønnlitterær sjanger og er et generisk begrep for ulike former for svært korte fiksjonsprosa. Kortprosa kan eller kan ikke være fortellende [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026543> ;
    skos:example "Gravgaver /  Tor Ulven."@nb,
        "Oss imellom? / Einar Økland."@nb,
        "Samlede kortprosa / Jan Erik Vold."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Flash fiction"@en,
        "Kortprosa"@nb,
        "Kortprosa"@nn ;
    skos:scopeNote "Brukes her for beskrive korte, skjønnlitterære tekster. Tekstene kan ha fortellende element, men det vil ikke være naturlig å kalle dem noveller, der kravet til handlingsforløp og karakterer er mer definert [BS]."@nb .

<https://id.nb.no/vocabulary/ntsf/1563> a skos:Concept ;
    dct:created "2022-09-05T11:00:29"^^xsd:dateTime ;
    skos:altLabel "Universal bibliography"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/29> ;
    skos:definition "Bibliografi over litteratur som skal dekke alle kunnskapsfelt og fag [Biblioterm]."@nb ;
    skos:example "Collectio in unum corpus omnium librorum Hebraeorum, Graecorum, Latinorum necnon Germanice, Italice, Gallicè, & Hispanicè scriptorum : qui in Nundinis Francofurtensibus ab anno 1564 usque ad Nundinas autumnales anni 1592, partim novi, partim nova forma, & diversis in locis editi, venales extiterunt."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Universal bibliographies"@en,
        "Universalbibliografier"@nb,
        "Universalbibliografiar"@nn .

<https://id.nb.no/vocabulary/ntsf/157> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-11-15T10:29:02"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/258> ;
    skos:definition "En kortroman (engelsk novella, tysk Novelle) er en mellomlang skjønnlitterær prosatekst; kortere enn en roman og lengre enn en novelle. Ofte avgrenses kortromaner til tekster rundt 15 000 til 40 000 ord (Wikipedia)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026019> ;
    skos:example "Elsken / Tomas Espedal."@nb,
        "Hvit / Han Kang."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Novellas"@en,
        "Kortromaner"@nb,
        "Kortromanar"@nn .

<https://id.nb.no/vocabulary/ntsf/159> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Detective fiction"@en,
        "Mystery fiction"@en,
        "Politi og detektiver"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/578> ;
    skos:definition "Fortellinger om forbrytelser – som oftest drap – og oppklaringen av dem. Vanligvis regnes Edgar Allan Poes novelle Mordene i Rue Morgue som den første kriminalfortelling (Wikipedia)."@nb ;
    skos:example "Camilla Läckberg/ Isprinsessen."@nb,
        "Mord på Orientekspressen / Agatha Christie."@nb,
        "Rødstrupe /Jo Nesbø."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Crime fiction"@en,
        "Krim"@nb,
        "Krim"@nn ;
    skos:scopeNote "Brukes på skjønnlitteratur hvor fokuset er på å oppklare forbrytelser, ofte drap og ofte med politi og detektiver i hovedrollen. Som regel brukt på litteratur for voksne."@nb .

<https://id.nb.no/vocabulary/ntsf/1636> a skos:Concept ;
    dct:created "2022-10-05T12:04:57"^^xsd:dateTime ;
    skos:altLabel "Dagspresse"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/340> ;
    skos:definition "Regelmessig, ofte daglig publikasjon med nyheter, reportasjer, artikler, annonser o.l. (NAOB)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026132> ;
    skos:example "Dag og tid (trykt utg.)."@nb,
        "Norske Intelligentssedler (1763)."@nb,
        "Smaalenenes avis."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Newspapers"@en,
        "Aviser"@nb,
        "Aviser"@nn ;
    skos:scopeNote "Brukes om regelmessige publikasjoner med minst en utgave per uke."@nb .

<https://id.nb.no/vocabulary/ntsf/164> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/404> ;
    skos:definition "Kunngjøring, meddelelse fra det offentlige eller private til allmennheten eller en større krets adressater. Kunngjøring har i tidens løp foregått på forskjellig vis, fra meddelelser ved budstikke, bauner eller trommeslag, ved høytlesning på tinget, kirkebakken eller fra prekestolen, frem til nåtidens meddelelser gjennom kringkasting, aviser og oppslag, flyveblad, annonser, masseutsendelser, på nettsider, SMS eller andre elektroniske plattformer [SNL]."@nb ;
    skos:example """Anordning ved Hans Kongelige Høihed Kronprindsens Prinds Joseph Frans Oscars tilkommende Gemalindes, Hendes Kongelige Høihed Prindsessen Josephine Maximiliana Eugenia af Leuchtenberg, Indtog i Residentsen (Stockholm) og den derpaa følgende Formæling ; Kongelig Kundgjørelse angaaende Afgifter af Varer og Fartøier for Tidsrummet fra 1ste Januar 1846 til 1ste Juli 1848.\r
[kilde: Norske bøker 1519-1850]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Announcements"@en,
        "Kunngjøringer"@nb,
        "Kunngjeringar"@nn ;
    skos:scopeNote "Hovedsakelig brukt på eldre materiale."@nb .

<https://id.nb.no/vocabulary/ntsf/1642> a skos:Concept ;
    dct:created "2022-10-10T10:31:35"^^xsd:dateTime ;
