        <https://id.nb.no/vocabulary/ntsf/453> ;
    skos:definition "Lokalhistorie er historieskriving på lokalt nivå, særlig bygde- og byhistorie  [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2017026152> ;
    skos:example "Det hende i Telemark : historier om dåd og udåd fortalt i Varden / Halvor Ulvenes."@nb,
        "Lokalhistorisk årbok for Rogaland / redigert av Jan K. Hognestad."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/2806>,
        <https://id.nb.no/vocabulary/ntsf/610> ;
    skos:prefLabel "Local histories"@en,
        "Lokalhistorie"@nb,
        "Lokalhistorie"@nn ;
    skos:scopeNote "Brukes kun om historie på lokalt nivå som ikke kan avgrenses til bygdehistorie eller byhistorie."@nb .

