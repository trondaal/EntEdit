    skos:example "Biler i Norge før 1970 : bilder og historier / [redaktør:] Arne Årseth."@nb,
        "Gamle bilder frå Nordhordland / Arne Årseth."@nb,
        "Norges krig i farger : 1940–45 i nytt lys / Niklas Lindblad og Daniel Voje ; redigert av Finn Jørgen Solberg."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
