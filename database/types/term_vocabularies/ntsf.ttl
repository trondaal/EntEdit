<https://id.nb.no/vocabulary/ntsf/220> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/310> ;
    skos:definition "Orienteringskart, svært detaljerte topografiske kart i store målestokker, spesielt laget for orienteringsløp. Fremstilling av fremkommelighet og representasjon av vesentlige orienteringsdetaljer er spesielt viktig for o-kart. Lesbarhet og nabonøyaktighet er viktigere enn absolutt posisjonsnøyaktighet [SNL]."@nb ;
    skos:example "Sunnmørsalpene : topp- og turkart."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Orienteering maps"@en,
        "Orienteringskart"@nb,
        "Orienteringskart"@nn .

<https://id.nb.no/vocabulary/ntsf/2202> a skos:Concept ;
    dct:created "2023-02-14T09:49:08"^^xsd:dateTime ;
    skos:altLabel "Classification schemes"@en,
        "Klassifikasjonsskjemaer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/339> ;
