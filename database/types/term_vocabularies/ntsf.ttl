<https://id.nb.no/vocabulary/ntsf/1819> a skos:Concept ;
    dct:created "2022-11-15T12:40:11"^^xsd:dateTime ;
    skos:altLabel "Kalendarium"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/138> ;
    skos:definition "Fortegnelse over kirkelige minne- og festdager"@nb ;
    skos:example "Calendarium perpetuum : Schiebetafel zum Kirchen- und Kalenderjahr."@nb ;
