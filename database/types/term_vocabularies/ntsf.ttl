    skos:example "Norsk orkestermusikk : 2800 norske orkesterverk fra barokken til vår egen tid = Norwegian orchestral music : 2800 Norwegian orchestral works from the Baroque era to the present."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Comprehensive catalogues"@en,
