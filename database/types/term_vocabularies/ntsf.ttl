<https://id.nb.no/vocabulary/ntsf/1029> a skos:Concept ;
    dct:created "2021-01-11T09:33:26"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Award theses"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/19> ;
    skos:definition "Et prisskrift er et skrift eller avhandling, som har vunnet en pris i konkurranser utlyst av vitenskapelige selskaper, etc., spesielt på 1700-tallet (NB)."@nb ;
    skos:example """Forsøg om Dragten især for Danmark og Norge / af C. Pram. \r
"Kronet med den anden af de Tre i Aaret 1788 udsatte Præmier for Besvarelsen af Spørgsmaalet: Er det nyttigt eller skadeligt at indføre en National-Dragt?"\r
[kilde: Norske bøker 1519-1850]"""@nb,
        """Forsøg om en Højskoles Anlæg i Norge efter den af et Selskab i Christiania fremsatte Priisopgave : Et Priisskrift / af Christen Pram.\r
[kilde: Norske bøker 1519-1850]"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Award thesis"@en,
        "Prisskrifter"@nb,
        "Prisskrift"@nn .

