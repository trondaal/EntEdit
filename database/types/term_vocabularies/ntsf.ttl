        "The vocabulary of Bjørnson's literary works : a word index and word count of a Norwegian author / Einar Haugen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Concordances"@en,
        "Konkordanser"@nb,
        "Konkordansar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/1502> .

