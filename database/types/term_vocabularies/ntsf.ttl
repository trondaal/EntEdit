<https://id.nb.no/vocabulary/ntsf/1069> a skos:Concept ;
    dct:created "2021-02-01T10:10:29"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:altLabel "Prayer books"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/503> ;
    skos:definition "En bønnebok er en bok som inneholder bønner og kanskje andaktslesninger, til privat eller felles bruk, eller i noen tilfeller som skisserer liturgien til religiøse tjenester. [Wikipedia (engelsk)]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026049> ;
    skos:example "Bahá'í bønner : et utvalg bønner åpenbart av Báb, Bahá'u'lláh og ´Abdu'l-Bahá."@nb,
        "Bønnebog for Land- og Søemand, til hver Dag i Ugen, med nogle hosføiede Psalmer, samt Bønner og Sange for de indfaldende Høitidsdage i Aaret / Samlede ved A.U. Schjeldrop, af Trondenes Menighed i Senjen."@nb,
        "Morgen- og Aften-Bønner til hver Dag i Ugen, i fire Uger, til Brug for dem, der holde Huusandagt."@nb,
        "Tidebønn : daglige bønner fra Bibelen / Helge Unneland."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1737> ;
    skos:prefLabel "Prayers"@en,
        "Bønnebøker"@nb,
        "Bønebøker"@nn .

