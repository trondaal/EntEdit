<https://id.nb.no/vocabulary/ntsf/1128> a skos:Concept ;
    dct:created "2021-09-23T11:52:27"^^xsd:dateTime ;
    dct:modified "2022-06-27T11:53:17"^^xsd:dateTime ;
    skos:altLabel "Actionfilmer"@nb,
        "Action"@nn ;
    skos:broadMatch <http://id.loc.gov/authorities/genreForms/gf2011026005> ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Actionfilm er et begrep på en spesiell filmsjanger og kommer av det engelske ordet for handling. Handlingen i en actionfilm er gjerne preget av mange kjappe og voldsomme hendelser som ofte blir drevet frem av kamp mot tid eller store og ofte onde krefter, eller begge deler. Ofte inngår en eller annen form for vold som slagsmål, biljakter, skytescener eller eksplosjoner som elementer i handlingen, og ofte krever slike scener mange spesialeffekter og stuntmenn for å få dem til å se bra ut (Wikipedia)."@nb ;
    skos:example "Fight Club (1999)."@nb,
        "James Bond."@nb,
        "Jason Bourne."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1157> ;
    skos:prefLabel "Action films"@en,
        "Action"@nb,
        "Actionfilmar"@nn ;
    skos:scopeNote "Brukes om handlingsmettede filmer, ofte med elementer som biljakter, skytescener og eksplosjoner."@nb .

<https://id.nb.no/vocabulary/ntsf/1153> a skos:Concept ;
    dct:created "2021-09-30T12:49:22"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Kortfilm er film som er kortere enn den vanlige langfilmen på kino. Begrepet brukes som regel om film med 30–40 minutters spilletid eller mindre [snl]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026570> ;
    skos:example "Den andalusiske hund."@nb,
        "Teak og palisander (1968)."@nb,
        "Veslefrikk med fela (1954)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1304> ;
    skos:prefLabel "Short films"@en,
        "Kortfilmer"@nb,
        "Kortfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1163> a skos:Concept ;
    dct:created "2021-09-30T15:39:28"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition """Stumfilm er film uten innspilt lyd, og dermed også uten hørbar dialog. Stumfilmens storhetsperiode varte fra filmmediets gjennombrudd i 1895 til slutten av 1920-tallet, da lydfilmen kom.\r
Stumfilmen kjennetegnes ved at deler av fortellingen, blant annet replikkene, blir formidlet gjennom tekstplakater på lerretet, såkalte "mellomtekster" (SNL)."""@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026575> ;
    skos:example "Byens lys (1917)."@nb,
        "Klokkeren fra Notre Dame (1923)."@nb,
        "Metropolis (1927, ny versjon 2013)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1304> ;
    skos:prefLabel "Silent films"@en,
        "Stumfilmer"@nb,
        "Stumfilmar"@nn ;
    skos:scopeNote "Filmer som er produsert i filmindustriens tidlige dager, før introduksjonen av filmer med synkronlyd. Stumfilmer har forklarende mellomtekster og ble akkompagnert med musikk"@nb .

<https://id.nb.no/vocabulary/ntsf/1188> a skos:Concept ;
    dct:created "2021-10-13T12:57:31"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer med fokus på fiktiv vitenskap og teknologi og som gjerne finner sted i en fremtid. Inneholder ofte romreiser, tidsreiser, og utenomjordiske livsformer [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026556.> ;
    skos:example "Blade runner."@nb,
        "Star trek."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1191> ;
    skos:prefLabel "Science fiction films"@en,
        "Science fiction (film)"@nb,
        "Science fiction (film)"@nn .

<https://id.nb.no/vocabulary/ntsf/1196> a skos:Concept ;
    dct:created "2021-10-13T13:45:29"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Brukes på filmer hvor fokuset er på å oppklare forbrytelser, ofte drap og ofte med politi og detektiver i hovedrollen [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026177> ;
    skos:example "Fargo."@nb,
        "Hodejegerne."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1199> ;
    skos:prefLabel "Crime films"@en,
        "Krim (film)"@nb,
        "Krim(film)"@nn ;
    skos:scopeNote "Som regel brukt på filmer for voksne."@nb .

<https://id.nb.no/vocabulary/ntsf/12> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/213> ;
    skos:definition "Andaktsbok er en bok som inneholder andakter, korte tekster som oftest basert på avsnitt fra Bibelen. Tekstene er beregnet til personlig oppbyggelse [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026056> ;
    skos:example "Du er elsket : et år med andakter for det åndelige livet / av Henri J.M. Nouwen."@nb,
        """Huus-Postil, eller En Samling af forskjellige Forfatteres, meest Luthers, Franckes og Pontoppidans, Betragtninger over Søn- og Fest-Dages deels Høimesse-, deels Aftensangs-Texter, samlede til en Aargang, og udgivne i den Hensigt, at befordre og vedligeholde christelig Huus-Andagt.\r
[kilde: Norske bøker 1519-1850]."""@nb,
        "Mandeltreet : 366 dikt og bibelord : andaktsbok / Haldis Totland Reigstad."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/237> ;
    skos:prefLabel "Meditations"@en,
        "Andaktsbøker"@nb,
        "Andaktsbøker"@nn .

<https://id.nb.no/vocabulary/ntsf/120> a skos:Concept ;
