    skos:example "Leonard Cohens horoskop : mystikk og sensualitet."@nb,
        "[I mørkeste Nat er den lyseste Tid]. I: Lykke- og Temperamentsblad. - Nr. 11."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Horoscopes"@en,
