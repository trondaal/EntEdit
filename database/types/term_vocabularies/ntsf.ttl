        "Haikerens guide til galaksen / Douglas Adams."@nb,
        "Ready player one / Ernest Cline."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Science fiction"@en,
        "Science fiction"@nb,
        "Science fiction"@nn .

<https://id.nb.no/vocabulary/ntsf/2712> a skos:Concept ;
    dct:created "2024-02-06T08:59:43"^^xsd:dateTime ;
    dct:modified "2024-02-27T09:04:45"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/14> ;
    skos:definition "Tekst som refererer og/eller vurderer en revyforestilling."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Revue recensions"@en,
        "Revyanmeldelser"@nb,
        "Revymeldingar"@nn .

<https://id.nb.no/vocabulary/ntsf/273> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-11-15T12:56:11"^^xsd:dateTime ;
    skos:altLabel "Romanserier"@nb,
        "Seriefiksjon"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/258> ;
    skos:definition "En lengre sammenhengende og avsluttet fortellende serie, som er minst 65–100 sider lang (verkets ”lengde” har også å gjøre med f.eks. antall bilder pr side, og kan derfor ikke  defineres  bare ved hjelp av sidetall). Begrepet omfatter ikke samlingar av episoder i en lengre løpende serie hvis disse ikke danner en større helhet som er tydelig sammenhengende og avsluttet (oversatt fra KB sjanger og formtesaurus, skjønnlitteratur)."@nb ;
    skos:example "Morgan Kane / Louis Masterson."@nb,
        "Sagaen om isfolket / Margit Sandemo."@nb,
        "Sønnavind / Frid Ingulstad."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Serieromaner"@nb,
        "Serieromanar"@nn ;
    skos:scopeNote "Brukes for skjønnlitteratur som utgis med en fast utgivelsesfrekvens, og med mange titler i serien. Selges ofte i kiosker og er ofte heftet."@nb .

<https://id.nb.no/vocabulary/ntsf/275> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-08-30T14:01:54"^^xsd:dateTime ;
    skos:altLabel "Sjøromaner"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Roman som omhandler livet til sjøs ; sjøfortelling [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2016026006> ;
    skos:example "En sjøens helt / Jon Michelet."@nb,
        "Skatten på sjørøverøya / R.L. Stevenson."@nb,
        "Toktet til Mauritius / Patrick O'Brian."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Sea fiction"@en,
        "Sjøfortellinger"@nb,
        "Sjøforteljingar"@nn ;
    skos:scopeNote "Brukes for skjønnlitteratur hvor handlingen er knyttet til livet på sjøen."@nb .

<https://id.nb.no/vocabulary/ntsf/2753> a skos:Concept ;
    dct:created "2024-03-13T08:12:09"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1070> ;
    skos:definition "Nivåskjemaet for et atom er en grafisk fremstilling av atomets energitilstander. Hver tilstand (eller nivå) tegnes som en vannrett strek, som vist i figuren, og kan beregnes ved å bruke kvantemekanikk [snl]."@nb ;
    skos:example "Nuclear structure along the Z = 28 and Z = 50 shells : shell evolution and shape coexistence in 74,76,78Cu and 126Sn  /  Line Gaard Pedersen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Level schemes"@en,
        "Nivåskjemaer"@nb,
        "Nivåskjema"@nn .

<https://id.nb.no/vocabulary/ntsf/276> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-03-07T10:55:44"^^xsd:dateTime ;
    skos:altLabel "Navigation charts"@en,
        "Draft"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/141> ;
    skos:definition "En grafisk fremstilling av et hav eller kystområde [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/subjects/sh85090331> ;
    skos:example "Indre Oslofjord : kystkart : Oslo - Larkollen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Nautical charts"@en,
        "Sjøkart"@nb,
        "Sjøkart"@nn ;
    skos:scopeNote "Definisjonen omfatter også innsjøer."@nb .

<https://id.nb.no/vocabulary/ntsf/2776> a skos:Concept ;
    dct:created "2024-04-03T07:58:41"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Multiple art"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1070> ;
    skos:definition "Kunstverk som er ment for salg eller distribusjon og er identisk produsert, noen ganger i ubegrenset antall, slik at det ikke er noen original"@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Multiples (Art)"@en,
        "Multipler (Kunst)"@nb,
        "Multiplar (kunst)"@nn .

<https://id.nb.no/vocabulary/ntsf/2799> a skos:Concept ;
    dct:created "2024-04-22T13:35:41"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/99> ;
    skos:definition "Oversikt over moser som vokser innenfor et bestemt område eller i en bestemt periode [UBO]"@nb ;
    skos:example "Distribution of bryophytes on Fuerteventura and Lanzarote, the Canary Islands."@nb,
        "Sjekkliste over norske mosar : vitskapleg og norsk namneverk."@nb,
        "Skandinaviens bladmossflora."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Moss floras"@en,
        "Mosefloraer"@nb,
        "Mosefloraer"@nn .

<https://id.nb.no/vocabulary/ntsf/2809> a skos:Concept ;
    dct:created "2024-05-13T12:27:24"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338> ;
    skos:definition "En litteraturgjennomgang  er i vitenskap er en skriftlig oversikt over tidligere forskning som er gjort i et fagområde (Wikipedia)."@nb ;
    skos:example "Dangdai Zhongguo jindai shehuishi yanjiu (1949-2019) =  Contemporary studies of modern Chinese social history  / Li Changli, Tang Shichun, Li Junling, Lü Wenhao zhu (ISBN 9787520351591)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Literature reviews"@en,
        "Litteraturgjennomganger"@nb,
        "Litteraturgjennomgangar"@nn .

<https://id.nb.no/vocabulary/ntsf/281> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2025-06-27T16:41:54"^^xsd:dateTime ;
    skos:altLabel "Slektsromaner"@nb,
        "Slektsromanar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Skjønnlitteratur som skildrer en families/familiers skjebne, ofte gjennom flere generasjoner [red.]."@nb ;
    skos:example "Familien Neshov / Anne B. Ragde."@nb,
        "Og bakom synger skogene / Trygve Gulbranssen."@nb,
        "Slåttekar i himmelen / Edvard Hoem."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Family sagas"@en,
        "Slektsfortellinger"@nb,
        "Slektsforteljingar"@nn .

<https://id.nb.no/vocabulary/ntsf/282> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-12-12T09:48:24"^^xsd:dateTime ;
    skos:altLabel "Mysterier"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/578> ;
    skos:definition "Litteratur med spennende, nervepirrende handling [NAOB]."@nb ;
    skos:example "Detektivbyrå nr. 2 / Jørn Lier Horst."@nb,
        "Fellini og grevlingmysteriet / Tor Åge Bringsværd."@nb,
        "Hvem gikk med utesko inne? / Lars Mæhle."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Spenning"@nb,
        "Spenning"@nn ;
    skos:scopeNote "Brukes på spennende skjønnlitteratur hvor andre termer under 'Krim og spenning' ikke passer. Ofte brukt på bøker for barn."@nb .

<https://id.nb.no/vocabulary/ntsf/2826> a skos:Concept ;
    dct:created "2024-06-11T10:29:09"^^xsd:dateTime ;
    dct:modified "2024-08-30T14:01:54"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/341> ;
    skos:definition "Beskrivelse av innhold, tid og sted for en eller flere operetteoppsetninger [red.]."@nb ;
    skos:example "Den glade enke."@nb,
        "Sommer i Tyrol."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Operetta programs"@en,
        "Operetteprogrammer"@nb,
        "Operetteprogram"@nn .

<https://id.nb.no/vocabulary/ntsf/2830> a skos:Concept ;
    dct:created "2024-08-28T11:13:04"^^xsd:dateTime ;
    dct:modified "2024-08-30T14:01:54"^^xsd:dateTime ;
    skos:altLabel "Beginner books"@en,
        "Easy reading books"@en,
        "Graded readers"@en,
        "Lettlestbøker"@nb,
        "Lettleste bøker"@nb,
        "Lettlesbøker"@nn,
        "Lettlesne bøker"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Litteratur som er særlig lett å lese, tilrettelagt for nybegynnere og lesesvake [red.]."@nb ;
    skos:example "Alt som er nytt / Anna Fiske."@nb,
        "Bettina vil til Syden / Sidsel Jøranlid ; illustrert av Monika Nilsen (Leseløve)."@nb,
        "Bibelen i tekst og bilder (Leser søker bok)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Easy readers"@en,
        "Lettlest litteratur"@nb,
        "Lettlesen litteratur"@nn ;
    skos:scopeNote "Brukes for lettleste bøker rettet mot barn og voksne på forskjellige nivåer tilpasset leseferdighet. For barn er bøkene ofte beregnet på de som skal lære seg å lese, de utgis gjerne som en del av en serie der lesenivå og alderstrinn tydelig er definert av forlaget. Bøkene kommer i varierende lengde og i ulike sjangre der tanken er at barna skal finne historier som de er opptatt av. For voksne er bøkene både beregnet på personer med lesevansker eller for de som akkurat har lært seg å lese, og det bør tydelig framkomme av publikasjonen at bøkene er rettet mot denne målgruppen."@nb .

<https://id.nb.no/vocabulary/ntsf/2845> a skos:Concept ;
    dct:created "2024-09-18T07:30:29"^^xsd:dateTime ;
    dct:modified "2024-10-02T07:57:45"^^xsd:dateTime ;
    skos:altLabel "NOU"@nb,
        "Norges offentlige utredninger"@nb,
        "Noregs offentlege utgreiingar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/319> ;
    skos:definition "Utredning fra et utvalg eller en arbeidsgruppe nedsatt av regjeringen eller et departement [Wikipedia]."@nb ;
    skos:example "Akademisk ytringsfrihet : god ytringskultur må bygges nedenfra, hver dag : utredning fra et utvalg oppnevnt av Kunnskapsdepartementet 20. juli 2021 : avgitt til Kunnskapsdepartementet 21. mars 2022."@nb,
        "Straffelovrådets utredning nr. 1 : kriminalisering av deltakelse i og rekruttering til kriminelle grupper : utredning fra et råd oppnevnt ved kongelig resolusjon 14. juni 2019 : avgitt til Justis- og beredskapsdepartementet 12. mars 2020."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Official Norwegian reports"@en,
        "NOU-er"@nb,
        "NOU-ar"@nn .

<https://id.nb.no/vocabulary/ntsf/2849> a skos:Concept ;
    dct:created "2024-09-18T07:57:57"^^xsd:dateTime ;
    dct:modified "2024-10-02T07:57:45"^^xsd:dateTime ;
    skos:altLabel "Consultations"@en,
        "Public hearings"@en,
        "Offentlige høringer"@nb,
        "Offentlege høyringar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/475> ;
    skos:definition "Høring er en type ordning for innhenting av synspunkter og opplysninger i forbindelse med behandling av saker i offentlig forvaltning og i politiske organer som Stortinget eller kommunestyrer. Høringer gir ofte adgang for berørte parter som for eksempel interesseorganisasjoner til å uttale seg før vedtak fattes [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2016026107> ;
    skos:example "Høring - forslag om Mosvatnet naturreservat, Stavanger kommune, Rogaland."@nb,
        "Verneplan av skog : høring av forslag om vern av 7 områder / av Kolbjørn Hoff & Erica Neby."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Hearings"@en,
        "Høringer"@nb,
        "Høyringar"@nn .

<https://id.nb.no/vocabulary/ntsf/285> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-10-04T13:20:56"^^xsd:dateTime ;
    skos:altLabel "Trivia books"@en,
        "Quiz-bøker"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/479> ;
    skos:definition "Bok med spørsmål og svar om ett eller flere temaer, gjerne ordnet tematisk og i bolker [red.]"@nb ;
    skos:example "Fjellquiz : 897 spørsmål om fjell og fjellfolk / Iver Gjelstenli og Erik Enitch."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Quiz books"@en,
        "Spørrebøker"@nb,
        "Spørjebøker"@nn .

<https://id.nb.no/vocabulary/ntsf/2867> a skos:Concept ;
    dct:created "2024-09-18T11:19:12"^^xsd:dateTime ;
    dct:modified "2024-10-02T07:57:45"^^xsd:dateTime ;
    skos:altLabel "General requirements"@en,
        "Retningslinjer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338> ;
    skos:definition "En veileder gir råd, støtte eller praktisk hjelp for å løse en oppgave eller oppnå et mål [Kudos]."@nb ;
    skos:example "Hus for storfe : norske anbefalinger / tekst: Lars Erik Ruud (red.), Åse Margrethe Sogstad, Lars Erik Heggen."@nb,
        "Nasjonale faglige retningslinjer for antibiotikabruk i primærhelsetjenesten."@nb,
        "Sakskostnader : en veileder basert på Sivilombudets uttalelser om sakskostnader."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Guidelines"@en,
        "Veiledere"@nb,
        "Rettleiarar"@nn ;
    skos:scopeNote "Brukes både for veiledere og for retningslinjer (formelle instruksjoner eller regler)."@nb .

<https://id.nb.no/vocabulary/ntsf/2892> a skos:Concept ;
    dct:created "2025-01-21T11:24:10"^^xsd:dateTime ;
    dct:modified "2025-10-27T17:26:21"^^xsd:dateTime ;
    skos:altLabel "Invitation cards"@en,
        "Invitation scripts"@en,
        "Invitasjoner"@nb,
        "Invitasjonskort"@nb,
        "Innbydingsskrift"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/404> ;
    skos:definition "Innbydelse til en spesiell begivenhet, for eksempel til en eksamen, eller en feiring eller annen spesiell begivenhet [red.]."@nb ;
    skos:example "De institutione puerili veterum Graecorum sc. & Romanorum : prolusio qvaad audiendam orationem gratulatoriam in adventum summe Venerabilis Episcopi, Petri Hansen, scholam primum publico nomine invisentis, atque examen Scholae annuum, ejusdem sub auspiciis Cal. Aug. & seqv. Habendum, Humaniorem literarum Fautores, qva qvemqve par est observantia, officiosissime invitat. Salomon Giør. Rect. Sch."@nb,
        """Indbydelsesskrift til de offentlige Afgangs- og Aarsprøver i\r
Nykøbing Katedralskole i Maj og Juni 1925."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Invitations"@en,
        "Innbydelsesskrift"@nb,
        "Innbydingar"@nn ;
    skos:scopeNote "Brukt mest for eldre forhold."@nb .

<https://id.nb.no/vocabulary/ntsf/2901> a skos:Concept ;
    dct:created "2025-01-27T06:47:26"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/592> ;
    skos:definition "Arbeidssanger er sanger som ledsager fysisk arbeid. Det er rytmiske sanger som bidrar til å koordinere arbeidsrytmen eller gir signal til en samtidig kraftanstrengelse. Kjente former for arbeidssanger er sjantier fra seilskutetida, rallarviser og arbeidssanger fra slavetiden i USA [SNL]."@nb ;
    skos:example "Blow boys, blow : sjanties frå Diderik Brochmanns samlingar."@nb,
        "Stenbrytervise / Nisser og dverge bygger i berge; men vi skal mine dem alle herut."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Work songs"@en,
        "Arbeidssanger"@nb,
        "Arbeidssongar"@nn ;
    skos:scopeNote """Sanger knyttet til arbeidsprosesser i motsetning til 'Arbeidersanger' som er knyttet til arbeidere som sosial gruppe. Arbeidssanger kan knytte seg til arbeidet gjennom funksjon (sjantier, mineboringssanger) eller gjennom innholdet (veveviser, spinneviser).\r
 \r
Brukes om tekster til arbeidssanger."""@nb .

<https://id.nb.no/vocabulary/ntsf/2904> a skos:Concept ;
    dct:created "2025-01-27T08:49:40"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:altLabel "Non-fiction crime narratives"@en,
        "Nonfiction crime narratives"@en,
        "True crime literature"@en,
        "True crime narratives"@en,
        "Kriminaldokumentarer"@nb,
        "Sanne kriminalhistorier"@nb,
        "Sannkrim"@nb,
        "True crime"@nb,
        "Virkelige kriminalhistorier"@nb,
        "Krim frå røyndomen"@nn,
        "Kriminaldokumentarar"@nn,
        "Verkelege kriminalhistorier"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/494> ;
    skos:definition "Faktabasert sjanger der forfatteren undersøker en virkelig kriminalsak og utforsker omstendighetene rundt og handlingene til personer som var knyttet til den aktuelle saken [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026203> ;
    skos:example "Hvem tok Therese? / Per Asle Rustad."@nb,
        "Med kaldt blod : en sannferdig beretning om et massemord og de følger det fikk / Truman Capote."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "True crime stories"@en,
        "Virkelighetskrim"@nb,
        "Røyndomskrim"@nn .

<https://id.nb.no/vocabulary/ntsf/291> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Fiktiv karakter med overnaturlige krefter eller evner [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026064> ;
    skos:example "Dei hemmelege superheltane / Sylvia Heinlein."@nb,
        "Super-Cherlie & mormormysteriet / Camilla Läckberg."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Superhero fiction"@en,
        "Superhelter"@nb,
        "Superheltar"@nn ;
    skos:scopeNote "Brukes om bøker om fiktive personer som av ulike årsaker har superkrefter, som oftest barnebøker."@nb .

<https://id.nb.no/vocabulary/ntsf/292> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Sangspill"@nb,
        "Vaudeville"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/280> ;
    skos:definition "Syngespill, opera av lett og munter karakter med avvekslende sang og tale, oppstod i Tyskland omkring 1750. Berømte syngespill er Mozarts Bortførelsen fra Seraillet og Tryllefløyten. Betegnelsen syngespill brukes ofte synonymt med vaudeville (SNL)"@nb ;
    skos:example "Fjeldeventyret : Syngespil i to Acter / Henrik Anker Bjerregaard."@nb,
        "Gudbrand i lia : syngespill i en akt / Alf Prøysen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Light operas"@en,
        "Syngespill"@nb,
        "Syngjespel"@nn .

<https://id.nb.no/vocabulary/ntsf/2922> a skos:Concept ;
    dct:created "2025-01-27T09:38:55"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:altLabel "Kriminaldokumentarer (TV-programmer)"@nb,
        "Sannkrim (TV-programmer)"@nb,
        "True crime (TV-programmer)"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1205> ;
    skos:definition "TV-programmer som undersøker en virkelig kriminalsak og utforsker omstendighetene rundt og handlingene til personer som var knyttet til den aktuelle saken [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026711> ;
    skos:example "Gåten Orderud (2018)."@nb,
        "Making a murderer (2015-2018)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "True crime television programs"@en,
        "Virkelighetskrim (TV-programmer)"@nb,
        "Røyndomskrim (TV-program)"@nn .

<https://id.nb.no/vocabulary/ntsf/2931> a skos:Concept ;
    dct:created "2025-02-07T07:57:33"^^xsd:dateTime ;
    dct:modified "2025-10-27T17:26:21"^^xsd:dateTime ;
    skos:altLabel "Acrostics"@en,
        "Akrostikon"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/580> ;
    skos:definition "Dikt hvor verslinjenes begynnelsesbokstaver eller sluttbokstaver lest i sammenheng danner et navn, et ord eller en setning [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026214> ;
    skos:example "Gjest Baardsens Levnetsløb : En ny mærkværdig Vise / forfattet af ham selv i Fængslet."@nb,
        "Hilsen og hyldest : en samling akrostikon / Halfdan Høstmark."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Acrostic poetry"@en,
        "Akrostika"@nb,
        "Akrostikon"@nn .

<https://id.nb.no/vocabulary/ntsf/2935> a skos:Concept ;
    dct:created "2025-03-06T08:27:22"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:altLabel "Literary analysis"@en,
        "Litterære vurderinger"@nb,
        "Litterære vurderingar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/475> ;
    skos:definition "Litteraturkritikk er en undersøkelse av litterære verker med det formål å omtale og vurdere dem [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2017026126> ;
    skos:example "Interpreting Chekhov / Geoffrey Borny."@nb,
        "Jon Fosse - enkelt og djupt : om romanane og forteljingane hans / Jan H. Landro."@nb,
        "Translation and the borders of contemporary Japanese literature : inciting difference / Victoria Young."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Literary criticism"@en,
        "Litteraturkritikk"@nb,
        "Litteraturkritikk"@nn .

<https://id.nb.no/vocabulary/ntsf/2941> a skos:Concept ;
    dct:created "2025-03-11T08:42:53"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/503> ;
    skos:definition "(Faste og regelmessig repeterte) ordelag som brukes ved henvendelse til guddom [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026049> ;
    skos:example "Herre, signe du og råde = Herre, signe du og råde = Sjugnehth mijjem, Lutnjestæjja. - I: Norsk salmebok 2013 Stor skrift Stavanger : Eide, [2013]. - S. 920-921."@nb,
        "Sápmelačča rohkadallan / Ardis Ronte Eriksen I: Skånland kirke gjennom hundre år / redaktører: Per Skåden, Asbjørg Skåden [Evenskjer] : Skånland menighetsråd, [2001]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Prayers"@en,
        "Bønner"@nb,
        "Bøner"@nn .

<https://id.nb.no/vocabulary/ntsf/2944> a skos:Concept ;
