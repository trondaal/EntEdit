    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Yoiks (texts)"@en,
        "Joiketekster"@nb,
        "Joiketekstar"@nn .

<https://id.nb.no/vocabulary/ntsf/105> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-07T15:21:26"^^xsd:dateTime ;
    skos:altLabel "Administrative regulations"@en ;
