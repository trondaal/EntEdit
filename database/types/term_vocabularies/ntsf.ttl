    skos:example "Hisclass : a historical international social class scheme (Leuven University Press cop. 2011)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Classification systems"@en,
        "Klassifikasjonssystemer"@nb,
        "Klassifikasjonssystem"@nn .

<https://id.nb.no/vocabulary/ntsf/221> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:altLabel "Synoptic history works"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338> ;
    skos:definition "Generell framstilling av hovedtrekkene ved et fag eller emne [red.]."@nb ;
    skos:example "Buddhisme : et illustrert oversiktsverk / redigert av Kevin Trainor ; oversatt av Marianne Uthaug."@nb,
        "Skilsmissen : dansk og norsk identitet før og efter 1814 / Rasmus Glenthøj."@nb,
        "Udsigt over den norske Historie / Johan Ernst Sars."@nb,
        "Verdenshistorie : med fortiden som speil / Terje Tvedt ; kart: Audun Skjervøy."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Synoptic histories"@en,
        "Oversiktsverk"@nb,
        "Oversiktsverk"@nn .

<https://id.nb.no/vocabulary/ntsf/223> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2020-03-23T15:34:01"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/127> ;
    skos:definition "(..) I litteraturen betegner parodi en komisk-satirisk diktning som etterligner et annet diktverk eller en gruppe diktverker ved at formen og tonen i parodien er overført på et lavt, hverdagslig eller ubetydelig innhold, f.eks. Holbergs Peder Paars, som parodierer det antikke eposet, og Wessels Kierlighed uden strømper, som parodierer de norske etterlignere av den franske klassisistiske tragedien (..) [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026470> ;
    skos:example "Kierlighed uden strømper / Johan Herman Wessel."@nb,
        "Peder Paars / Ludvig Holberg."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Parodies (literature)"@en,
        "Parodier"@nb,
        "Parodiar"@nn .

<https://id.nb.no/vocabulary/ntsf/2234> a skos:Concept ;
    dct:created "2023-02-14T11:07:43"^^xsd:dateTime ;
    skos:altLabel "Comic fairy tales"@en,
        "Funny fairy tales"@en,
        "Funny tales"@en,
        "Lygeeventyr"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/897> ;
    skos:definition "Eventyr med få eller ingen overnaturlige innslag, som har hatt som hovedfunksjon å underholde og vekke latter hos tilhørerne. Gruppa er svært sammensatt, og kan f.eks. handle om molboer, friere, ektepar, dumme menn og kjerringer osv. «Kjerringa mot strømmen» er et kjent skjemteeventyr. Mange skjemteeventyr har brodd mot prester, futer og andre øvrighetspersoner, som framstår som dumme og oppblåste, i kontrast til en allmuesmann som representerer den sunne fornuft. Noen skjemteeventyr kan rettere kalles lygeeventyr, der poenget er å fortelle en nonsenshistorie med de størst mulige overdrivelser. Erotiske eventyr kan også regnes til skjemteeventyra. Bruk av skjemteeventyr ser ikke ut til å være geografisk begrenset. En rekke eldre eventyr lever fortsatt i muntlig tradisjon som vitser eller groviser, gjerne uten at forteller og tilhører er seg bevisst at historia er et genuint eventyr [Wikipedia]."@nb ;
    skos:example "Norske skjemteeventyr."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Humorous fairy tales"@en,
        "Skjemteeventyr"@nb,
        "Skjemteeventyr"@nn .

<https://id.nb.no/vocabulary/ntsf/225> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/33> ;
    skos:definition "Bøker med lite eller ingen tekst, ofte uten handling og med tydelige bilder, der barn kan \"peke på\" illustrasjonene [red.]."@nb ;
    skos:example "Livet på gården (Mine første ord)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Wordless picture books"@en,
        "Pekebøker"@nb,
        "Peikebøker"@nn ;
    skos:scopeNote "Som oftest brukt på bøker for små barn 0-3 år."@nb .

<https://id.nb.no/vocabulary/ntsf/2251> a skos:Concept ;
    dct:created "2023-03-14T08:53:56"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Industrial folk music"@en,
        "Industrial folk songs"@en,
        "Industrial songs"@en,
        "Industrial work songs"@en,
        "Occupational songs"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Arbeidersanger er en moderne form for folkeviser med utgangspunkt i arbeiderklassens leve- og arbeidsvilkår.Arbeidersangene oppsto med framveksten av en egen arbeiderklasse etter den industrielle revolusjon som et ledd i en eldre tradisjon med realistiske folkeviser.I ulike land artet fenomenet seg på ulike måter, avhengig av hvilken visekultur som alt fantes i landet, og etter hvilke mål arbeiderklassen jobbet ut fra.Etter oktoberrevolusjonen i Russland fikk arbeiderkultur og arbeidersanger et oppsving over hele verden, og ble flittig brukt både som propaganda og underholdning både av kommunister og sosialdemokrater.Etter andre verdenskrig hadde de tradisjonelle arbeidersangene i stor grad utspilt sin rolle, og ble mindre brukt til annet enn underholdning og for å bevare historikk i arbeiderbevegelsen.En av de mest kjente norske komponistene av arbeidersanger var Jolly Kramer-Johansen, som satte musikk til andres tekster. (Wikipedia)"@nb ;
    skos:example "Arbeidernes sangbok / samlet av Arbeidernes oplysningsforbund."@nb,
        "Seiren vet vi at vi får :  arbeiderbevegelsens sanger / samlet av Oddbjørn Johannessen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Working songs"@en,
        "Arbeidersanger"@nb,
        "Arbeidarsongar"@nn ;
    skos:scopeNote """Sanger knyttet til arbeidere som sosial gruppe i motsetning til 'Arbeidssanger' som er knyttet til arbeidsprosesser.\r
Brukes om tekster til arbeidersanger."""@nb .

<https://id.nb.no/vocabulary/ntsf/2261> a skos:Concept ;
    dct:created "2023-03-14T09:25:47"^^xsd:dateTime ;
    skos:altLabel "Death registers"@en,
        "Dødsfallsprotokoller"@nb,
        "Dødsfallsregistre"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "Historisk brukt for lister over døde innenfor et bestemt område og en bestemt periode, i områder der det ikke fantes kirkebøker."@nb ;
    skos:example "Døde i Idd 1720 til og med 1769 og 1770 til og med 1789 (Historielaget, 2005)."@nb,
        "Dødsfall i Norge 1841-1850 (Norsk slektshistorisk forening, 1987)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Death records"@en,
        "Dødsfallslister"@nb,
        "Dødsfallslister"@nn ;
    skos:scopeNote ""@nb .

<https://id.nb.no/vocabulary/ntsf/2266> a skos:Concept ;
    dct:created "2023-03-14T13:00:05"^^xsd:dateTime ;
    skos:altLabel "Party programmes"@en,
        "Party programs"@en,
        "Political manifestoes"@en,
        "Political manifests"@en,
        "Political programmes"@en,
        "Political programs"@en,
        "Partiprogram"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/404> ;
    skos:definition "Et partiprogram er et skrift utgitt av et politisk parti. I partiprogrammet redegjør partiet for sin politikk for en kommende periode, som regel en valgperiode på fire år, eksempelvis for perioden 2013–2017. Partiprogram har tradisjon for å være delt i to deler — ett overordnet prinsipprogram og et mer detaljert og konkret arbeidsprogram. Prinsipprogrammet drøfter partiets verdier og prinsipper. Arbeidsprogrammet tar for seg partiets oppfatning av status, viktige mål og tiltaksplaner innenfor konkrete områder som klima, økonomi, samferdsel, helse, miljø og utenriks. Dette gjør arbeidsprogrammet egnet til å fungere som et arbeidsdokument for partiet i programmets periode. Partiprogrammet vedtas normalt på partiets landsmøte i forkant av perioder med valgkamp, og fungerer som et sentralt dokument for partiet i valgkampen. Partiprogrammet er i så måte gjenstand for gjentatte og vedvarende analyser fra både media og konkurrerende partier [Wikipedia]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Party platforms"@en,
        "Partiprogrammer"@nb,
        "Partiprogram"@nn .

<https://id.nb.no/vocabulary/ntsf/2275> a skos:Concept ;
    dct:created "2023-03-14T13:27:26"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Sanglek er en sosial samværsform som kombinerer vokal og kroppslig utfoldelse. I vår tid møter vi oftest sangleker som barnetradisjon. I samband med juletregang ser vi sangleker utføres av barn og voksne i fellesskap. Tradisjonelt har sanglekene vært vel så mye til adspredelse for de store som for de små (Wikipedia)."@nb ;
    skos:example "Sett deg opp i kørja- : og andre sangleker."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Singing games"@en,
        "Sangleker"@nb,
        "Songleikar"@nn ;
    skos:scopeNote "Brukes om tekster til sangleker."@nb .

<https://id.nb.no/vocabulary/ntsf/2278> a skos:Concept ;
    dct:created "2023-03-14T13:33:08"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/127> ;
    skos:definition "Fantastisk historie, skrøne (slik den blir fortalt av skippere og andre sjøfolk) [Wikipedia]."@nb ;
    skos:example "Skepparhistorier : skrönor från haven (Carlssons 1988)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Tall tales of the sea"@en,
        "Skipperskrøner"@nb,
        "Skipperskrøner"@nn .

<https://id.nb.no/vocabulary/ntsf/2283> a skos:Concept ;
    dct:created "2023-03-17T11:34:12"^^xsd:dateTime ;
    skos:altLabel "Phone books"@en,
        "Telephone books"@en,
        "Telefonbøker"@nb ;
