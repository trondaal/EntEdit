<https://id.nb.no/vocabulary/ntsf/296> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:altLabel "Addresses"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/475> ;
    skos:definition "Tale er en tekst som framføres for et publikum, gjerne ved litt høytidelige anledninger. Det finnes flere typer taler, og alle har sine sjangerforventninger. Felles er at teksten bør ha gjennomtenkt struktur og ha et tydelig budskap [ndla]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026363> ;
    skos:example "Bjørnstjerne Bjørnsons Tale paa Slotspladsen for Dagen [17de Mai 1864] [og] Advokat Dunkers Tale for Danmark."@nb,
        "Bjørnstjerne Bjørnsons Tale ved Fædrenes Minde den 16de Febr."@nb,
        "Tale i Oslo Rådhus ved åpningen av minnehøytidlighetene i anledning av 50-årsdagen for Bjørnstjerne Bjørnsons død av Francis Bull."@nb,
        "Ved åpningen av Universitetsbibliotekets Bjørnson-utstilling 26. april 1960 / av Harald L. Tveterås."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1729> ;
    skos:prefLabel "Speeches"@en,
        "Taler"@nb,
        "Talar"@nn ;
    skos:scopeNote "Brukt om taler ved spesielle anledninger eller begivenheter."@nb .

<https://id.nb.no/vocabulary/ntsf/306> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2021-02-15T16:49:04"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/578> ;
    skos:definition "En thriller er en spennende historie om store problemer, hvor hovedpersonen som regel havner i fare, og må redde situasjonen før det er for sent [Sølvberget]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026571> ;
    skos:example "Alt er mitt / Ruth Lillegraven."@nb,
        "Presidenten er savnet / Bill Clinton."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1081> ;
    skos:prefLabel "Thrillers (fiction)"@en,
        "Thrillere"@nb,
        "Thrillerar"@nn ;
    skos:scopeNote "Brukes for spennende skjønnlitteratur, hvor fokuset ikke nødvendigvis er på å oppklare en forbrytelse. Ofte med innslag av psykisk terror, kan også være spionthrillere eller politiske thrillere."@nb .

