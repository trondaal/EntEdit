    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Educational films"@en,
        "Informasjonsfilmer"@nb,
        "Informasjonsfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1655> a skos:Concept ;
    dct:created "2022-10-18T13:11:45"^^xsd:dateTime ;
