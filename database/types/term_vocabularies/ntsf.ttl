    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026128> ;
    skos:example "Karlstadforhandlingene 1905 : referat fra de møter hvor sekretærene var til stede."@nb,
        "Nasjonal samling : møteprotokoll 1934-1945."@nb,
