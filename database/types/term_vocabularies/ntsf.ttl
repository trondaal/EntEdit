    skos:definition "En stamtavle er en oversikt over slektskapsforholdene mellom medlemmene av en slekt i grafisk form eller i listeform [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026106> ;
