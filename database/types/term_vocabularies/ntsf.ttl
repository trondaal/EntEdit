        "Mánáid bláđđi."@nb,
        "Norsk barneblad."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Children's magazines"@en,
        "Barneblader"@nb,
        "Barneblad"@nn .

<https://id.nb.no/vocabulary/ntsf/1648> a skos:Concept ;
    dct:created "2022-10-18T12:21:27"^^xsd:dateTime ;
