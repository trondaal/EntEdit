<https://id.nb.no/vocabulary/ntsf/1209> a skos:Concept ;
    dct:created "2021-10-18T13:25:17"^^xsd:dateTime ;
    dct:modified "2022-02-20T08:52:32"^^xsd:dateTime ;
    skos:altLabel "Fjernsynsserier"@nb,
