<https://id.nb.no/vocabulary/ntsf/219> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-12-03T14:49:51"^^xsd:dateTime ;
    skos:altLabel "Maximes"@en,
        "Proverbial sayings"@en,
        "Sayings"@en,
        "Maksimer"@nb,
        "Ordtak"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/508> ;
    skos:definition "Ordtak, ordspråk, fyndig og lettfattelig setning som inneholder en leveregel eller et visdomsord, eller som gir uttrykk for en alminnelig erfaring eller iakttagelse.Et ordspråks opprinnelse og alder er ikke lett å fastslå, det gir ofte uttrykk for en allmenn, menneskelig erfaring, og samme tanke kan finnes igjen i ordspråk fra flere kulturer. Som eventyrene har de også vandret fra land til land (SNL)."@nb ;
    skos:example "Ordtak fra Nord-Norge / Nils Aagaard-Nilsen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Proverbs"@en,
        "Ordspråk"@nb,
        "Ordspråk"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/1815>,
        <https://id.nb.no/vocabulary/ntsf/4> .

<https://id.nb.no/vocabulary/ntsf/222> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-03-07T10:30:00"^^xsd:dateTime ;
    skos:altLabel "Phrase books"@en,
        "Polyglot phrase books"@en,
        "Polyglot phrasebooks"@en,
        "Polyglottparlører"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/339>,
        <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Samlinger av nyttige eller idiomatiske uttrykk på et fremmed språk, med eller uten definisjoner og/eller ekvivalenter i andre språk [LCGFT, overs.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026145> ;
    skos:example "Croatian : phrasebook and dicionary / Gordana Ivatec."@nb,
        "Parlør (med utvidet ordliste) til bruk i Kroatia, Serbia, Montenegro, Bosnia-Hercegovina / i redaksjonen: Brit Bakker Haugen, Jan Ivar Haugen."@nb,
        "På reise i Romania : norsk-rumensk parlør / Crina Leon."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Phrasebooks"@en,
        "Parlører"@nb,
        "Parlørar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/1502> .

<https://id.nb.no/vocabulary/ntsf/228> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/475>,
        <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "En petit er en kort, humoristisk tekst i kåserende stil i en avis. Den har en personlig og muntlig språktone. Ofte er den et fast innslag i avisen, skrevet av samme person. Ordet kommer fra det franske ordet \"petit\" som betyr liten. «Petit er en kort, kommenterende, smått oppslått, helhetlig, ofte humoristisk, alltid personlig og poengtert betraktning om hva som helst», ifølge Lorentzen (1996). Virkemidler kan være - blant mange andre - syntaks, allusjon, ordspill, parodi, ironi, dramatisering, språklige bilder, overraskende vendinger, besjeling, overdrivelse, underdrivelse, oppramsing, symmetribrudd eller muntlighet [Wikipedia]."@nb ;
    skos:example """Sleng på byen / Dag Solstad ; med etterord av Jan Erik Vold.\r
Samling av petiter tidligere publisert i avisen Tiden, Arendal 1962."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Paragraphs"@en,
        "Petiter"@nb,
        "Petitar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/166> .

<https://id.nb.no/vocabulary/ntsf/239> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-03-07T10:41:52"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338>,
        <https://id.nb.no/vocabulary/ntsf/438> ;
    skos:definition "Høytidelig, offentlig kunngjøring [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026467> ;
    skos:example """Kongl. Maj:ts nådiga Kungörelse om Krig emot Konungen i Dannemark, gifwen Haga slott den 15 September 1813. Proclamationer fra Hans Kongelige Høihed Kronprindsen af Sverrig, og Bulletiner, udstædte i den forenede Nord-Tydske Armees Hoved-Qvarteer fra Begyndelsen af denne Armees Operationer indtil 16de September 1813 / oversat efter den paa Fransk i Lüttich udkomne 2den Udgave. Samling af Breve, Proclamationer og Taler af Carl Johan, Kronprinds og senere Konge til Sverig og Norge. Første Deel. Oversatte fra det Franske.\r
[kilde: 1814-bibliografi]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/2024> ;
    skos:prefLabel "Proclamations"@en,
        "Proklamasjoner"@nb,
        "Proklamasjonar"@nn ;
    skos:scopeNote "Hovedsakelig brukt på eldre materiale."@nb .

<https://id.nb.no/vocabulary/ntsf/251> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278>,
