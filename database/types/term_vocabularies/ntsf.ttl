<https://id.nb.no/vocabulary/ntsf/4> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:altLabel "Bevingede ord"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/339> ;
    skos:definition """En aforisme er en kort setning, et løsrevet sitat eller en strøtanke som på en treffende og underfundig måte uttrykker et tankevekkende poeng, en læresetning eller allmenn sannhet, særlig om vitenskap, kunst, moral og psykologi. Aforismer minner både i form og innhold om ordspråk, men aforismene har kjent opphav, enten de er sitater fra litterære verk og taler eller de er nyskrevet. Aforismer er ofte humoristiske, men ikke like komiske som vitser. Aforismediktning eller -kunst regnes av flere som en egen litterær form innen prosasjangeren. I litteraturvitenskaplig teori blir imidlertid en aforisme definert snevrere enn den gjør i dagligtalen.\r
Ordet aforisme kommer fra det greske aforismós som er avledet av aphorizein, det vil si «å avgrense».\r
Aforismer, sentenser, litterære sitater og andre gullkorn kalles gjerne «bevingede ord», et uttrykk den greske historiedikteren Homer bruker i Iliaden og Odysseen. I 1863 tok også tyskeren Georg Büchmann i bruk Geflügelte Worte om slike uttrykk [SNL]."""@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026170> ;
    skos:example "Fra gullkorn til sleivspark : visdomsord, humor og treffende kommentarer."@nb,
        "Skriften på veggen : og andre bibelord i dagligtale / Dag Kjær Smemo."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Aphorisms"@en,
        "Aforismer"@nb,
        "Aforismar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/219> .

<https://id.nb.no/vocabulary/ntsf/414> a skos:Concept ;
    dct:created "2019-03-07T12:47:42"^^xsd:dateTime ;
    dct:modified "2019-03-07T12:47:55"^^xsd:dateTime ;
    skos:altLabel "Adapsjoner"@nb,
        "Bearbeidelser"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/412> ;
    skos:definition "Adaptasjon innen litteratur er en tilpasning eller ny produksjon av et litterært verk som eksempelvis en roman, novelle eller dikt til en ny sjanger eller til et nytt medium som film, teater, tegneserie eller videospill [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026041> ;
    skos:example "An enemy of the people / a new version by Rebecca Lenkiewicz ; from a literal translation by Charlotte Barslund."@nb,
        "Hedda Tesman / Cordelia Lynn ; after Henrik Ibsen."@nb,
        "Robinson : Underholdende Fortælling for Ungdommen, efter Campes Robinson der Jüngere."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Adaptations"@en,
        "Adaptasjoner"@nb,
        "Adaptasjonar"@nn .

<https://id.nb.no/vocabulary/ntsf/423> a skos:Concept ;
    dct:created "2019-03-07T13:10:32"^^xsd:dateTime ;
