        "Matriklar"@nn .

<https://id.nb.no/vocabulary/ntsf/1875> a skos:Concept ;
    dct:created "2022-11-23T09:21:29"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1929>,
        <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "Lensregnskapene ble ført av lensherren som var den øverste lokale myndighet i Norge før eneveldet ble innført i 1660. Årlige regnskap ble i sin tid sendt inn til Rentekammeret i København for revisjon, men oppbevares nå i Riksarkivet. Lensregnskapene er en unik kilde til norsk historie i en periode som ellers er relativt fattig på kildemateriale [Wikipedia]."@nb ;
    skos:example "Arkivregistraturar : 4 1 : Lensrekneskapar Austlandet."@nb,
        "Næsbyhoved lens regnskaber 1502-1511, Privatarkiver nr. 1-243 : hovedkatalog."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Account books for feudal overlords"@en,
        "Lensregnskaper"@nb,
        "Lensrekneskap"@nn .

