<https://id.nb.no/vocabulary/ntsf/1851> a skos:Concept ;
    dct:created "2022-11-22T11:38:37"^^xsd:dateTime ;
    skos:altLabel "Keys (Text books)"@en,
        "Solution manuals"@en,
        "Løsningsforslag"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/524> ;
    skos:definition "Fasit er resultatet av et regnestykke, og et ord som brukes i matematikk. En fasit kan også være en fasitbok, altså en bok som inneholder løsningene på regnestykkene i en oppgavesamling. Når man har regnet ferdig et regnestykke, kan man sjekke utregningen og svaret mot fasiten [SNL]."@nb ;
    skos:example "Amigos : 1 : Uno Fasit."@nb,
        "Changes : technical English in a changing world : Key to exercises."@nb,
        "Giella skálla : Čoavddagirji."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Answer books"@en,
        "Fasiter"@nb,
        "Fasitar"@nn ;
    skos:scopeNote "Brukt for fasiter innen alle fag, ikke bare matematikk."@nb .

<https://id.nb.no/vocabulary/ntsf/186> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/577> ;
    skos:definition "Magisk realisme er en litterær sjanger der overnaturlige fenomener finner sted i en realistisk og jordnær handling. Tanken bak magisk realisme er at elementer av det utrolige, det fantastiske, det magiske og himmelske er en del av «hverdagsrealismen», uten at fenomenene virker unaturlige. Det magiske er rett og slett en integrert del av virkeligheten [snl]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026424> ;
    skos:example "Bobla / Siri Pettersen."@nb,
        "Hundre års ensomhet / Gabriel Gracía Marquez."@nb,
        "Åndenes hus / Isabel Allende."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Magic realist ficion"@en,
        "Magisk realisme"@nb,
        "Magisk realisme"@nn .

<https://id.nb.no/vocabulary/ntsf/1861> a skos:Concept ;
    dct:created "2022-11-23T08:54:24"^^xsd:dateTime ;
    skos:altLabel "Church registers"@en,
        "Kirkebok"@nb,
        "Ministerialbok"@nb,
        "Ministerialbøker"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "Kirkebok er embetsprotokoller ved prestekontoret som for hver menighet føres over døpte, konfirmerte, ektevidde, døde, inn- og utmeldte av kirken [SNL]."@nb ;
    skos:example "Kirkebok : begravelseslister : Malvik, Strinda sogneprestembete Fra 1878 til 1893."@nb,
        "Kirkebok for Rendalen 1661-1680."@nb,
        "Ministerialbok for Venabygd 1878-1898."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Parish registers"@en,
        "Kirkebøker"@nb,
        "Kyrkjebøker"@nn .

<https://id.nb.no/vocabulary/ntsf/187> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-06T13:55:00"^^xsd:dateTime ;
    skos:altLabel "Magisteroppgaver"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/19> ;
    skos:definition "[Avhandling avgitt til magistergraden], akademisk grad på nivå mellom kandidatgrad og doktorgrad oppnådd bl.a. på grunnlag av en vitenskapelig avhandling [NAOB]. Brukt i Norge i perioden 1921-2003."@nb ;
    skos:example """Zwischen Enttäuschung, Patriotismus und Glaube : Motive und Argumente der Auswanderungsgegner in Norwegen von Ende der 1830er Jahre bis 1914 / Jeannette Woermann.\r
Magistergradsavhandling - Universität zu Köln, 2007.\r
[kilde: Norsk-amerikansk bibliografi]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Magister degrees"@en,
        "Magistergradsavhandlinger"@nb,
        "Magistergradsavhandlingar"@nn .

<https://id.nb.no/vocabulary/ntsf/188> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/301> ;
