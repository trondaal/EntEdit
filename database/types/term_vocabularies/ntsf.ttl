<https://id.nb.no/vocabulary/ntsf/536> a skos:Concept ;
    dct:created "2019-11-13T14:07:29"^^xsd:dateTime ;
    dct:modified "2021-03-01T10:49:04"^^xsd:dateTime ;
    skos:altLabel "Dagboksromaner"@nb ;
