<https://id.nb.no/vocabulary/ntsf/1666> a skos:Concept ;
    dct:created "2022-10-19T07:38:11"^^xsd:dateTime ;
    skos:altLabel "Instruction manuals"@en,
        "User handbooks"@en,
        "User manuals"@en,
        "Brukerhåndbøker"@nb,
        "Bruksanvisninger"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
