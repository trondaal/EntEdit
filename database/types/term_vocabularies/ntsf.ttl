    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026092> ;
    skos:example "Almindeligt Litteraturlexicon for Danmark, Norge, og Island, eller Fortegnelse over danske, norske, og islandske, saavel afdøde som nu levende Forfattere, med Anførelse af deres vigtigste Levnets-Omstændigheder og Liste over deres Skrifter / Ved R. Nyerup og J.E. Kraft."@nb,
        "Aschehoug og Gyldendals store norske leksikon."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Encyclopedias"@en,
        "Leksika"@nb,
        "Leksika"@nn .

