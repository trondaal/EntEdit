<https://id.nb.no/vocabulary/ntsf/1865> a skos:Concept ;
    dct:created "2022-11-23T09:12:48"^^xsd:dateTime ;
    skos:altLabel "Cadasters"@en,
        "Land registers"@en,
        "Urbaria"@en,
