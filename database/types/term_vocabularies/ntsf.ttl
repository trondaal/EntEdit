<https://id.nb.no/vocabulary/ntsf/1993> a skos:Concept ;
    dct:created "2022-11-28T13:56:59"^^xsd:dateTime ;
    skos:altLabel "Reverse dictionary"@en,
        "Baklengsordbok"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1502> ;
    skos:definition "En alfabetisk liste over ord stavet i omvendt rekkefølge, til bruk spesielt for lingvister og kryptografer [UBO]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026167> ;
    skos:example "A reverse dictionary of modern Irish."@nb,
        "Reverse dictionary of Mordvin = Obratnyj slovar' mordovskich jazykov."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Reverse dictionaries"@en,
        "Baklengsordbøker"@nb,
        "Baklengsordbøker"@nn .

<https://id.nb.no/vocabulary/ntsf/2> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-06T12:48:40"^^xsd:dateTime ;
    skos:altLabel "Adress books"@en,
        "Adressebok"@nb,
        "Adressekataloger"@nb,
        "Adresselister"@nb,
        "Adresseregister"@nb,
        "Adresseregistre"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144> ;
    skos:definition "En adressebok er en samling av kontaktinformasjon på personer, enten i papirform eller i form av en database. Vanligvis listes kontaktene systematisk i alfabetisk rekkefølge basert på etternavn, med ytterligere kontaktinformasjon i en standardisert form [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026087> ;
    skos:example "Adressebok : museum og samlingar."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Directories"@en,
        "Adressebøker"@nb,
        "Adressebøker"@nn .

<https://id.nb.no/vocabulary/ntsf/2005> a skos:Concept ;
    dct:created "2022-11-29T14:33:05"^^xsd:dateTime ;
    skos:altLabel "Recommendations"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338> ;
    skos:definition "Forslag til vedtak i en sak (især en ansettelsessak, utnevnelsessak e.l.) som legges frem for dem som har beslutningsmyndighet (NAOB)."@nb ;
    skos:example "Liturgi : forslag til ny ordning for hovedgudstjeneste i Den norske kirke."@nb,
        "Museet i universitetet : et forslag til universitetsmuseets rolle i framtida : museumsutredningen 28.01.98."@nb,
        "Norsk fotografisk museum : innstilling."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Nominations"@en,
        "Innstillinger"@nb,
        "Innstillingar"@nn .

<https://id.nb.no/vocabulary/ntsf/2009> a skos:Concept ;
    dct:created "2022-11-29T14:45:03"^^xsd:dateTime ;
    skos:altLabel "Codexes"@en,
        "Codices"@en,
        "Manuscript books"@en,
        "Manuskripter"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "Et håndskrift er en håndskrevet papyrusrull eller bok (codex) som vanligvis består av blader av skinn eller papir. Manuskript er et annet ord for en slik håndskrevet bok eller rull. Begrepet brukes oftest om bøker fra oldtiden og middelalderen, men det kan også brukes om en moderne, håndskrevet bok [SNL]."@nb ;
    skos:example "Arabic palaeography : a collection of Arabic texts from the first century of the Hidjra till the year 1000 / edited by Bernhard Moritz."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Manuscripts"@en,
        "Håndskrifter"@nb,
        "Handskrift"@nn .

<https://id.nb.no/vocabulary/ntsf/2015> a skos:Concept ;
    dct:created "2022-12-01T12:51:26"^^xsd:dateTime ;
    skos:altLabel "Complaint letters"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/44> ;
    skos:definition "Brev, skriftlig henvendelse som uttrykker en (mer eller mindre formell) klage [NAOB]."@nb ;
    skos:example "Le bailliage de Quingey en 1789 : les cahiers de doléancs (Belles Lettres 1989)-."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Letters of complaint"@en,
        "Klagebrev"@nb,
        "Klagebrev"@nn ;
    skos:scopeNote "Brukes på historiske dokumenter"@nb .

<https://id.nb.no/vocabulary/ntsf/2024> a skos:Concept ;
    dct:created "2022-12-05T11:30:04"^^xsd:dateTime ;
    skos:altLabel "Manifestoes"@en,
        "Manifests"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/239> ;
    skos:definition "Manifest er en erklæring til offentligheten, en programerklæring, proklamasjon eller et opprop [SNL]."@nb ;
    skos:example "100 artists' manifestos."@nb,
        "Burn it down! : feminist manifestos for the revolution."@nb,
        "Det kommunistiske manifest."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Manifestos"@en,
        "Manifester"@nb,
        "Manifest"@nn .

<https://id.nb.no/vocabulary/ntsf/2029> a skos:Concept ;
    dct:created "2022-12-05T14:37:45"^^xsd:dateTime ;
    skos:altLabel "Archaeological excavation reports"@en,
        "Arkeologiske utgravingsrapporter"@nb,
        "Arkeologiske utgravningsrapporter"@nb,
        "Utgravingsrapporter"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1775> ;
    skos:definition """Rapport fra arkeologiske utgravninger [UBO].\r
."""@nb ;
    skos:example "East of the theater : glassware and glass production."@nb,
        "The Pitted Ware culture on Djursland : supra-regional significance and contacts in the Middle Neolithic of southern Scandinavia."@nb,
        "The economy of a Norse settlement in the Outer Hebrides : excavations at mounds 2 and 2a Bornais, South Uist."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Excavation reports"@en,
        "Utgravningsrapporter"@nb,
        "Utgravingsrapportar"@nn .

<https://id.nb.no/vocabulary/ntsf/203> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-11-13T12:29:27"^^xsd:dateTime ;
    skos:altLabel "Fagterminologier"@nb,
        "Navnelister"@nb,
        "Namnelister"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/339> ;
    skos:definition "Nomenklatur, liste over en samling av de navn, fagord el.l. som forekommer i en vitenskap eller en kunstart; også: terminologien i et bestemt fag [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2018026159> ;
    skos:example "Fransk chemisk Nomenklatur / paa Dansk udgiven med Anmærkninger af N. Tychsen."@nb,
        "Norske soppnavn."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Nomenclatures"@en,
        "Nomenklaturer"@nb,
        "Nomenklaturar"@nn .

<https://id.nb.no/vocabulary/ntsf/2036> a skos:Concept ;
    dct:created "2022-12-05T14:48:19"^^xsd:dateTime ;
    skos:altLabel "Scholion"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/475> ;
    skos:definition "Skolier er korte randbemerkninger i greske og latinske håndskrifter med språklige eller reale forklaringer [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2018026072> ;
    skos:example "Scholia graeca in Platonem : 1 : Scholia ad Dialogos tetralogiarum I - VII continens."@nb,
        "Scolii metrici alla tetra de sofoclea."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Scholia"@en,
        "Skolier"@nb,
        "Skoliar"@nn .

<https://id.nb.no/vocabulary/ntsf/2040> a skos:Concept ;
    dct:created "2022-12-05T15:06:17"^^xsd:dateTime ;
    skos:altLabel "Language samples"@en,
        "Målprøver"@nb,
        "Språkprøver"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "En dialektprøve er en beskrivelse eller et lydopptak av en persons talemåte [UBO]."@nb ;
    skos:example "Målsamlingar frå Trondhjems og Tromsø Stifter av Ivar Aasen."@nb,
        "The Jewish Neo-Aramaic dialect of Betanure (province of Dihok)."@nb,
        "The MacArthur-Bates communicative development inventories (CDIs) : user's guide and technical manual."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Dialect samples"@en,
        "Dialektprøver"@nb,
        "Dialektprøver"@nn .

<https://id.nb.no/vocabulary/ntsf/207> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-10-03T10:37:46"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/404> ;
    skos:definition "Kort skriftlig melding (i avis e.l.) ; kort opptegnelse [NAOB]."@nb ;
    skos:example """On annonce la mort de Mme Jacobine Collett. -\r
I: L'Intransigeant (Paris : trykt utg.). - Paris : H. Rochefort. - 1895, 11/3."""@nb,
        """Til "Dagbladet" : [Takk fra Colletts Sønner]. -\r
I: Dagbladet (Oslo : 1869 : trykt utg.). - Oslo : A/S Dagbladet. - 1895 Nr. 71, 12/3. - S. [1]\r
[kilde: Collett-bibliografi]."""@nb,
        """[Tak for Blomster paa Fødselsdagen den 23de Januar] / Camilla Collett.\r
I: Aftenposten (morgenutg. : trykt utg.). - Oslo : Aftenposten A/S. - 1895 Nr. 59, 29/1. - S. [1]"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Notifications"@en,
        "Notiser"@nb,
        "Notisar"@nn ;
    skos:scopeNote "Hovedsakelig brukt på eldre materiale."@nb .

<https://id.nb.no/vocabulary/ntsf/2071> a skos:Concept ;
    dct:created "2023-01-11T11:09:18"^^xsd:dateTime ;
    dct:modified "2023-01-11T11:20:23"^^xsd:dateTime ;
    skos:altLabel "Graphic journalism"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/301> ;
    skos:definition "Reportasjer og lignende i form av tegneserier. Tegneserier brukt til å dokumentere og vise faktiske forhold i et samfunn eller et sosialt miljø [Litteratur- og medieleksikon]."@nb ;
    skos:example "Palestine / Joe Sacco."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Comics journalism"@en,
        "Tegneseriejournalistikk"@nb,
        "Teikneseriejournalistikk"@nn .

<https://id.nb.no/vocabulary/ntsf/2074> a skos:Concept ;
    dct:created "2023-01-11T11:24:52"^^xsd:dateTime ;
    skos:altLabel "Museum guide books"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/120> ;
    skos:definition "Veiviser til et museum som sier noe om museet og samlingene der [UBO]."@nb ;
    skos:example "Guide des musées Provence, Alpes, Côte d'Azur."@nb,
        "Handbuch der kunst- und kulturgeschichtlichen Sammlungen."@nb,
        "Stavanger museum : fører for den arkeologiske avdeling."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Museum guides"@en,
        "Museumsguider"@nb,
        "Museumsguidar"@nn .

<https://id.nb.no/vocabulary/ntsf/21> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:altLabel "Avisartikkel"@nb,
        "Avisklipp"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "Artikler i aviser (naob)."@nb ;
    skos:example """Vor store lille By / (C.C.).\r
I: Aftenposten (morgenutg. : trykt utg.). - 1885 Nr. 234 A, 6/10. - S. [1]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Newspaper articles"@en,
        "Avisartikler"@nb,
        "Avisartiklar"@nn .

<https://id.nb.no/vocabulary/ntsf/2100> a skos:Concept ;
    dct:created "2023-01-25T09:50:39"^^xsd:dateTime ;
    dct:modified "2025-10-27T17:26:21"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Vise er en musikksjanger hvor et metrisk dikt synges til en enkel melodi. Betegnelsen brukes gjerne om sanger med et folkelig preg [snl]."@nb ;
    skos:example """Steinrøysa neri bakken / Alf Prøysen. -\r
I: Magasinet for alle (trykt utg.). - Oslo. - 20(1947)nr. 9-10. - S. [22]."""@nb,
        "Viser fra en glad pessimist / Ragnar Olsen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Scandinavian ballads"@en,
        "Viser"@nb,
        "Viser"@nn ;
    skos:scopeNote "Brukt om tekster til viser."@nb .

<https://id.nb.no/vocabulary/ntsf/211> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/277> ;
    skos:definition "Nyhetsviser er skillingsviser med nyheter om en aktuell hendelse, og som oppgir fakta om hendelsen på tittelsiden. (kilde: forskning.no)."@nb ;
    skos:example "Dramaet i Fyresdal i Telemarken / Torkel Bøhn."@nb,
        "Minnesang om den skrekkelige naturkatastrofe i Tafjord på Møre natten til 7. april 1934, hvor 41 mennesker omkom ved den høie flodbølge / Johan Skøien."@nb,
        "Vanas Forlis / af Ragnvald Fredriksen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "News ballads"@en,
        "Nyhetsviser"@nb,
        "Viser om nyhende"@nn ;
    skos:scopeNote "Brukes om tekster til nyhetsviser."@nb .

<https://id.nb.no/vocabulary/ntsf/2111> a skos:Concept ;
    dct:created "2023-02-03T13:12:18"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/800> ;
    skos:definition "Alfabetisk fortegnelse over ord (ordregister) eller emner (sakregister) behandlet i aviser ; stikkordregister [red.]."@nb ;
    skos:example "Avismeldingar om norsk litteratur 1951-1965 : opptak til ein bibliografi."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Newspaper indexes"@en,
        "Avisindekser"@nb,
        "Avisindeksar"@nn .

<https://id.nb.no/vocabulary/ntsf/2116> a skos:Concept ;
    dct:created "2023-02-03T13:29:39"^^xsd:dateTime ;
    skos:altLabel "Journal indexes"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/800> ;
    skos:definition "Løpende fortegnelse over innholdet i et antall tidsskrift. (Språkrådets termwiki)"@nb ;
    skos:example "Index theologicus : IxTheo : Zeitschrifteninhaltsdienst Theologie / Universitätsbibliothek Tübingen."@nb,
        "National geographic : official journal of the National Geographic Society. Index 1888-1988."@nb,
        "Register til Heimen 1922-1966, Bd. I-XIII / utarbeidet av Norsk lokalhistorisk institutt ved K. Frøyset."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Periodical indexes"@en,
        "Tidsskriftindekser"@nb,
        "Tidsskriftindeksar"@nn .

<https://id.nb.no/vocabulary/ntsf/2120> a skos:Concept ;
    dct:created "2023-02-03T13:33:08"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "En drikkevise er en kort eller lang sang som ofte omhandler det å drikke (alkohol) eller det som er i situasjonen rundt drikkingen [Wikipedia]."@nb ;
    skos:example "Sanger og viser til festbord og glade lag, 96 drammeviser : Skål på norsk!, Akevittviseboken : en hilsen til akevittvenner ."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Drinking songs"@en,
        "Drikkeviser"@nb,
        "Drikkeviser"@nn ;
    skos:scopeNote "Brukes om tekster til drikkeviser."@nb .

<https://id.nb.no/vocabulary/ntsf/2123> a skos:Concept ;
    dct:created "2023-02-03T13:42:15"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Ballads about giants"@en,
        "Heroic ballads"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/23> ;
    skos:definition "Kjempevise er egentlig en vise om en kjempe, nå betegnelse på en gruppe middelalder-ballader som i innhold har nær tilknytning til norrøn litteratur. I Danmark ble betegnelsen fra 1500- til 1800-tallet brukt om middelalderlige viser generelt [SNL]."@nb ;
    skos:example "Danske folkeviser : 1 : Trylleviser, kæmpeviser, historiske viser."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Kjempeviser"@en,
        "Kjempeviser"@nb,
        "Kjempeviser"@nn ;
    skos:scopeNote "Brukes for tekster til kjempeviser."@nb .

<https://id.nb.no/vocabulary/ntsf/2128> a skos:Concept ;
    dct:created "2023-02-03T13:50:50"^^xsd:dateTime ;
    skos:altLabel "Kveder"@nb,
        "Kvæde"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/592> ;
    skos:definition "Kvad er dikt med eldre nordisk språk og metrikk [SNL]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Scaldic poetry"@en,
        "Kvad"@nb,
        "Kvad"@nn .

<https://id.nb.no/vocabulary/ntsf/2133> a skos:Concept ;
    dct:created "2023-02-03T13:55:13"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Religious ballads"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/23> ;
    skos:definition "Legendevisene er viser som ble til i den katolske kirkes tid i Norge, eller som er kommet hit fra utlandet. Visene handler om helgener og de prøvelsene de måtte utholde, eller om religiøse visjoner [NDLA]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Religious carols"@en,
        "Legendeviser"@nb,
        "Legendeviser"@nn ;
    skos:scopeNote "Brukes for tekster til legendeviser."@nb .

<https://id.nb.no/vocabulary/ntsf/2137> a skos:Concept ;
    dct:created "2023-02-03T14:06:20"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Politiske sanger"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Viser med politisk innhold [UBO]."@nb ;
    skos:example """Politiska visor från Sveriges senmedeltid.\r
Krigsvisor : svensk värvnings- & krigspropaganda från 30-åriga kriget till Gustav III."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Political songs"@en,
        "Politiske viser"@nb,
        "Politiske viser"@nn ;
    skos:scopeNote "Brukes om tekster til politiske viser."@nb .

<https://id.nb.no/vocabulary/ntsf/2141> a skos:Concept ;
    dct:created "2023-02-03T14:10:20"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Ballads about knights"@en,
        "Knight's ballads"@en,
        "Ridderballader"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/23> ;
    skos:definition "Ridderviser er en en gruppe ballader med handling lagt til høyere sosiale kretser. De gir en realistisk skildring av menneskelige konflikter, ofte av kjærlighetsforhold, mange med tragisk utgang. I riddervisene møter vi et allmenn-europeisk, høvisk ideal, men bare få av de nordiske riddervisene har direkte sammenheng med viser utenom Norden [SNL]."@nb ;
    skos:example "Riddara-rímur."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Ballads of chivalry"@en,
        "Ridderviser"@nb,
        "Ridderviser"@nn ;
    skos:scopeNote "Brukes for tekser til ridderviser."@nb .

<https://id.nb.no/vocabulary/ntsf/2150> a skos:Concept ;
    dct:created "2023-02-03T14:31:36"^^xsd:dateTime ;
    skos:altLabel "Tittelregister"@nb,
        "Tittelregistre"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/800> ;
    skos:definition "Alfabetisk fortegnelse over titler behandlet i et vitenskapelig arbeid [UBO]."@nb ;
    skos:example "The Columbia Granger's index to poetry in anthologies / Tessa Kale."@nb,
        "Titles of English books (and of foreign books printed in England) : an alphabetical finding-list by title of books published under the author's name, pseudonym or initials : 2 : 1641-1700."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Title indexes"@en,
        "Tittelindekser"@nb,
        "Tittelindeksar"@nn .

<https://id.nb.no/vocabulary/ntsf/216> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:altLabel "Barndom"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Verk med barn eller ungdom som hovedpersoner, og hvor skildring av oppvekst/barndom er et sentralt tema [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026243> ;
    skos:example "Beatles / L.S. Christensen."@nb,
        "Da He-man kom til Norge : en fortelling om å vokse opp på åttitallet / Ole-Martin Ihle."@nb,
        "Herman: historier fra en udiagnostisert oppvekst / Herman Flesvig og Erlend Loe."@nb,
        "Mannen som elsket Yngve / Tore Renberg."@nb,
        "Populærmusikk fra Vittula / Mikael Niemi."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Coming-of-age"@en,
        "Oppvekst"@nb,
        "Oppvekst"@nn ;
    skos:scopeNote "Kan brukes på både fag- og skjønnlitteratur."@nb .

<https://id.nb.no/vocabulary/ntsf/2160> a skos:Concept ;
    dct:created "2023-02-06T08:17:17"^^xsd:dateTime ;
    skos:altLabel "Catalogue raisonné"@en,
        "Comprehensive catalogs"@en,
        "Oeuvre catalogs"@en,
