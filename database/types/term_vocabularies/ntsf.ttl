<https://id.nb.no/vocabulary/ntsf/168> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-11-15T15:22:56"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/508> ;
    skos:definition "Legende er i vanlig språkbruk underholdende og oppbyggelige fortellinger om en helgen (eller en annen helt). Opprinnelig ble ordet brukt om de kirkelige søndagstekster, dels de utdrag av martyr- og helgenkrøniker som fra gammel tid ble lest i kirkene. Legendestoff baserer seg oftest på muntlige overleveringer om en helgens liv og/eller død, men er utsmykket og utvidet av fortellere, har fått sin form av nedskriverne, oftest kirkens menn, og kan ha fjernet seg langt fra virkeligheten. Legender tjente som klosterlesning og underholdning i middelalderen (SNL)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026407> ;
    skos:example "Kaiser Octavianus."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Legends"@en,
        "Legender"@nb,
        "Legender"@nn .

<https://id.nb.no/vocabulary/ntsf/1681> a skos:Concept ;
    dct:created "2022-10-19T08:28:15"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/503> ;
    skos:definition "Encyklika er et rundskriv fra paven, enten til hele den katolske kirke eller til et enkelt lands biskoper. I senere tid er de også stilet til alle lekfolk og til «alle mennesker av god vilje» [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026081> ;
    skos:example "Evangelium vitae : om menneskelivets verdi og ukrenkelighet."@nb,
        "Tro og fornuft : pave Johannes Paul IIs rundskriv til biskopene i Den katolske kirke om forholdet mellom tro og fornuft."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Encyclicals"@en,
        "Encyklikaer"@nb,
        "Encyclikaer"@nn .

<https://id.nb.no/vocabulary/ntsf/1684> a skos:Concept ;
    dct:created "2022-10-19T08:50:05"^^xsd:dateTime ;
    skos:altLabel "Government yearbooks"@en,
        "Statskalender"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/336> ;
    skos:definition """Norges statskalender var en fortegnelse over konstitusjonelle organer og statsforvaltning som ble utgitt årlig i perioden 1815-2011.\r
 \r
Statskalenderen inneholdt en komplett oversikt over statsinstitusjoner med opplysninger om antall ansatte, virksomhetsområder, organisering, budsjetter, ansvars- og arbeidsområde. Den hadde også oversikt over ansatte (med personalia), adresser og telefonnumre. Videre inneholdt den oppdatert oversikt over Stortingets sammensetning, regjeringen og kongehuset.\r
Norges statskalender ble etter vedtak av Fornyings- administrasjon og kirkedepartementet nedlagt med virkning fra 1. januar 2012 [SNL]."""@nb ;
    skos:example "Norges statskalender : fortegnelse over konstitusjonelle organer og statsforvaltning m.v. = Norwegian government yearbook."@nb,
        "Suomen valtiokalenteri = Finlands statskalender."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "State calendars"@en,
        "Statskalendere"@nb,
        "Statskalendrar"@nn .

<https://id.nb.no/vocabulary/ntsf/169> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2025-10-27T17:26:21"^^xsd:dateTime ;
    skos:altLabel "Encyclopediaer"@nb,
