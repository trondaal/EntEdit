    skos:definition "Telefonkatalog er en samling av telefonnummer sortert etter abonnentnavn innen et område [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026189> ;
    skos:example "Katalog over abonnenter ved telefonanlegg i Oslo og omegn 1929."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Telephone directories"@en,
        "Telefonkataloger"@nb,
        "Telefonkatalogar"@nn .

<https://id.nb.no/vocabulary/ntsf/229> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:altLabel "Plansjer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/418> ;
    skos:definition "Verk (bok i stort format) som inneholder plansjer [NAOB]."@nb ;
    skos:example "Døren : 24 plansjer i farger / ved Katti Wankel."@nb,
        """The vegetable garden = Der Gemüseegarten / text by Werner Dressendörfer.\r
Hovedsakelig ill."""@nb,
        "Vi tar hverandres hender : merkedager i høsthalvåret. [Plansjer]."@nb,
        """Vues de Paris : photogravures / de Neurdein frères. -\r
[24] pl. : ill. ; 22 x 32 cm."""@nb,
        """Vyer af Helsingfors. -\r
[12] løse pl. ; i mappe.\r
De fleste bilder merket: C.A. Hårdh's fotografi."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Plate books"@en,
        "Plansjeverk"@nb,
        "Plansjeverk"@nn ;
    skos:scopeNote "Her brukt om verk som hovedsakelig består av plansjer."@nb .

<https://id.nb.no/vocabulary/ntsf/2304> a skos:Concept ;
    dct:created "2023-03-20T12:44:48"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Lamentations"@en,
        "Songs of grief"@en,
        "Lamentoer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/580> ;
    skos:definition """Lamento (italiensk «klage») er en klage- eller sørgesang.Det tidligste kjente eksempelet på et lamentostykke er Lamento di Tristan fra 1200-tallet. Betegnelsen ble på 1600- og 1700-tallet brukt om komposisjoner med spesifikke musikalske kjennetegn, som lamenti i operaer. Et av de mest kjente eksemplene er «Lamento d'Arianna» («Ariadnes klage») i Claudio Monteverdis opera L'Arianna (1608); et annet kroneksempel er samme komponists «Lamento della Ninfa» fra Madrigali Guerrieri et Amorosi (1638).\r
Typiske musikalske kjennetegn for lamento-komposisjonene er diatonisk eller kromatisk fallende kvart-baserte tonerekker mellom toneartens grunn- og kvinttone (i a-moll for eksempel a–g–f–e eller a–gis–g–fis–f–e). Lamentobasser er ikke sjelden grunnlag for ostinate komposisjoner. Noen eksempler er Didos arie «When I am laid» fra Henry Purcells Dido and Aeneas, Johann Sebastian Bachs, «Crucifixus» fra Messe i h-moll BWV 232 og Wolfgang Amadeus Mozarts «Qui tollis peccata mundi» fra Messe i c-Moll KV 427.\r
Det er helt fram til vår tid blitt skrevet stykker som kan betegnes som lamenti eller som bare bygger på musikalsk materiale fra lamento-tradisjonen [Wikipedia]."""@nb ;
    skos:example "Lamentations funéraires (Publications Langues'O 1996)."@nb,
        "Planctus Magistrae Doloris : volgarizzamento in antico veronese (De Gruyter cop. 2013)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Laments"@en,
        "Klagesanger"@nb,
        "Klagesongar"@nn ;
    skos:scopeNote "Brukes for tekster til klagesanger."@nb .

<https://id.nb.no/vocabulary/ntsf/2328> a skos:Concept ;
    dct:created "2023-03-21T11:07:14"^^xsd:dateTime ;
    skos:altLabel "Lists of periodicals"@en,
        "Tidsskriftfortegnelser"@nb,
        "Tidsskriftregistre"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144> ;
    skos:definition "Systematisk oversikt, fortegnelse over periodika."@nb ;
    skos:example "List of journals indexed for MEDLINE (National Library of Medicine 2005-)."@nb,
        "Zeitschriften Deutschland, Österreich, Schweiz : deutschsprachige und ausgewählte internationale wissenschaftliche Zeitschriften, Loseblatt-Werke, Jahrbücher, Periodika auf CD-ROM und Online (Verlag der Schillerbuchhandlung Hans Banger 2000-)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Periodicals registers"@en,
        "Periodikafortegnelser"@nb,
        "Periodikalister"@nn .

<https://id.nb.no/vocabulary/ntsf/2347> a skos:Concept ;
    dct:created "2023-03-21T13:09:06"^^xsd:dateTime ;
    skos:altLabel "Songbooks"@en,
        "Sangbok"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Bok med tekster (og noter) til sanger (til bruk ved allsang e.l.) [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014027102> ;
    skos:example "Byen på tvers i viser og vers (Christianssands Byselskab, 2020)."@nb,
        "Osloviser (Musikk-husets forlag A/S, 2019)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Song books"@en,
        "Sangbøker"@nb,
        "Songbøker"@nn ;
    skos:scopeNote "Sangbøker inneholder som oftest noter, men vi har allikevel valgt å ta med begrepet i denne tesaurusen."@nb .

<https://id.nb.no/vocabulary/ntsf/2361> a skos:Concept ;
    dct:created "2023-03-27T07:59:19"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/14> ;
    skos:definition "Tekst som refererer og/eller vurderer et hørespill. Hørespill ble opprinnelig laget for fremføring i radio, f.eks. NRK Radioteatret [red.]."@nb ;
    skos:example """[Det var i den tid] / N. Chr. B.\r
Om "Sult" som hørespill, ved Radioteatret, Norge, 3/11, 1959."""@nb,
        """[Victoria] : [hørespill] / O.S.\r
Om "Victoria" som hørespill, ved Radioteatret, Norge, 20/11, 1956."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Radio plays reviews"@en,
        "Hørespillanmeldelser"@nb,
        "Høyrespelmeldingar"@nn .

<https://id.nb.no/vocabulary/ntsf/237> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Postills"@en,
        "Huspostiller"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/12> ;
    skos:definition "Postill er en prekensamling, helst brukt om prekensamlinger prester tidligere kunne bruke til høytlesning under gudstjenester. De var gjerne samlinger med prekener over alle kirkeårets tekster. En huspostill er en prekensamling beregnet på bruk i hjemmene, som en andaktsbok [Wikipedia]."@nb ;
    skos:example "En liden Postille for Børn / af H. Halling, Candidat i Theologien."@nb,
        "Huus oc Skibszpostille Offver alle Søndagers oc Hellige Dagers Epistler oc Evangelia / Mestendeel aff Lutheri Postiller sammendragen Aff Niels Mickelszøn Aalborg forige Sognepræst til Kongel. Majest. Sogn Bremerholm."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Postils"@en,
        "Postiller"@nb,
        "Postillar"@nn .

<https://id.nb.no/vocabulary/ntsf/2379> a skos:Concept ;
    dct:created "2023-04-11T09:53:15"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/287> ;
    skos:definition "Ein song med berre ei strofe, til dømes Stev. Slåttestev er også ofte einstrofingar. (Ballade og bånsull)"@nb ;
    skos:example "Vierzeiler-Lexikon : Schnaderhüpfel, Gesätzle, Gestanzeln, Rappeditzle, Neck-, Spott-, Tanzverse und verwandte Formen aus mündlicher Überlieferung : ein kommentiertes Typenverzeichnis : 1 : A-E (P. Lang c1991)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Quatrains"@en,
        "Enstrofinger"@nb,
        "Einstrofingar"@nn .

<https://id.nb.no/vocabulary/ntsf/2416> a skos:Concept ;
    dct:created "2023-05-31T07:29:45"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/580> ;
    skos:definition "Et epigram er et kort, fyndig og ofte satirisk dikt som ofte gir uttrykk for en tanke eller beskriver en person. Ordet kommer fra gresk der epigramma betyr «innskrift» eller «påskrift» [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026312> ;
    skos:example "Epigram / Anders Hovden. I: Urd 13(1909)."@nb,
        """Nordiske epigrammer / ved Finn Glambæk. \r
https://urn.nb.no/URN:NBN:no-nb_digibok_2010110206022"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Epigrams"@en,
        "Epigrammer"@nb,
        "Epigram"@nn .

<https://id.nb.no/vocabulary/ntsf/2420> a skos:Concept ;
    dct:created "2023-05-31T08:39:57"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "Leder, en redaksjonell kommentar som står på fast plass i en avis eller annen publikasjon og som uttrykker redaksjonens syn i et aktuelt spørsmål. Lederartiklene fungerte i partipressens tid, fram til 1980-årene, ofte som et uttrykk for standpunkter og holdninger som avisens parti sto for [SNL]."@nb ;
    skos:example """Nybrottsarbeid i trøbbel. – 2008, I: Aftenposten : kultur. - Oslo. - 14/12-(2008), s. 2 : ill., port.\r
https://urn.nb.no/URN:NBN:no-nb_digavis_aftenposten_morgen_1_20081214_149_583_2 (side 34 i visningen)."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Editor's introductions"@en,
        "Ledere"@nb,
        "Leiarar"@nn .

<https://id.nb.no/vocabulary/ntsf/2423> a skos:Concept ;
    dct:created "2023-05-31T10:14:44"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "Leserbrev, også kalt leserinnlegg, debattinnlegg eller brev til redaktøren, er kortere innlegg som en avis eller et annet periodikum publiserer. (...) (Wikipedia)."@nb ;
    skos:example "\"An Enemy of the people\" : to the editor. I: Evening post : 29/4-(1899), 3, Wellington."@nb,
        "The Ibsen subscription plays : to the editor of The Times / ... , Frederick Pollock. I: The Times : 12/5-(1893), 10, London."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Letters to the editor"@en,
        "Leserbrev"@nb,
        "Lesarbrev"@nn .

<https://id.nb.no/vocabulary/ntsf/2430> a skos:Concept ;
    dct:created "2023-06-05T10:23:29"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Større sangkomposisjon i flere satser, vanligvis for solostemmer, kor og orkester, især skrevet for høytidelige anledninger; tekst (eller musikk) til en slik komposisjon» [NAOB]."@nb ;
    skos:example """Sørgekantate, til Erindring av Salig Hr. Justizraad og Rektor Boalth, opførst av det Kongelige Harmoniske Akademie / Calus Fasting.\r
https://marcus.uib.no/instance/book/ubb-romertall-box-xxx-boa-02.html"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Cantatas"@en,
        "Kantater (tekster)"@nb,
        "Kantatar"@nn ;
    skos:scopeNote "Brukes her om teksten til kantater."@nb .

<https://id.nb.no/vocabulary/ntsf/2436> a skos:Concept ;
    dct:created "2023-06-09T10:13:55"^^xsd:dateTime ;
    skos:altLabel "Anatomic atlases"@en,
        "Anatomical atlases"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/339> ;
    skos:definition "En mer eller mindre komplett samling tegninger av anatomiske strukturer i menneskekroppen, både makroskopiske snitt og overflatestrukturer [SML/SNL]."@nb ;
    skos:example "Atlas of the human brain."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Anatomy atlases"@en,
        "Anatomiske atlas"@nb,
        "Anatomiske atlas"@nn .

<https://id.nb.no/vocabulary/ntsf/2439> a skos:Concept ;
    dct:created "2023-06-09T10:28:24"^^xsd:dateTime ;
    skos:altLabel "Celestial charts"@en,
        "Celestial maps"@en,
        "Star atlases"@en,
        "Star charts"@en,
        "Historiske stjernekart"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/17> ;
    skos:definition "Et himmelatlas er et kart over nattehimmelen, gjerne brukt for gamle stjernekart. Himmelatlas brukes til å identifisere stjerner, stjernebilder og planeter på nattehimmelen [UBO]."@nb ;
    skos:example "Maps of the heavens : antique maps of the heavens / by Carole Stott."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Celestial atlases"@en,
        "Himmelatlas"@nb,
        "Himmelatlas"@nn .

<https://id.nb.no/vocabulary/ntsf/2440> a skos:Concept ;
    dct:created "2023-06-09T10:34:10"^^xsd:dateTime ;
    skos:altLabel "Geologiske atlas"@nb,
        "Geologiske atlas"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/141> ;
    skos:definition "Geologiske kart er kart som viser et områdes geologiske oppbygning. De forskjellige bergartene eller strukturelle enhetene er avsatt med forskjellig farge eller skravering, og forkastninger og andre strukturer er avmerket med tegn. Geologiske kart over løsavsetninger kalles ofte jordartskart [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026296> ;
    skos:example "Geological map of Asia."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Geological maps"@en,
        "Geologiske kart"@nb,
        "Geologiske kart"@nn .

<https://id.nb.no/vocabulary/ntsf/2443> a skos:Concept ;
    dct:created "2023-06-09T10:47:05"^^xsd:dateTime ;
    skos:altLabel "Hydrographic charts"@en,
        "Hydrographic survey charts"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/141> ;
    skos:definition "Et hydrografisk kart viser hvordan bekker og elver renner gjennom landskapet, hvordan innsjøer, vann, bekker og elver danner et vassdrag og hvor store nedbørfelt de ulike vassdragene har [NVE]."@nb ;
    skos:example "A data capture system for hydrographic maps."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Hydrographic maps"@en,
        "Hydrografiske kart"@nb,
        "Hydrografiske kart"@nn .

<https://id.nb.no/vocabulary/ntsf/2444> a skos:Concept ;
    dct:created "2023-06-09T11:01:31"^^xsd:dateTime ;
    skos:altLabel "Celestial maps"@en,
        "Star maps"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/141> ;
    skos:definition "Et stjernekart er et kart over nattehimmelen. Astronomer deler stjernehimmelen inn i et rutenett for å forenkle bruken. De beynttes for å identifisere astronomiske objekter som stjerner, stjernebilder og galakser. Historisk har de blitt benyttet til navigasjon siden sivilisasjonens morgen [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026116> ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Celestial charts"@en,
        "Stjernekart"@nb,
        "Planetkart"@nn .

<https://id.nb.no/vocabulary/ntsf/2448> a skos:Concept ;
    dct:created "2023-06-09T11:16:50"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/141> ;
    skos:definition "Et kart som viser utbredelsen av organismer eller naturtyper i et område [UBO]."@nb ;
    skos:example "Hekkefuglatlas for Aust-Agder 1995-2004."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Distribution maps"@en,
        "Utbredelseskart"@nb,
        "Utbreiingskart"@nn .

<https://id.nb.no/vocabulary/ntsf/2449> a skos:Concept ;
    dct:created "2023-06-09T11:24:49"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/141> ;
    skos:definition "Vegetasjonskart er et kart som gjengir fordelingen av vegetasjonen eller plantesamfunnene i et gitt område [SNL]."@nb ;
    skos:example "Vegetasjonskartlegging og bruk av vegetasjonskart."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Vegetation maps"@en,
        "Vegetasjonskart"@nb,
        "Vegetasjonskart"@nn .

<https://id.nb.no/vocabulary/ntsf/2450> a skos:Concept ;
    dct:created "2023-06-20T10:13:28"^^xsd:dateTime ;
    skos:altLabel "Barnebok"@nb,
        "Barnelitteratur"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Tekster skrevet av voksne for å bli lest av eller for barn. Mer enn bare en målgruppe: «Barneperspektivet og det aktive barnet er hovedelement i barnelitteraturen» [SNL]."@nb ;
    skos:example """Henrik og badesvampen.\r
https://www.nb.no/items/URN:NBN:no-nb_digibok_2012052305053"""@nb,
        "Lommebog for Børn."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Children's books"@en,
        "Barnebøker"@nb,
        "Barnebøker"@nn ;
    skos:scopeNote "Termen blir brukt særlig i Nasjonalbibliotekets spesialbibliografier for eldre barnelitteratur som forskningsobjekt, og i Ibsenbibliografien på Ibsenrelatrert stoff rettet mot barn.  Som oftest ikke brukt på moderne, ordinære barnebøker."@nb .

<https://id.nb.no/vocabulary/ntsf/2454> a skos:Concept ;
    dct:created "2023-06-20T10:37:16"^^xsd:dateTime ;
    dct:modified "2025-10-27T17:26:21"^^xsd:dateTime ;
    skos:altLabel "Omdiktinger"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Gjenskaping av en annen forfatters litterære tekst, for eksempel i form av en parodi [Humord]."@nb ;
    skos:example """Henrik Falk / Vigdis Hjort. -\r
(Omdiktning av Hedda Gabler)."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Retellings"@en,
        "Omdiktninger"@nb,
        "Omdiktingar"@nn .

<https://id.nb.no/vocabulary/ntsf/246> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:altLabel "By-laws"@en,
        "Statutories"@en,
        "Instruks"@nb,
        "Regelverk"@nb,
        "Reglement"@nb,
        "Vedtekter"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/438> ;
    skos:definition """Et reglement (fra fransk règlement ) er en samling av nedskrevne regler for en viss virksomhet. Betegnelsen er gjerne brukt av offentlige virksomheter eller offentlige eller private institusjoner, etter vedtak i et besluttende organ (ordensreglement, uniformsreglement)\r
Et reglement vil, i likhet med forskrifter, gjerne være inndelt i punkter eller paragrafer, men reaksjoner på brudd vil gjerne være mildere enn ved brudd på forskrifter\r
I gamle dager ble betegnelsen reglement også benyttet i betydningen budsjett (Statsreglement, lønningsreglement) [Jusleksikon.no]."""@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026611> ;
    skos:example """Midlertidigt reglement for Rigshospitalet i Christiania / ifølge kongelig bemyndigelse udfærdiget af stiftelsens direction.\r
[kilde: Norske bøker 1519-1850]."""@nb,
        "Reglement om Qvarantainevæsenet : Christiania den 10de Februar 1849."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Statutes"@en,
        "Reglementer"@nb,
        "Reglement"@nn .

<https://id.nb.no/vocabulary/ntsf/2484> a skos:Concept ;
    dct:created "2023-08-01T13:17:17"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/14> ;
    skos:definition "En journalistisk eller essayisk tekst som refererer og vurderer en ballettforestilling [red.]."@nb ;
    skos:example """Fuhr, Bodil\r
Ny og voldsom Vildand i fransk ballettutgave. \r
I: Aftenposten. - Oslo. - 1994, 9/2."""@nb,
        """[Om Pan] : [ballett]. \r
I: Programbladet (Oslo : 1946-2000). - Oslo : Programbladet A/S. - 18(1964)nr. 11. - S. 9, 17.\r
Om David Monrad Johansens Pan-komposisjon oppført som ballet ved Edith Roger."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Ballett recensions"@en,
        "Ballettanmeldelser"@nb,
        "Ballettmeldingar"@nn .

<https://id.nb.no/vocabulary/ntsf/2488> a skos:Concept ;
    dct:created "2023-08-23T08:35:28"^^xsd:dateTime ;
    skos:altLabel "Commentaries (literature)"@en,
        "Litterære kommentarutgaver"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/2282> ;
    skos:definition "En tekst som gir opplysninger om eller angir et kritisk perspektiv i forhold til en annen tekst [Litteraturvitenskapelig leksikon, s. 111]."@nb ;
    skos:example "Anmærkninger over de tre første Bøger af Hr. David Crantzes Historie om Grønland / [Henrik Christopher Glahn]."@nb,
        "Kommentarbind til Henrik Ibsens skrifter."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Literary commentaries"@en,
        "Litterære kommentarer"@nb,
        "Litterære kommentarar"@nn .

<https://id.nb.no/vocabulary/ntsf/2492> a skos:Concept ;
    dct:created "2023-08-23T08:49:04"^^xsd:dateTime ;
    skos:altLabel "Commentaries (journalism)"@en,
        "News commentaries"@en,
        "Kommentarer (journalistiske)"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/2282> ;
    skos:definition "En tekst som kjennetegnes av at journalisten bruker sin stemme og analyserer en aktuell sak i nyhetsbildet. I en kommentar kan journalisten åpent argumentere for sitt standpunkt [https://snl.no/kommentar_-_journalistisk_sjanger]."@nb ;
    skos:example """Leser de Ibsen i India? / Inger Anne Olsen.\r
I: Aftenposten : kultur. - 2010, 25/8, s. 2."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Journalistic commentaries"@en,
        "Journalistiske kommentarer"@nb,
        "Journalistiske kommentarar"@nn .

<https://id.nb.no/vocabulary/ntsf/250> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:altLabel "Itineraries"@en,
        "Travel descriptions"@en,
        "Travel diaries"@en,
        "Travel literature"@en,
        "Travelers' writings"@en,
        "Travellers' writings"@en,
        "Travelogs"@en,
        "Travelogues"@en,
        "Reisebeskrivelser"@nb,
        "Reisebrev"@nb,
        "Reiselitteratur"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/494> ;
    skos:definition "Skildring av en reise (særlig av en reise man selv har gjort) [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026200> ;
    skos:example "Iran og det nye Midt-Østen / Mah-Rukh Ali."@nb,
        "Omelette norvegiénne : reiser i Norge : epistler og notater / Suzanne Brøgger."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Travel writing"@en,
        "Reiseskildringer"@nb,
        "Reiseskildringar"@nn ;
    skos:scopeNote "Brukes for verk hvor det legges mer vekt på skildring av reise og opplevelse enn på oversikt over overnatting og severdigheter."@nb .

<https://id.nb.no/vocabulary/ntsf/2512> a skos:Concept ;
    dct:created "2023-09-04T11:21:33"^^xsd:dateTime ;
    skos:altLabel "Astronomisk årbok"@nb,
        "Astronomiske årbøker"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/295> ;
    skos:definition "Efemerider er tabeller over forutberegnede posisjoner for himmellegemer ved gitte tidspunkter. Ordet brukes også i betydningen astronomisk årbok [SNL]."@nb ;
    skos:example "Astronomical Phenomena for the Year 2019."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Ephemerides"@en,
        "Efemerider"@nb,
        "Efemeridar"@nn .

<https://id.nb.no/vocabulary/ntsf/2515> a skos:Concept ;
    dct:created "2023-09-04T11:38:41"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Samling av eksempler, enten som selvstendig verk eller som del av eller vedlegg til lærebok, avhandling eller lignende [ordbøkene.no]."@nb ;
    skos:example "Foundations of physical chemistry : worked examples."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Worked examples"@en,
        "Eksempelsamlinger"@nb,
        "Eksempelsamlingar"@nn .

<https://id.nb.no/vocabulary/ntsf/2518> a skos:Concept ;
    dct:created "2023-09-04T11:44:14"^^xsd:dateTime ;
    skos:altLabel "Ekskursjonsførere"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/132> ;
    skos:definition "Bøker som beskriver et geografisk område av særlig interesse for vitenskapelig undersøkelse, for eksempel av biologisk eller geologisk art [UBO]."@nb ;
    skos:example "Excursion guide : tours a and b to Svalbard."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Excursion guides"@en,
        "Ekskursjonsguider"@nb,
        "Ekskursjonsguidar"@nn .

<https://id.nb.no/vocabulary/ntsf/2522> a skos:Concept ;
    dct:created "2023-09-04T12:07:38"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144> ;
    skos:definition "Farmakopé er en statsautorisert liste eller katalog over legemidler. I en farmakopé gis det regler og forskrifter for analyse og fremstilling av legemidler blant annet på apotek [SML/SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2017026039> ;
    skos:example "Den Norske Farmakopé 1939."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Pharmacopoeias"@en,
        "Farmakopeer"@nb,
        "Farmakopear"@nn .

<https://id.nb.no/vocabulary/ntsf/253> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/104> ;
    skos:definition "Reskript ble i enevoldstiden brukt om kongelige befalinger rettet til en eller flere bestemte personer eller myndigheter, f.eks. et regjeringskollegium [NLI]."@nb ;
    skos:example "(Kongelig reskript til overøvrighetene på landet, angående opptagelse av manntall, og om dessuten å holde stortingsvalg i «Nordlandene og Finmarken»)."@nb,
        "[Rescript angaaende Mandtal over alle stemmeberettigede Indvaanere i Districterne]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Rescripts"@en,
        "Reskripter"@nb,
        "Reskript"@nn .

<https://id.nb.no/vocabulary/ntsf/2535> a skos:Concept ;
    dct:created "2023-09-06T11:52:56"^^xsd:dateTime ;
    skos:altLabel "Laboratoriemanualer"@nb,
        "Laboratoriemanualar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/132> ;
    skos:definition "En oppgavebok med instrukser til laboratorieeksperimenter. Den blir ofte utgitt i forbindelse med en tekstbok [UBO]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026120> ;
    skos:example "Microbiology : a laboratory manual."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Laboratory manuals"@en,
        "Laboratoriehåndbøker"@nb,
        "Laboratoriehandbøker"@nn .

<https://id.nb.no/vocabulary/ntsf/2539> a skos:Concept ;
    dct:created "2023-09-06T12:17:02"^^xsd:dateTime ;
    skos:altLabel "Hugsekort"@en,
        "Flashkort"@nb,
        "Huskekort"@nb,
        "Lærekort"@nb,
        "Læringskort"@nb,
        "Memoreringskort"@nb,
        "Puggekort"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Huskekort, som brukes for eksempel ved forberedelse til eksamen [red.]."@nb ;
    skos:example "Farmakologikort : huskekort til eksamenslæsning."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Flashcards"@en,
        "Memokort"@nb,
        "Memokort"@nn .

<https://id.nb.no/vocabulary/ntsf/2549> a skos:Concept ;
    dct:created "2023-09-06T12:49:06"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Et molekylbyggesett er et fysisk, tredimensjonalt modelleringsverktøy for bygging av molekyler og krystallgitter/krystallstrukturer som illustrerer deres atomære sammensetning og bindingsforhold [UBO]."@nb ;
    skos:example "The Prentice Hall molecular model set for organic chemistry."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Molecular modelling kits"@en,
        "Molekylbyggesett"@nb,
        "Molekylbyggjesett"@nn .

<https://id.nb.no/vocabulary/ntsf/2552> a skos:Concept ;
    dct:created "2023-09-06T13:16:52"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/9> ;
    skos:definition "Nautisk almanakk er et tabellverk for posisjon på forskjellige himmellegemer hver dag gjennom året. Det er utarbeidet til bruk ved astronomisk navigasjon til sjøs, og inneholder astronomiske tabeller over sol, måne, fire planeter og 57 stjerner som trengs for beregning av posisjon [SNL]."@nb ;
    skos:example "Norsk nautisk almanakk og sjøfartskalender."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Nautical almanacs"@en,
        "Nautiske almanakker"@nb,
        "Nautiske almanakkar"@nn .

<https://id.nb.no/vocabulary/ntsf/2555> a skos:Concept ;
    dct:created "2023-09-06T13:26:37"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144> ;
    skos:definition "Systematisk oversikt eller fortegnelse over planter i en spesifikk samling, for eksempel herbariesamlinger eller botaniske hager [UBO]."@nb ;
    skos:example "Catalogue of plants 1990."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Plant catalogues"@en,
        "Plantekataloger"@nb,
        "Plantekatalogar"@nn .

<https://id.nb.no/vocabulary/ntsf/2558> a skos:Concept ;
    dct:created "2023-09-06T13:36:56"^^xsd:dateTime ;
    dct:modified "2023-09-06T13:37:06"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/99> ;
    skos:definition "Oversikt over sopp som vokser innenfor et bestemt område eller i en bestemt periode [UBO]."@nb ;
    skos:example "Cappelens soppbok."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Fungi floras"@en,
        "Soppfloraer"@nb,
        "Soppfloraer"@nn .

<https://id.nb.no/vocabulary/ntsf/2561> a skos:Concept ;
    dct:created "2023-09-06T13:52:14"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/339> ;
    skos:definition "Spektralatlas er et referanseverk med samling av spektra av forskjellige objekter, ofte presentert grafisk [UBO]."@nb ;
    skos:example "A high resolution spectral atlas of the solar irrariance from 380 to 700 nanometers."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Spectral atlases"@en,
        "Spektralatlas"@nb,
        "Spektralatlas"@nn .

<https://id.nb.no/vocabulary/ntsf/2564> a skos:Concept ;
    dct:created "2023-09-06T14:01:01"^^xsd:dateTime ;
    dct:modified "2023-09-18T10:33:07"^^xsd:dateTime ;
    skos:altLabel "Star catalogs"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144> ;
    skos:definition "Stjernekatalog er en systematisk ordnet oversikt over stjerner etter koordinater (rektascensjon og deklinasjon) på himmelhvelvingen, sammen med informasjon om størrelsesklasse, lysspekter, parallakse, med mer [SNL]."@nb ;
    skos:example "Washington double star catalog cross index."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Star catalogues"@en,
        "Stjernekataloger"@nb,
        "Stjernekatalogar"@nn .

<https://id.nb.no/vocabulary/ntsf/2568> a skos:Concept ;
    dct:created "2023-09-06T14:09:27"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1775> ;
    skos:definition "Rapport fra marinbiologiske eller oseanografiske feltundersøkelser [UBO]."@nb ;
    skos:example "Toktrapport fra haneskjellundersøkelser i Porsangerfjorden…"@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Target reports"@en,
        "Toktrapporter"@nb,
        "Toktrapportar"@nn .

<https://id.nb.no/vocabulary/ntsf/2573> a skos:Concept ;
    dct:created "2023-09-06T14:17:43"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1781> ;
    skos:definition "En verneplan er en oversikt over natur- og/eller kulturverdier med formål å sikre ivaretagelse av viktige ressurser for ettertiden [UBO]."@nb ;
    skos:example "Barskog i Nord-Norge : utkast til verneplan."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Conservation plans"@en,
        "Verneplaner"@nb,
        "Verneplanar"@nn .

<https://id.nb.no/vocabulary/ntsf/260> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-10-02T15:29:00"^^xsd:dateTime ;
    skos:altLabel "Kongesagaer"@nb,
        "Norrøn litteratur"@nb,
        "Ættesagaer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition """Saga er en betegnelse for den islandske episke prosalitteraturen fra middelalderen. I norrøn språkbruk betyr saga både muntlig og skrevet fortelling, uten hensyn til lengde, innhold eller form; man har skjelnet mellom «sann-saga» og «lygi-saga», men grensen går ikke alltid der man nå ville sette den mellom historie og diktning.\r
Sagaene har for det meste anonyme forfattere. Bare enkelte konge-og samtidssagaer har navngitte forfattere, for eksempel Snorre Sturlason og Sturla Tordarson (SNL)."""@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026522> ;
    skos:example "Alexanders saga / Brandr Jónsson."@nb,
        "Heimskringla / Snorri Sturluson."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Sagas"@en,
        "Sagaer"@nb,
        "Sagaer"@nn .

<https://id.nb.no/vocabulary/ntsf/2607> a skos:Concept ;
    dct:created "2023-10-03T09:48:28"^^xsd:dateTime ;
    skos:altLabel "Seismiske atlas"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/2603> ;
    skos:definition "Seismiske kart er geofysiske kart som viser seismiske data, og brukes til å tolke f.eks. sedimenttyper og geologiske lag [UBO]."@nb ;
    skos:example "Seismic atlas of Western Svalbard."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Seismic maps"@en,
        "Seismiske kart"@nb,
        "Seismiske kart"@nn .

<https://id.nb.no/vocabulary/ntsf/261> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2020-03-20T09:17:29"^^xsd:dateTime ;
    skos:altLabel "Contemporary folk tales"@en,
        "Family stories"@en,
        "Historical legends"@en,
        "Legends about supernatural beings"@en,
        "Legends about supranatural beings"@en,
        "Migratory legends"@en,
        "Modern urban legends"@en,
        "New urban legends"@en,
        "Urban legends"@en,
        "Urban myths"@en,
        "Gudesagn"@nb,
        "Historiske sagn"@nb,
        "Overnaturlige sagn"@nb,
        "Samtidssagn"@nb,
        "Vandresagn"@nb,
        "Ættesagn"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/508> ;
    skos:definition "Sagn (av det norrøne verbet segja, «å fortelle noe», altså «sagn» som i «utsagn») er en kort, ofte enepisodisk, muntlig fortelling nært knyttet til folketroen. Sagnene er gjenfortalt (tradert) folkediktning. Fortellinger om fortellerens egne møter med det overnaturlige kalles memorat. Sagn forekommer i flere varianter og kan kategoriseres etter innhold i naturmytiske sagn, historiske sagn, opphavssagn og nåtidssagn eller moderne sagn. Sagnet forteller om krefter mennesket ikke kan kontrollere, og som det bør passe seg for. I motsetning til eventyret, der helten seirer over motstanderen, ender sagnet stort sett med nederlag for hovedpersonen. Sagn skiller seg fra eventyr ved at fortellinger utgir seg for å være sanne. Det betyr ikke at fortelleren nødvendigvis tror på innholdet, men han må gå god for det i fortellersituasjonen. Mens eventyr ikke er knyttet til bestemte steder og dertil foregår i en ubestemmelig tid, forsterkes sagnenes virkelighetstilknytning ved at begivenhetene ofte oppgis å ha foregått på et navngitt sted med navngitte personer. På denne måten underbygges fortellingens troverdighet. Ikke desto mindre finner vi ofte samme fortelling knyttet til mange forskjellige steder. Dette kaller vi vandresagn i motsetning til lokalsagn som bare finnes på ett sted [Wikipedia]."@nb ;
    skos:example "Gebirgs-Sagen / Henrich Steffens."@nb,
        "Norske sagn."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Folk legends"@en,
        "Sagn"@nb,
        "Segner"@nn .

<https://id.nb.no/vocabulary/ntsf/2642> a skos:Concept ;
    dct:created "2023-10-18T06:57:01"^^xsd:dateTime ;
    skos:altLabel "Red Lists"@en,
        "Red data lists"@en,
        "Red list"@en,
        "Røde lister"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/2502> ;
    skos:definition "Rødliste er en liste over arter eller naturtyper med vurderinger av deres risiko for å dø ut (utryddelse) eller å forsvinne fra et område (snl)."@nb ;
    skos:example "Norsk rødliste for naturtyper 2011."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "IUCN Red List of Threatened Species"@en,
        "Rødlister"@nb,
        "Raudlister"@nn .

<https://id.nb.no/vocabulary/ntsf/2684> a skos:Concept ;
    dct:created "2024-01-11T14:03:25"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338> ;
    skos:definition "En database er en samling data lagret på et elektronisk medium. Datasamlingen er organisert og strukturert etter en bestemt strategi eller modell – en databasemodell. Dataene brukes og vedlikeholdes gjennom et bestemt programsystem som kalles et databasesystem eller databasehåndteringssystem (SNL)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026081> ;
    skos:example """Dartmouth Dante project.\r
Omtale: The Dartmouth Dante Project (DDP) is a searchable full-text database containing more than seventy commentaries on Dante's Divine Comedy - the Commedia."""@nb,
        """Factiva.\r
Omtale: Newspapers, journals and news from thousands of newspapers such as Financial Times, Wall Street Journal, Le Monde and El Pais. Company information. Financial instruments: Stocks, currency, funds and stock indices."""@nb,
        """MedicinesComplete.\r
Omtale: MedicinesComplete brings together the world's leading resources, providing health professionals with expert and unbiased knowledge to make the best clinical decisions on the use and administration of drugs and medicines."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Databases"@en,
        "Databaser"@nb,
        "Databasar"@nn .

<https://id.nb.no/vocabulary/ntsf/2688> a skos:Concept ;
    dct:created "2024-01-29T10:55:45"^^xsd:dateTime ;
    dct:modified "2024-02-27T09:04:45"^^xsd:dateTime ;
    skos:altLabel "Dialektordbok"@nb,
        "Dialektordbok"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1502> ;
    skos:definition """Ordbok med forklaring av dialektord \r
; ordbok over ordforrådet i en dialekt (naob)."""@nb ;
    skos:example "Prate døl / Jørn Dissen og Rune Solhjem."@nb,
        "Stadig ballong : ord og uttrykk fra gamle Ålesund."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Dialect dictionaries"@en,
        "Dialektordbøker"@nb,
        "Dialektordbøker"@nn .

<https://id.nb.no/vocabulary/ntsf/27> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Bibelhistorier"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/251> ;
    skos:definition "Fortelling som forekommer i Bibelen [NAOB]."@nb ;
    skos:example "Bibelfortellinger for barn / Svein Tindberg."@nb,
        "David og Goliat / Sophie Piper."@nb,
        "Noahs ark og andre fortellinger / Sally Ann Wright."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Bible stories"@en,
        "Bibelfortellinger"@nb,
        "Bibelforteljingar"@nn ;
    skos:scopeNote "Brukes for skjønn- og faglitteratur hvor fortellingen henter karakterer og handling fra Bibelen. Som oftest brukt på bøker for barn."@nb .

<https://id.nb.no/vocabulary/ntsf/270> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:altLabel "Samfunnssatire"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/127> ;
    skos:definition "Satire, opprinnelig brukt om en litteraturform hos romerne som refset og spottet tidens laster og narraktigheter. Sjangeren ble først utformet av Ennius, og dens største representanter i romersk litteratur er Horats og Juvenal.Humanismen brakte igjen satiren på mote. Hovednavn er da og senere Rabelais, Erasmus, Cervantes, Swift, Voltaire, Holberg. I moderne litteratur brukes betegnelsen om enhver diktning som med spottens våpen angriper tidens, samfunnets eller det enkelte menneskets skrøpeligheter [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026525> ;
    skos:example "Brennpunkt: Oslo /  [Ronald] Kabíček, [Endre] Skandfer, [Bjarte] Agdestein."@nb,
        "Satiren / Georg Ignaz Lucius."@nb,
        "Slyngel de luxe / Steffen Kverneland."@nb,
        "Udvalg af Corsarens to første Aargange."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Satirical literature"@en,
        "Satire"@nb,
        "Satire"@nn .

<https://id.nb.no/vocabulary/ntsf/2709> a skos:Concept ;
    dct:created "2024-02-06T08:55:06"^^xsd:dateTime ;
    dct:modified "2024-02-27T09:04:45"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/341> ;
    skos:definition "Beskrivelse av innhold, tid og sted for en eller flere revyoppsetninger."@nb ;
    skos:example "Dætta æ et juleshow : program. Øyer teaterlag."@nb,
        "Fri, villig og het. Gjerdrum bygderevy."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Revue programs"@en,
        "Revyprogrammer"@nb,
        "Revyprogram"@nn .

<https://id.nb.no/vocabulary/ntsf/271> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-11-15T12:22:26"^^xsd:dateTime ;
