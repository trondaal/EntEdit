<https://id.nb.no/vocabulary/ntsf/1135> a skos:Concept ;
    dct:created "2021-09-27T14:27:41"^^xsd:dateTime ;
    dct:modified "2021-09-27T14:27:47"^^xsd:dateTime ;
    skos:altLabel "Animated cartoons"@en,
        "Animasjon (film)"@nb,
        "Tegnefilmer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Animasjonsfilm er en fellesbetegnelse for ulike filmteknikker der filmskaperen skaper en illusjon av bevegelse gjennom å manipulere motivet ved hjelp av enkeltbildeteknikk. Tegnefilm, dataanimasjon og dukkefilm er de mest kjente typene animasjonsfilm. I dag dominerer dataanimasjon innenfor kommersiell animasjonsfilmproduksjon. I fri kunstnerisk animasjonsfilm brukes et mangfold av ulike teknikker [snl]."@nb ;
    skos:example "Flåklypa grand prix (1975) [Mavis 415502]."@nb,
        "Gubben og katten"@nb,
        "Istid (2002)."@nb,
        "Sjel (2020)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrowMatch <http://id.loc.gov/authorities/genreForms/gf2011026049> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1311>,
        <https://id.nb.no/vocabulary/ntsf/1312> ;
    skos:prefLabel "Animated films"@en,
        "Animasjonsfilmer"@nb,
        "Animasjonfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1337> a skos:Concept ;
    dct:created "2022-02-20T18:10:23"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1202>,
        <https://id.nb.no/vocabulary/ntsf/338>,
