<https://id.nb.no/vocabulary/ntsf/121> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/479>,
        <https://id.nb.no/vocabulary/ntsf/508> ;
    skos:definition "En gåte er et spørsmål med et svar som er ukjent eller vanskelig å finne. Gåter kan være dype filosofiske spørsmål, mysterier en forsøker å løse i vitenskapen, eller en form for underholdning. Det er en prøve på skarpsindighet; å finne svaret på spørsmål som bevisst er uklart formulert [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026169> ;
    skos:example "777 gåter for barn / Børge Jensen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Riddles"@en,
        "Gåter"@nb,
        "Gåter"@nn .

<https://id.nb.no/vocabulary/ntsf/1230> a skos:Concept ;
