    skos:example "Norsk salmebok."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Psalm books"@en,
        "Salmebøker"@nb,
        "Salmebøker"@nn .

