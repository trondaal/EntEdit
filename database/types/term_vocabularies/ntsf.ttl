<https://id.nb.no/vocabulary/ntsf/883> a skos:Concept ;
    dct:created "2020-06-18T09:28:15"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/404> ;
    skos:definition "Skillingstrykk var små trykksaker, som oftest bare et sammenbrettet papirark, som kunne inneholde nyheter, humoristiske, sensasjonelle eller pedagogiske prosatekster, men som i de aller fleste tilfellene var på viseform, såkalte skillingsviser. Skillingstrykkene dukket opp allerede med de første boktrykkerne [Wikipedia]."@nb ;
    skos:example "Hans Kongelige Majestæt af Sverrig Carl den Ellevtes Syn 1676 : Natten mellem den 16de og 17de December."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/277> ;
    skos:prefLabel "Occasional prints"@en,
        "Skillingstrykk"@nb,
        "Skilingstrykk"@nn ;
    skos:scopeNote "Hovedsakelig brukt på eldre materiale (i perioden før 1950)."@nb .

<https://id.nb.no/vocabulary/ntsf/895> a skos:Concept ;
