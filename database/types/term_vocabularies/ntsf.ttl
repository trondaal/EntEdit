<https://id.nb.no/vocabulary/ntsf/1823> a skos:Concept ;
    dct:created "2022-11-16T07:55:21"^^xsd:dateTime ;
    skos:altLabel "Visuell antropologi"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1202> ;
    skos:definition "Dokumentarfilm som tar i bruk metode, teoretiske perspektiver og begreper fra sosialantropologien. Kalles også visuell antropologi. I sin strengeste forstand er etnografisk film mer en form for forskningsformidling for det antropologiske forskningsmiljøet enn formidling til et bredere publikum [red.]"@nb ;
    skos:example "Cold Case Hammarskjöld."@nb,
        "In My Mother's House."@nb,
        "The Anthropologist."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Ethnographic films"@en,
        "Etnografiske filmer"@nb,
        "Etnograifske filmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1838> a skos:Concept ;
    dct:created "2022-11-16T09:13:09"^^xsd:dateTime ;
    skos:altLabel "Parish reports"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "Kallsbok er en protokoll som føres av presten med opplysninger om embetet (kallet), til orientering og dokumentasjon for prost og biskop og etterfølgere. Innholdet kan variere mye, men ofte finnes opplysninger om kirken og kirkeinventaret, prestegården, embetsinntekter (prestelønnen), embetsdistriktet og fordelingen av gudstjenestene mellom de enkelte kirkene og kapellene [SNL]."@nb ;
    skos:example "Kaldsbok for Vadsø sognepræstembede under Varanger provsti i Tromsø stift."@nb,
        "Rødenes prestegjelds kaldsbog 1885."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Parish protocols"@en,
        "Kallsbøker"@nb,
        "Kallsbøker"@nn .

<https://id.nb.no/vocabulary/ntsf/1845> a skos:Concept ;
    dct:created "2022-11-16T09:49:26"^^xsd:dateTime ;
    skos:altLabel "Petitions"@en,
        "Petisjoner"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "Søknad, bønn, begjæring (til myndighet, øvrighetsperson) [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026358> ;
    skos:example "Überlebende von Kaufering : biografische Skizzen jüdischer ehemaliger Häftlinge ; Materialien zum KZ-Aussenlagerkomplex Kaufering."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Supplications"@en,
        "Supplikker"@nb,
        "Supplikar"@nn .

<https://id.nb.no/vocabulary/ntsf/185> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Veiledning knyttet til et bestemt læreverk for oppplæring i bestemte emner/fag [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026188> ;
    skos:example "Alfa 1 og 2 : lærerens bok / Ellen Hanssen."@nb,
