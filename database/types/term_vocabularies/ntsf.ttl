        "Stille lys / Morten Krogvold."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Photo books"@en,
        "Fotobøker"@nb,
        "Fotobøker"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/423> .

<https://id.nb.no/vocabulary/ntsf/524> a skos:Concept ;
    dct:created "2019-10-28T13:47:59"^^xsd:dateTime ;
    dct:modified "2019-10-28T13:51:17"^^xsd:dateTime ;
    skos:altLabel "Assignments"@en,
        "Exercises"@en,
        "Work books"@en,
        "Workbooks"@en,
        "Arbeidsbøker"@nb,
        "Oppgavesamlinger"@nb,
        "Øvebøker"@nb,
        "Øvinger"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Oppgavesamlinger, arbeidsbøker eller øvebøker som er utarbeidet til bruk i undervisning på grunn- og videregående skole, universitet, høgskoler og voksenopplæring. Inneholder oppgaver som skal løses av eleven eller studenten. Ofte tilknyttet et skoleverk [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026154> ;
    skos:example "Norsk nå! : arbeidsbok 1 - A1 : norsk og samfunnskunnskap for voksne innvandrere/ Gölin Kaurin Nilsen og Jorunn Fjeld."@nb,
        "Stairs 7 : workbook / Cecilie Thorsen, Hege Dahl Unnerud."@nb,
        "Zeppelin 5 : arbeidsbok til språkbok : norsk for barnetrinnet / Dagny Holm, Bjørg Gilleberg Løkken."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1851> ;
    skos:prefLabel "Problems and exercises"@en,
        "Oppgavebøker"@nb,
        "Oppgåvebøker"@nn .

<https://id.nb.no/vocabulary/ntsf/529> a skos:Concept ;
    dct:created "2019-11-12T11:08:54"^^xsd:dateTime ;
    dct:modified "2025-06-27T16:41:54"^^xsd:dateTime ;
    skos:altLabel "Feel-and-touch books"@en,
        "Texture books"@en,
        "Texturized books"@en,
        "Touch-and-feel books"@en,
        "Ta- og føle på-bøker"@nb,
        "Taktile bøker"@nb,
        "Ta- og føle på-bøker"@nn,
        "Taktile bøker"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/2969>,
        <https://id.nb.no/vocabulary/ntsf/425> ;
    skos:definition "Bok med taktile elementer som barn kan ta og føle på [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026192> ;
    skos:example "Dyra på gården : ta og føle."@nb,
        "Rogers filledokke mister alt / Anette Diesen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Textured books"@en,
        "Følebøker"@nb,
        "Følebøker"@nn ;
    skos:scopeNote """Målgruppen er her både små seende barn og blinde barn.\r
Med følebøker som i hovedsak er beregnet for blinde barn, kan barna øve opp evnen til å kjenne igjen former og figurer med fingrene og forberede seg på å lære punktskrift. Disse bøkene har former og figurer i forskjellige materialer, et utvalg taktile bilder som gjengir sentral tekst fra den visuelle boka, og parallell tekst i visuell skrift og punktskrift. Bøkene kan både være basert på eksisterende verk eller bøker skapt som følebøker"""@nb .

<https://id.nb.no/vocabulary/ntsf/532> a skos:Concept ;
    dct:created "2019-11-13T13:41:55"^^xsd:dateTime ;
    dct:modified "2020-01-06T12:34:41"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/258> ;
    skos:definition "Roman hvor handlingen er gjengitt i form av brev (NAOB)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026314> ;
    skos:example "Djevelen dypper pennen /  C.S. Lewis."@nb,
        "Siste jul i Paris / Hazel Gaynor."@nb,
        "Unge Werthers lidelser / Goethe."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Epistolary fiction"@en,
        "Brevromaner"@nb,
        "Brevromanar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/536> ;
    skos:scopeNote "Brukes for skjønnlitteratur hvor handlingen er gjengitt i form av brev."@nb .

<https://id.nb.no/vocabulary/ntsf/581> a skos:Concept ;
    dct:created "2020-01-03T16:04:45"^^xsd:dateTime ;
    dct:modified "2020-01-03T16:04:50"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278>,
        <https://id.nb.no/vocabulary/ntsf/508> ;
    skos:definition """Folkebok er en type prosalitteratur av blandet innhold og av forskjellig opprinnelse som ble trykt og spredt blant det brede lag av folket i europeiske land på 1400- og 1500-tallet. Opprinnelsen til denne typen litteratur er ofte å finne i legender og gjenfortellinger av middelalderlige episke dikt og romaner, som i forkortet og bearbeidet form snart tapte sitt opprinnelige aristokratiske publikum for å oppnå desto større popularitet som folkelesning.  \r
Forutsetningen for denne litteraturen var utviklingen av boktrykkerkunsten, som gjorde det mulig å masseprodusere bøker, og som førte til større lesekyndighet hos vanlige folk. Folkebøkenes popularitet holdt seg i mange hundre år og har dannet grunnlaget for flere kjente diktverker, blant annet Goethes drama Faust.Det eldste kjente norske trykket av en folkebok er En tragoedisk historie om den ædle og tappre Tistrand, hertugens søn af Burgundien, og den skiønne Indiana, den store Mogul keiserens datter af Indien (Christiania 1775) (SNL)."""@nb ;
    skos:example "En fornøielig Historie om den skjønne Magelone, en Kongedatter fra Neapel, og Ridder Peter med Sølvnøglerne, som var en Grevesøn af Provence."@nb,
        """[Holger Danske]\r
[kilde: Norske bøker 1519-1850]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Chapbooks"@en,
        "Folkebøker"@nb,
        "Folkebøker"@nn .

<https://id.nb.no/vocabulary/ntsf/588> a skos:Concept ;
    dct:created "2020-01-07T13:09:00"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Hymns"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/213>,
        <https://id.nb.no/vocabulary/ntsf/587> ;
    skos:definition "Salmer er religiøse sanger som primært hører til i gudstjenester i synagoger og kirker. Tekstene kan være fra Bibelen, særlig Salmenes bok, eller være diktet senere, enten på latin eller på ulike folkespråk. Med reformasjonen fikk den folkespråklige, kristne salmediktningen et kraftig oppsving. Salmer ble samlet og utgitt i salmebøker. Salmemelodiene er ment som felles menighetssang, men formen og de sanglige praksisene kan variere atskillig [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026079> ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Psalms (music)"@en,
        "Salmer"@nb,
        "Salmar"@nn ;
    skos:scopeNote "Brukes om tekster til religiøse sanger som primært hører til i gudstjenester i synagoger og kirker."@nb .

