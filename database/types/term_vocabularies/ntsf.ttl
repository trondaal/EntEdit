        "Kartografisk materiale"@nn .

<https://id.nb.no/vocabulary/ntsf/3024> a skos:Concept ;
    dct:created "2026-02-12T08:32:00"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
