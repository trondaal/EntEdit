    skos:related <https://id.nb.no/vocabulary/ntsf/1324> .

<https://id.nb.no/vocabulary/ntsf/1243> a skos:Concept ;
    dct:created "2021-10-19T12:49:43"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Filmer som har ungdom som målgruppe. Omhandler typisk miljø og tema som ungdom kan kjenne seg igjen i [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026632> ;
    skos:example "Fucking Åmål (1998)."@nb,
        "Få meg på, for faen (2011)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Teen films"@en,
        "Ungdomsfilmer"@nb,
        "Ungdomsfilmer"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/1374> .

<https://id.nb.no/vocabulary/ntsf/1253> a skos:Concept ;
    dct:created "2021-10-19T14:18:47"^^xsd:dateTime ;
    dct:modified "2025-03-25T07:44:15"^^xsd:dateTime ;
    skos:altLabel "Enketer"@nb,
        "Rundspørringer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/475> ;
    skos:definition "Enquête eller enkét, fra fransk enquête, avledet fra latin inquirere «utspørre», betyr rundspørring, og brukes først og fremst i pressen. En enquête er en undersøkelse som blir gjort ved å stille de samme spørsmål til et bestemt antall mennesker [Wikipedia]."@nb ;
    skos:example """"Z-enquête : 3 kortfilmskapere om norsk film" (Z : filmtidsskrift).\r
https://znett.com/2019/09/z-enquete-tre-kortfilmskapere-om-norsk-film/"""@nb,
        """Bloom i Norge (Agora).\r
https://www.idunn.no/agora/2019/02/enqute"""@nb,
        """Slik økes kvinneandelen i ledende stillinger : likestilling i arbeidslivet (Revisjon og regnskap).\r
https://www.revregn.no/i/2019/2/rr-2019-02-891"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Enquets"@en,
        "Enqueter"@nb,
        "Enquetar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/1708> .

<https://id.nb.no/vocabulary/ntsf/1262> a skos:Concept ;
    dct:created "2021-10-29T11:46:36"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Fotodokumentarer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/418>,
        <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "En historie eller hendelse som blir formidlet hoedsakelig ved hjelp av bilder [red.]."@nb ;
    skos:example "\"At eg ville døy, kunne ingen sjå\" (Tidsskrift for Norsk psykologforening, vol. 47, nr. 12 (2010)), se https://psykologtidsskriftet.no/reportasje/2010/12/eg-ville-doy-kunne-ingen-sja"@nb,
        "\"Klar - ferdig - utrykning!\" (Utdanning, nr. 1 (2020), s. 32-37) https://www.utdanningsnytt.no/lek-og-laering/klar-ferdig-utrykning/214303"@nb,
        "\"Siste etappe : å kunne leve mest mulig normalt sammen med familien var det Arne hadde å håpe på\" (Tidsskriftet sykepleien, nr. 6 (2019)), se https://sykepleien.no/sites/default/files/2020-02/er%20det%20alltid%20h%C3%A5p.pdf (s. 74-87)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Photo reports"@en,
        "Fotoreportasjer"@nb,
        "Fotoreportasjar"@nn .

<https://id.nb.no/vocabulary/ntsf/1267> a skos:Concept ;
    dct:created "2021-11-10T09:23:25"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338>,
        <https://id.nb.no/vocabulary/ntsf/453> ;
    skos:definition "En bedriftshistorie er en elektronisk eller skrevet tekst som beskriver opprinnelsen og driften av en virksomhetsenhet. Bedriftshistorien gir ofte en tidslinje som dekker alt fra stiftelsen av selskapet til hendelser som skjer i dag [Netinbag]"@nb ;
    skos:example "Med murerskje og engasjement : Frost-selskapene, murerbransjen og boligpolitikk 1943-2021 / Terje T.V. Bratberg og Per Frost."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Company history"@en,
        "Bedriftshistorie"@nb,
        "Føretakshistorie"@nn ;
    skos:scopeNote "Brukes ofte sammen med 'Jubileumsbøker'."@nb .

<https://id.nb.no/vocabulary/ntsf/130> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:altLabel "Pastoral letters and charges"@en,
        "Pastoralbrev"@nb ;
