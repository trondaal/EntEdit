<https://id.nb.no/vocabulary/ntsf/81> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-15T10:09:42"^^xsd:dateTime ;
    skos:altLabel "Essaysamlinger"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/494> ;
    skos:definition "Essay er en kortere avhandling på prosa hvor det subjektive preget og den stilistiske utformingen er mer vesentlig enn den saklige, vitenskapelige behandling av emnet. Essayistikken er den viktigste kunstneriske prosasjanger utenom fiksjonsprosaen [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026094> ;
    skos:example "Det var en gang et menneske / Jan Grue."@nb,
        "Å tale og å tie / Vigdis Hjorth."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Essays"@en,
        "Essay"@nb,
        "Essay"@nn ;
    skos:scopeNote "Subjektive tekster som stiller spørsmål ved og diskuterer ulike emner."@nb .

<https://id.nb.no/vocabulary/ntsf/82> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "Avsnitt, redegjørelse hvor en forfatter (eller utgiver, oversetter) henvender seg til leseren ved slutten av en bok [NAOB]."@nb ;
    skos:example """Etterord : rein vare / av Jon Fosse. - \r
I: Roman 1987. - [Stabekk] : Den norske bokklubben, 1992. - S. 345-349."""@nb,
        """Postfazione / Massimo Ciaravolo. - \r
I: Timidezza e dignità. - Milano : Iperborea, 2010. - S. 169-175."""@nb,
        """Postfazione / di Ingrid Basso. - \r
I: La notte del professor Andersen. - Milano : Iperborea, 2015. - S. [153]-166."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Afterwords"@en,
        "Etterord"@nb,
        "Etterord"@nn ;
    skos:scopeNote "Brukes om etterord i bøker."@nb .

<https://id.nb.no/vocabulary/ntsf/84> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2020-01-03T10:24:12"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/508> ;
    skos:definition "Fabel, fra latin fabula som betyr fortelling (fra verbet fari, å fortelle) er en betegnelse for en kort fortelling med en satirisk eller moralistisk handling, ofte i form av allegorier, og ofte i form av et dyr i hovedrollen som personifikasjoner av menneskelige egenskaper, laster eller dyder. Fabelens hensikt er å være belærende og underholdende, og en sjelden gang også refsende (Wikipedia)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026327> ;
    skos:example "Æsops fabler."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Fables"@en,
        "Fabler"@nb,
        "Fablar"@nn ;
    skos:scopeNote "Korte fortellinger med satirisk og moralsk handling, ofte med dyr i hovedrollen."@nb .

<https://id.nb.no/vocabulary/ntsf/88> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2019-03-07T12:54:09"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/412> ;
