<https://id.nb.no/vocabulary/ntsf/170> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2025-06-27T16:41:54"^^xsd:dateTime ;
    skos:altLabel "Lesebok"@nb,
        "Lesehefter"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/184> ;
    skos:definition "Bøker til bruk i grunnleggende leseopplæring, satt sammen av et variert utvalg av tekster i ulike sjangre, både sakprosa og skjønnlitteratur. Tekstene er ofte inndelt etter tema, med ordforklaring og oppgaver til hver tekst. Kan også omfatte lesehefter inndelt i ulike nivåer, med økende tekstmengde og vanskelighetsgrad [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026160> ;
    skos:example "Bokbussen oransje / forlagsredaktør: Kristin Hide."@nb,
        "Isbjørn : nivå 8 / Maria Roslev (Leseunivers)."@nb,
        "Jeg kan : lesebok : A2 / Ragnhild Andreassen."@nb,
        "Nye Zeppelin 3 : norsk for barnetrinnet : lesebok / Turid Fosby Elsness."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/434> ;
    skos:prefLabel "Readers (Publications)"@en,
        "Lesebøker"@nb,
        "Lesebøker"@nn .

<https://id.nb.no/vocabulary/ntsf/1761> a skos:Concept ;
    dct:created "2022-11-14T11:58:21"^^xsd:dateTime ;
    skos:altLabel "News stories"@en,
        "News story"@en,
        "Reportages"@en,
        "Reportasjelitteratur"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338>,
        <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "Reportasjen er en journalistisk sjanger der journalisten og/eller fotografen selv drar ut for å undersøke hva som skjer, og for å snakke med aktuelle personer [SNL]."@nb ;
    skos:example "1 av 12 jenter har en form for spiseproblemer reportasje: Mona Jacobsen. I: Skoleforum. Årg. 90, nr. 1 (1991)."@nb,
        "Vietnam : the real war : a photographic history."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "News reports"@en,
        "Reportasjer"@nb,
        "Reportasjar"@nn ;
    skos:scopeNote "Brukes både for bøker og enkeltstående reportasjer i en avis eller et tidsskrift."@nb .

<https://id.nb.no/vocabulary/ntsf/177> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:altLabel "Code of laws"@en,
        "Decrees"@en,
        "Laws"@en,
        "Lover (særtrykk)"@nb,
        "Lovsamlinger"@nb,
        "Særtrykk av lover"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/438> ;
    skos:definition """Lov betegner i videste forstand rettsregler som fastsetter rettigheter og plikter, såkalt materiell lov. I en mer snever betydning brukes ordet lov om skrevne rettsregler utferdiget av lovgivningsmakten, såkalt formell lov\r
I Norge er materiell lov rettsregler som bestemmer rettsforholdet til private rettsubjekter og hva innholdet går ut på, mens formell lov er en lov som er vedtatt i Stortinget og har Regjeringens sanksjon. Formell lov må ses i sammenheng med Legalitetsprinsippet, som handler om at ingen kan dømmes uten hjemmel i lov, jf. Grunnloven § 96, forsterket gjennom Grunnloven § 113, som sier at "Myndighetenes inngrep overfor den enkelte må ha grunnlag i lov.".\r
Skillet mellom formell lov og materiell lov har blitt stadig mer utvisket i Norge. Begrepet forskrift omfatter ikke bare vedtak som krever hjemmel i formell lov, men også generelle bestemmelser om f.eks. rett til tilskudd som bygger på budsjettvedtak kommer med. På denne måten utvides anvendelsesområdet for begrepet lov til å gjelde alle offentlige vedtak av generell karakter som er bestemmende for rettigheter og plikter til private personer m.v. Dermed har vi tatt mange skritt nærmere et lovsbegrep som omfatter mer enn formell lov, noe som også er normalt i andre (komparative) stater.\r
I Norge er det Stortinget som vedtar lover (lovgivende makt), mens domstolene med sin dømmende makt har prøvingsrett, som vil si å kontrollere om en lov eller vedtak er i overensstemmelse med Grunnloven. Stortingets kompetanse til å vedta lover er gitt i Grunnloven § 75 bokstav a, mens domstolenes prøvingsrett fremgår av Grunnloven § 89.\r
Når Stortinget ikke er samlet, kan Regjeringen vedta midlertidige lover på noen områder, jf. Grunnloven § 17. Det heter provisorisk anordning [Jusleksikon.no]"""@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026611> ;
    skos:example "Kongeriget Norges Criminallov : af 20de August 1842."@nb,
        "Love og Anordninger m.v. for Aaret 1814."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/104> ;
    skos:prefLabel "Statutes and codes"@en,
        "Lover"@nb,
        "Lovar"@nn ;
    skos:scopeNote "Brukes i betydningen 'formell lov'."@nb .

<https://id.nb.no/vocabulary/ntsf/178> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
