    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Study booklets"@en,
        "Studiehefter"@nb,
        "Studiehefte"@nn .

<https://id.nb.no/vocabulary/ntsf/1729> a skos:Concept ;
    dct:created "2022-10-19T13:15:52"^^xsd:dateTime ;
    skos:altLabel "State of the Union"@en,
        "State of the Union address"@en,
        "The King's speeches"@en,
        "The Queen's speeches"@en,
        "Throne speeches"@en ;
