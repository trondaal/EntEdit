    skos:example "Hele Norge 2020 : veikart."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Road maps"@en,
        "Veikart"@nb,
        "Vegkart"@nn .

<https://id.nb.no/vocabulary/ntsf/326> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2025-06-27T16:41:54"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Fortellinger fra uberørte naturområder [red.]."@nb ;
    skos:example "Ensom blant ulver / Jean Craighead George."@nb,
        "Rovdyrhøst / Kai H. Nielsen."@nb,
        "Tikaan-Olli : en villmarksroman fra Alaska / Ståle Botn."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Wilderness tales"@en,
        "Villmarksfortellinger"@nb,
        "Villmarksforteljingar"@nn ;
    skos:scopeNote "Brukes for skjønnlitteratur hvor handlingen foregår i «villmarken» ."@nb .

<https://id.nb.no/vocabulary/ntsf/332> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:altLabel "Jests"@en,
        "Witticisms"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/127> ;
    skos:definition "En vits er en vittighet eller kort historie med et overraskende poeng, som er ment å være morsomt. Det kan være en spøkefull bemerkning eller en replikk med et treffende poeng. Ordet vits kan bety mening, verdi eller poeng i setninger som «hva er vitsen med det?». Humor og vitser er uttrykk for følelser, lek og sosialt samspill og har i forskjellige former eksistert like lenge som mennesket har hatt språk og kultur. De kan være muntlige, skriftlige eller formidlet gjennom bilder, for eksempel i vitsetegninger, en sjanger i slekt med tegneserier og karikaturer [Wikipedia]."@nb ;
    skos:example "Alle barna-vitser / Håkon Forfod Sønneland."@nb,
        "Verdens morsomste vitser : alle barna-vitser, vill vest-vitser, brillevitser, prompevitser, bøllevitser, doktorvitser, heksevitser og mye, mye mer! : for hele familien / Anton Andersen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Jokes"@en,
        "Vitser"@nb,
        "Vitsar"@nn .

<https://id.nb.no/vocabulary/ntsf/333> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-11-15T11:55:52"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Skjønnlitteratur hvor handlingen foregår i det såkalte ville vesten i amerikansk historie [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026594> ;
    skos:example "I præriens grep / Zane Grey."@nb,
        "Legenden om Blueberry / Jean-Michel Charlier."@nb,
        "Morgan Kane / Louis Masterson."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Western fiction"@en,
        "Western"@nb,
        "Western"@nn .

<https://id.nb.no/vocabulary/ntsf/337> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2024-05-31T10:03:55"^^xsd:dateTime ;
    skos:altLabel "Årsmeldinger"@nb,
