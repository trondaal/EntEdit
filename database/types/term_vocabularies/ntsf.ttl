    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026198> ;
    skos:example "Registrerte varemerker : klasse 23 : hermetikk / utarbeidet av Gustav Iversen ; [utgitt av] Tidsskrift for Hermetikkindustri."@nb ;
