        <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "Regnskap, sammendrag av et foretaks bokføring for en periode, som regel et kalenderår, i form av en oversikt over resultatet av virksomheten og den økonomiske stilling ved slutten av perioden [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2017026136> ;
    skos:example "Christian III's Rentemesterregnskaber : 5 : Ordforklaringer, sagregister og stikordsregister."@nb,
        "Elizabeth de Burgh, Lady of Clare (1295-1360) : household and other records."@nb,
        "The Kellis agricultural account book : (P.Kell.IV Gr.96)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1875> ;
    skos:prefLabel "Accounting"@en,
        "Regnskaper"@nb,
        "Regnskap"@nn .

<https://id.nb.no/vocabulary/ntsf/1936> a skos:Concept ;
    dct:created "2022-11-28T08:53:56"^^xsd:dateTime ;
    skos:altLabel "Abstracts"@en,
        "Summary"@en,
        "Abstrakt"@nb,
        "Abstrakter"@nb,
        "Handlingsresyméer"@nb,
        "Resymeer"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338>,
        <https://id.nb.no/vocabulary/ntsf/412> ;
    skos:definition "Sammendrag er en forkortet gjengivelse av teksten i et dokument, hvor man har forsøkt å bevare kronologien. Et sammendrag kan bestå av flere sider med tekst [SNL]."@nb ;
    skos:exactMatch <https://id.loc.gov/authorities/genreForms/gf2014026038.html> ;
    skos:example "Der Romanführer : der Inhalt der Romane und Novellen der Weltliteratur : Bd. 48 : Jahresband 2007 : Deutsche und internationale Prosa ; mit ausführlichem Personen-, Orts- und Sachwortregister."@nb,
        "Kunst- og kulturopplæring i Norge 2010/2011 : sammendrag på norsk av kartleggingen \"Arts and cultural education in Norway\"."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Summaries"@en,
        "Sammendrag"@nb,
        "Samandrag"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/1842> .

<https://id.nb.no/vocabulary/ntsf/201> a skos:Concept ;
