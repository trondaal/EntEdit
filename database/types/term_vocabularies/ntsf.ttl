        "Skattematrikler"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144>,
        <https://id.nb.no/vocabulary/ntsf/602> ;
    skos:definition "Martikkel betyr register. I Norge er Matrikkelen navnet på Norges offisielle register over fast eiendom. Matrikkelen er det norske eiendomsregisterets objektregister. Grunnboka er eiendomsregisterets rettighetsregister [SNL]."@nb ;
    skos:example "Domesday book : a complete translation."@nb,
        "Jordebok for Bergen bispedømme ca. 1600 : med jordebok for Hospitalet i Bergen ca. 1617-21."@nb,
