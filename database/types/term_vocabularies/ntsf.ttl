<https://id.nb.no/vocabulary/ntsf/1726> a skos:Concept ;
    dct:created "2022-10-19T13:08:44"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/430> ;
    skos:definition "Selvstendig vedlegg til en bok, teaterprogram el.l. med en pedagogisk bearbeidelse av temaer, gjerne etterfulgt av spørsmål og eventuelt oppgaver [UBO]."@nb ;
    skos:example "Computus and its cultural context in the Latin west, AD 300-1200 : proceedings of the 1st International conference on the science of computus in Ireland and Europe, Galway, 14-16 July, 2006."@nb,
