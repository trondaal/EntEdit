        <https://id.nb.no/vocabulary/ntsf/404>,
        <https://id.nb.no/vocabulary/ntsf/479> ;
    skos:definition "Bøker som skal aktivisere barn eller voksne, f.eks. der de kan løse oppgaver med tall, bokstaver, tegn og bilder. Omfatter også bøker til å skrive, tegne eller male i. (red.)."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2017026059> ;
    skos:example "Gangetabellen, skriv svaret og tørk det bort! (Matte-moro)."@nb,
        "Min aktivitetsbok med maskiner og kjøretøy."@nb,
        "Min store havfrue-aktivitetsbok (Skrap og tegn)."@nb,
        "Snøsøsteren : aktivitetsbok / Maja Lunde og Lisa Aisato ; omslagsdesign og layout: Terese Moe Leiner."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Activity books"@en,
        "Aktivitetsbøker"@nb,
        "Aktivitetsbøker"@nn .

<https://id.nb.no/vocabulary/ntsf/603> a skos:Concept ;
    dct:created "2020-01-15T10:34:56"^^xsd:dateTime ;
    skos:altLabel "Genealogi"@nb,
        "Slektsforskning"@nb,
        "Slektsgranskning"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/338>,
        <https://id.nb.no/vocabulary/ntsf/453> ;
    skos:definition "Slektshistorie (genealogi, slektsgransking) er en hjelpedisiplin innen historiefaget som går ut på å dokumentere sentrale begivenheter i personers livsløp (som fødsel, ekteskap og død) og slektskapsbånd mellom forskjellige personer [NLI]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026100> ;
    skos:example """Stamtavle over familien Bassøe.\r
https://www.nb.no/items/URN:NBN:no-nb_digibok_2011080508019"""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Family histories"@en,
        "Slektshistorie"@nb,
        "Slektshistorie"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/614> .

<https://id.nb.no/vocabulary/ntsf/610> a skos:Concept ;
    dct:created "2020-01-15T10:54:49"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/3024> ;
    skos:definition "Bygdebok er en fellesnevnelse på historiebøker skrevet om og for bestemte lokalsamfunn, en bygd, en kommune eller deler av en kommune [NLI]."@nb ;
    skos:example "Folk og fortid i Hol (hele verket: 2 bind allmennsoge + 7 bind gards- og slektshistorie)."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/614>,
        <https://id.nb.no/vocabulary/ntsf/690> ;
    skos:prefLabel "Local history books"@en,
        "Bygdebøker"@nb,
        "Bygdebøker"@nn ;
    skos:scopeNote "Brukes for større lokalhistoriske verk som beskriver både den historiske utviklingen og historien for hver enkelt gård i et lokalsamfunn, en bygd, en kommune eller deler av en kommune. Bygdebøker kan ofte ha mange bind."@nb .

<https://id.nb.no/vocabulary/ntsf/897> a skos:Concept ;
    dct:created "2020-07-07T12:39:06"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/508>,
        <https://id.nb.no/vocabulary/ntsf/83> ;
    skos:definition "(..)Folkeeventyret er en muntlig tradisjon og har ingen kjent forfatter. Folkeeventyret er delt over store avstander og og lange tidsspenn i mange ulike varianter(..) ."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026344> ;
    skos:example "Norske folkeeventyr / Asbjørnsen og Moe."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/2234> ;
    skos:prefLabel "Folk tales"@en,
        "Folkeeventyr"@nb,
        "Folkeeventyr"@nn .

<https://id.nb.no/vocabulary/ntsf/1202> a skos:Concept ;
    dct:created "2021-10-18T12:52:42"^^xsd:dateTime ;
    skos:altLabel "Documentaries"@en,
        "Documentary-style films"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Film som skildrer virkeligheten med autentiske personer, miljøer og hendelser, i motsetning til fiksjonsfilm. Dokumentarfilmen har en intensjon utover det å bare dokumentere. For eksempel kan den presentere et politisk, sosialt eller historisk tema ut fra et bestemt synspunkt. Er gjerne redigert og bruker filmatiske virkemidler, i motsetning til rene dokumentasjonsopptak og aktualiteter [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026205> ;
    skos:example "Generasjon Utøya (2021)"@nb,
        "Heftig og begeistret (2002)"@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1236>,
        <https://id.nb.no/vocabulary/ntsf/1337>,
        <https://id.nb.no/vocabulary/ntsf/1823> ;
    skos:prefLabel "Documantary films"@en,
        "Dokumentarfilmer"@nb,
        "Dokumentarfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/1290> a skos:Concept ;
    dct:created "2022-02-18T14:56:53"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1122> ;
    skos:definition "Samlebegrep for filmer hvor musikk er en viktig bestanddel. Kan være både fiksjon og faktabasert [red.]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1237>,
        <https://id.nb.no/vocabulary/ntsf/1258>,
        <https://id.nb.no/vocabulary/ntsf/1344> ;
    skos:prefLabel "Musikkfilmer"@nb,
        "Musikkfilmar"@nn .

<https://id.nb.no/vocabulary/ntsf/138> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/404> ;
    skos:definition "En kalender er et hjelpemiddel for å holde orden på tiden gjennom et solår/serie av solår eller måneår. Som et minimum viser en kalender vanligvis årets oppdeling i måneder og uker samt hvilken ukedag som faller på hver dato [Wikipedia]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026055> ;
    skos:example "Lions Club Sogndal Sogndalkalenderen 1995."@nb,
        "Nemi bordkalender 2020 / Lise Myhre."@nb,
        "Strikkekalender 2019 / Britta Mikkelborg."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/1819>,
        <https://id.nb.no/vocabulary/ntsf/2263> ;
    skos:prefLabel "Calendars"@en,
        "Kalendere"@nb,
        "Kalendrar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/9> .

<https://id.nb.no/vocabulary/ntsf/1842> a skos:Concept ;
    dct:created "2022-11-16T09:25:59"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/602>,
        <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "En regest er et kort sammendrag av innholdet i et dokument. Regest brukes i historisk utgiverpraksis som betegnelse på kortfattede innholdsangivelser som vanlig anbringes foran aktstykker og andre tekster, særlig fra middelalderen [NB]."@nb ;
    skos:example "Regesta Imperii : 31 : Regesten Kaiser Friedrichs III : (1440-1493) : nach Archiven und Bibliotheken geordnet. Die Urkunden und Briefe aus den Archiven und Bibliotheken der deutschen Bundesländer Bremen, Hamburg und Schleswig-Holstein sowie der skandinavischen Länder."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Regests"@en,
        "Regester"@nb,
        "Regestar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/1936>,
        <https://id.nb.no/vocabulary/ntsf/2153> .

<https://id.nb.no/vocabulary/ntsf/1910> a skos:Concept ;
    dct:created "2022-11-25T11:54:36"^^xsd:dateTime ;
