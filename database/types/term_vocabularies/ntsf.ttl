<https://id.nb.no/vocabulary/ntsf/1929> a skos:Concept ;
    dct:created "2022-11-25T13:22:50"^^xsd:dateTime ;
    skos:altLabel "Account books"@en,
        "Accountancy"@en,
        "Accounting books"@en,
        "Regnskapsbøker"@nb ;
