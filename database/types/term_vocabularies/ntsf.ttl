<https://id.nb.no/vocabulary/ntsf/23> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Folk ballads"@en,
        "Medieval ballads"@en,
        "Middelalderballader"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/592> ;
    skos:definition "Ballade er først og fremst et sjangernavn for den typen episke viser som i høy- og seinmiddelalderen kom på moten over store deler av Europa. Ordet kommer fra det provençalske ballada, som betyr dansevise, noe som tyder på at balladene opprinnelig har vært danset til [Wikipedia]."@nb ;
    skos:example "En historisk Vise om Axel Thorsen og Skjøn Valborg."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:narrower <https://id.nb.no/vocabulary/ntsf/2123>,
        <https://id.nb.no/vocabulary/ntsf/2133>,
        <https://id.nb.no/vocabulary/ntsf/2141> ;
    skos:prefLabel "Ballads"@en,
        "Ballader"@nb,
        "Balladar"@nn ;
    skos:scopeNote "Brukes om balladetekster."@nb .

<https://id.nb.no/vocabulary/ntsf/2585> a skos:Concept ;
