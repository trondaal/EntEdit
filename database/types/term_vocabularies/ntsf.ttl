        """Topografisk, kronologisk fortegnelse over danske aviser 1648-1970 (1971)\r
Tønnesen, Helge."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Newspaper listings"@en,
        "Avisfortegnelser"@nb,
        "Avislister"@nn .

<https://id.nb.no/vocabulary/ntsf/22> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2020-02-13T13:30:07"^^xsd:dateTime ;
    skos:altLabel "Bachelor's thesis"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/19> ;
