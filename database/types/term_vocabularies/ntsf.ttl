<https://id.nb.no/vocabulary/ntsf/104> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2025-11-10T14:08:34"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/177> ;
    skos:definition "Forordning er en betegnelse som brukes om lover og andre rettsakter. Bruken av ordet har variert over tid [SNL]."@nb ;
    skos:example "Bekjendtgjørelse : [angaaende Eiendomsretten til endel Sager, der efter Dødsstrafs-Arrestanter ere tagne i Forvaring]."@nb,
        "Bryssel II ter-förordningen, Rom III-förordningen, internationella äktenskapslagen och nordiska äktenskapsförordningen."@nb,
