    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Playbills (posters)"@en,
        "Teaterplakater"@nb,
        "Teaterplakatar"@nn .

<https://id.nb.no/vocabulary/ntsf/30> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    skos:altLabel "Library catalogs"@en,
        "Library directories"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144> ;
    skos:definition "Katalog som består av bibliografiske data knyttet til samlingen i et bibliotek [Biblioterm]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026003> ;
    skos:example "Catalog over Det Norske Videnskabersselskabs Samlinger. 1. Del. Böger og Haandskrifter."@nb,
        "Catalog over Jacob Aalls Bibliothek."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Library catalogues"@en,
        "Bibliotekkataloger"@nb,
        "Bibliotekkatalogar"@nn .

<https://id.nb.no/vocabulary/ntsf/300> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-03-07T11:47:19"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/341> ;
    skos:definition "Beskrivelse av innhold, tid og sted for en eller flere teateroppsetninger [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026193> ;
    skos:example "Utlendingen : av Larry Shue / redaktør: Mari Brovold Owen [teaterprogram]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Theater programs (publications)"@en,
        "Teaterprogrammer"@nb,
        "Teaterprogram"@nn .

<https://id.nb.no/vocabulary/ntsf/3011> a skos:Concept ;
    dct:created "2025-10-07T07:59:10"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Fedrelandssanger"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Nasjonalsang er en patriotisk sang som er særlig avholdt og brukes ved offisielle høytideligheter [SNL]."@nb ;
    skos:example "Polsk nasjonalsang [musikktrykk]."@nb,
        "The star spangled banner / Oscar George Theodore Sonneck."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "National anthems"@en,
        "Nasjonalsanger"@nb,
        "Nasjonalsongar"@nn ;
    skos:scopeNote """I noen land har en sang offisiell status som “nasjonalsang” eller lignende, mens i andre land er dette basert på sedvane.\r
Brukes om tekster til nasjonalsanger."""@nb .

<https://id.nb.no/vocabulary/ntsf/3015> a skos:Concept ;
    dct:created "2025-11-11T07:25:36"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Studentersanger"@nb,
        "Studentarsongar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Sanger brukt i studentermiljø eller som handler om studenter og universitetsmiljø [Ballade og bånsull]."@nb ;
    skos:example "Gaudeamus igitur."@nb,
        "Sjung om studentens lyckliga dag / tekst: H. Sätherrberg ; Prins Gustav."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Student songs"@en,
        "Studentsanger"@nb,
        "Studentsongar"@nn ;
    skos:scopeNote "Brukes om tekster til sanger skrevet for studenter."@nb .

<https://id.nb.no/vocabulary/ntsf/302> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2020-01-14T16:26:17"^^xsd:dateTime ;
    skos:altLabel "Tegneserieromaner"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/301> ;
    skos:definition """Grafisk roman (engelsk: graphic novel) er et lengre tegneserie-verk i bokform.\r
Begrepet «grafisk roman» brukes bredt og omfatter alt fra skjønnlitteratur til sakprosa og biografi. Begrepet har sitt utspring i USA og Frankrike og er ment å markere avstand fra ordinære tegneserier.\r
Kjennetegn på en grafisk roman er at den har flere bilder på hver side [Wikipedia]."""@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026362> ;
    skos:example "Amuletten / Kazu Kibuishi."@nb,
        "Apefjes / Tor Erling Naas."@nb,
        "Sult / Martin Ernstsen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Graphic novels"@en,
        "Grafiske romaner"@nb,
        "Grafiske romanar"@nn ;
    skos:scopeNote "Dekker en sammenhengende og avsluttet historie og er som regel ikke en del av et serieunivers."@nb .

<https://id.nb.no/vocabulary/ntsf/3020> a skos:Concept ;
    dct:created "2025-11-25T08:09:22"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Vise som er del av en revy, humoristisk eller satirisk forestilling. Revyviser er oftest laget til en spesiell sesong, men enkelte revyviser har fått et langt liv i muntlig tradisjon eller i visebøker [Ballade og bånsull]."@nb ;
    skos:example "I hjertets have / [norsk] tekst: Otto Carlmar."@nb,
        "Ut på camping : en revyvise / av Finn Bø."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Revue songs"@en,
        "Revyviser"@nb,
        "Revyviser"@nn ;
    skos:scopeNote "Brukes om tekster til revyviser."@nb .

<https://id.nb.no/vocabulary/ntsf/305> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/438> ;
    skos:definition "Et testament eller testamente (av latin testamentum, «bevitnelse») er et dokument som inneholder en fortegnelse av hva man vil skal skje med ens eiendeler etter at man er død. Gjennom testamentet kan man innenfor lovens begrensninger (eller arvingenes samtykke) bestemme at de legale arvereglene skal fravikes. Ettersom opprettelse av testament er en såvidt viktig beslutning, og det kan være fare for at det vil bli påberopt forfalskede testamenter etter at arvelateren er død, er det i de fleste land opprettet nokså strenge formregler som må være oppfylt for at testamentet skal anses gyldig. Er ikke disse reglene oppfylt, vil ikke testamentet ha noen virkning [Jusleksikon.no]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026740> ;
    skos:example """Afgangne Thomas Angells Testamente med tilføiede Codiciller, efter Kongelig allernaadigst forundt Facultatem Testandi som Fundats for de Angellske Stiftelser, tilligemed senere udgangne, og for nærværende Tid gieldende Kongelige Rescripter, bemeldte Stiftelser vedkommende.\r
[kilde: Norske bøker 1519-1850]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Wills"@en,
        "Testamenter"@nb,
        "Testamente"@nn .

<https://id.nb.no/vocabulary/ntsf/308> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-03-19T12:33:48"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/894> ;
    skos:definition "Artikkel publisert i et tidsskrift [NAOB]."@nb ;
    skos:example """Arne Lygre mellom Norge og Tyskland : teateroppføring og oversettelse i et postmoderne grenseland mellom Ibsen og Fosse / Linnea Eirin Timmermann Buerskogen. \r
I: Norsk litterær årbok. - 2020. - Side 291-312."""@nb,
        """Om kunsten å se og skrive / Kåre Bulie. \r
I: Vinduet (Oslo : trykt utg.). - Årg. 68, nr. 1 (2014). - S. 78-90 : port."""@nb,
        """Solguden and other stories : Hamsun, Ibsen and forgery / Giuliano D'Amico. - \r
I: Edda (Oslo : online). - Årg. 106, nr. 4 (2019). - S. 249-263."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Journal articles"@en,
        "Tidsskriftartikler"@nb,
        "Tidsskriftartiklar"@nn .

<https://id.nb.no/vocabulary/ntsf/312> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:altLabel "Treaty"@en,
        "Konvensjoner"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/438> ;
    skos:definition "Traktat (av lat. tractare; \"forhandle\") er en folkerettslig bindende avtale mellom to eller flere stater. Andre navn for en traktat er konvensjon, overenskomst, avtale, charter, pakt og protokoll [Jusleksikon.no]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2011026707> ;
    skos:example """ILO-konvensjon nr. 169 om urfolk og stammefolk (1989) : håndbok.Konvensjonen vedtatt av Den internasjonale arbeidsorganisasjons generalkonferanse 27. juni 1989.Kommentarer utarbeidet av John B. Henriksen.\r
https://bibsys-almaprimo.hosted.exlibrisgroup.com/permalink/f/18nvp5u/BIBSYS_ILS71472134720002201."""@nb,
        """[Riksakten (1815)].\r
Rigs-Act, oprettet imellem Norges Riges Storthing og Sveriges Riges Stænder, indeholdende Bestemmelse af de imellem begge Riger opkomne constitutionelle Forhold. (Ordlydende aftrykt efter det i Rigsarchivet opbevarede Originalexemplar, under Tilsyn af det juridiske Facultet)."""@nb,
        """[Traktater, etc. 1814-01-14].\r
Freds-Tractat imellem Danmark og Engeland : sluttet i Kiel den 14de Januar 1814.\r
[kilde: 1814-bibliografi]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Treaties"@en,
        "Traktater"@nb,
        "Traktatar"@nn .

<https://id.nb.no/vocabulary/ntsf/313> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/503> ;
    skos:definition "En trosbekjennelse er en sammenfatning av en felles religiøs tro som den enkelte gir sin tilslutning til, ofte i offentlig sammenheng [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2015026031> ;
    skos:example "Den Augsburgske Konfession eller den Troesbekjendelse, som blev overrakt Kejser Karl den 5te paa Rigsdagen i Augsburg 1530 : tilligemed de tre Hovedsymboler eller Bekjendelser af Christi Tro, som ere endrægtig brugte i Kirken."@nb,
        """Konkordiebogen, eller den evangelisk-lutherske Kirkes Bekjendelsesskrifter / aftrykt med nogle Rettelser efter den af Professorerne Caspari og Johnsen besørgede Udgave samt forsynet med historisk-theologisk Indledning og Register.\r
[kilde: Norsk-amerikansk bibliografi]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Creeds"@en,
        "Trosbekjennelser"@nb,
        "Trusvedkjenningar"@nn .

<https://id.nb.no/vocabulary/ntsf/321> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2025-12-11T14:23:35"^^xsd:dateTime ;
    skos:altLabel "Exhibition catalogs"@en,
        "Exhibits"@en,
        "Kunstkataloger"@nb,
        "Utstillinger"@nb,
        "Utstillingsguider"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/144> ;
    skos:definition "Katalog over verker som skal vises fram på en utstilling [NAOB]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026098> ;
    skos:example "Sveve sveve. Dag Solstad : utstilling i Nasjonalbiblioteket 12. mai-6. august 2011 / [kurator: Trond Haugen, Hege Stensrud Høsøien og Marius Wulfsberg]."@nb,
        "Vanessa Baird - go down with me / curatorial editor Kari J. Brandtzæg ; editor Heidi Bale Amundsen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Exhibition catalogues"@en,
        "Utstillingskataloger"@nb,
        "Utstillingskatalogar"@nn ;
    skos:scopeNote "Brukes også for bøker som i tillegg til systematisk oversikt over verk/objekter på en bestemt utstilling, inneholder kompletterende tekster."@nb .

<https://id.nb.no/vocabulary/ntsf/325> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
