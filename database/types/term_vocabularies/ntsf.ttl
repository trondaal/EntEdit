        "Suksess for Cirkus Rex-Revyen / B.G. - I: Sunnmøre arbeideravis (trykt utg.). - Ålesund : [s.n.]. - 1949, 2/7."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Circus reviews"@en,
        "Sirkusanmeldelser"@nb,
        "Sirkusmeldingar"@nn .

<https://id.nb.no/vocabulary/ntsf/297> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2019-03-07T11:35:55"^^xsd:dateTime ;
    skos:altLabel "Teateromtaler"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/14> ;
    skos:definition "Tekst som refererer og/eller vurderer en teateroppsetning [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026194> ;
    skos:example "Ei mor på Torshov : [anmeldelse av Torshovteatrets oppsetting av Bertholt Brecht: Moren] / Dag Solstad."@nb,
        "Karl Schönherrs \"Trenkwalder\" und Knut Hamsuns \"Vom Teufel geholt / Friedrich Düsel."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Theater review"@en,
        "Teateranmeldelser"@nb,
        "Teatermeldingar"@nn .

<https://id.nb.no/vocabulary/ntsf/2971> a skos:Concept ;
    dct:created "2025-06-13T06:20:00"^^xsd:dateTime ;
    dct:modified "2025-06-27T16:41:54"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/2969> ;
    skos:definition "Bildebøker med punktskrift for blinde voksne og seende barn. Bildebøkene er splittet opp og sydd sammen igjen med folieark mellom. På de gjennomsiktige foliearkene er det punktskrift, slik at blinde kan lese punktskrift mens barnet ser på bildene [red.]."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Interleaved books"@en,
        "Interfolierte bøker"@nb,
        "Interfolierte bøker"@nn ;
    skos:scopeNote "Ei interfoliert bok er en vanlig bildebok som har gjennomsiktige folieark med punktskrift mellom boksidene."@nb .

<https://id.nb.no/vocabulary/ntsf/2976> a skos:Concept ;
    dct:created "2025-06-16T10:06:11"^^xsd:dateTime ;
    dct:modified "2025-10-27T17:26:21"^^xsd:dateTime ;
    skos:altLabel "War novels"@en,
        "Krigsromaner"@nb,
        "Krigsromanar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Skjønnlitteratur som skildrer krig og militære konflikter [red.]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2014026590> ;
    skos:example "Catch 22 / Joseph Heller."@nb,
        "Farvel til våpnene / Ernest Hemingway."@nb,
        "Luftens heltinne / Suzanne Fortin."@nb,
        "Skumring 1941 : roman fra en krigstid / Kjell Westö."@nb,
        "Sneen var ren / Hans Olav Lahlum."@nb,
        "Tvillingenes dagbok / Agota Kristof."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "War fiction"@en,
        "Krigsfortellinger"@nb,
        "Krigsforteljingar"@nn ;
    skos:scopeNote "Kan omhandle både soldatliv og sivilt liv under en krig, forutsatt at krigen er en sentral bakgrunnsramme."@nb .

<https://id.nb.no/vocabulary/ntsf/298> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2025-10-27T17:26:21"^^xsd:dateTime ;
    skos:altLabel "Play scripts"@en,
        "Play-scripts"@en,
        "Playtexts"@en,
        "Theater scripts"@en,
        "Theatre scripts"@en,
        "Regibok"@nb,
        "Regibøker"@nb,
        "Scenarier"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/189> ;
    skos:definition "En tekst som danner basis for en teateroppsetning. Den kan være basert på et originalt skuespill eller på en tekst i en annen form [red.]."@nb ;
    skos:example "'Bikubesong' basert på  Bikubesong av Frode Grytten."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Playscripts"@en,
        "Teatermanus"@nb,
        "Teatermanus"@nn .

<https://id.nb.no/vocabulary/ntsf/2981> a skos:Concept ;
    dct:created "2025-06-16T11:37:55"^^xsd:dateTime ;
    dct:modified "2025-06-27T16:41:54"^^xsd:dateTime ;
    skos:altLabel "Proletarian fiction"@en,
        "Proletarian novels"@en,
        "Arbeiderdiktning"@nb,
        "Arbeiderromaner"@nb,
        "Arbeidardikting"@nn,
        "Arbeidarromanar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/278> ;
    skos:definition "Arbeiderlitteratur er tekster som løfter frem arbeidere og deres politiske, økonomiske og sosiale situasjon [SNL]."@nb ;
    skos:exactMatch <http://id.loc.gov/authorities/genreForms/gf2019026138> ;
    skos:example "Arbeidsnever : noveller / Jan Kristoffer Dale."@nb,
        "Streik : arbeiderroman / Per Sivle."@nb,
        "Yarden : en fortelling : roman / Kristian Lundberg."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Proletarian literature"@en,
        "Arbeiderlitteratur"@nb,
        "Arbeidarlitteratur"@nn ;
    skos:scopeNote "Kan brukes på både fag- og skjønnlitteratur."@nb .

<https://id.nb.no/vocabulary/ntsf/299> a skos:Concept ;
    dct:created "2019-03-06T12:20:31"^^xsd:dateTime ;
    dct:modified "2020-04-01T16:23:04"^^xsd:dateTime ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/409> ;
    skos:definition "Plakater som informerer om en bestemt teateroppsetning [def.]."@nb ;
