<https://id.nb.no/vocabulary/ntsf/1678> a skos:Concept ;
    dct:created "2022-10-19T08:19:00"^^xsd:dateTime ;
    skos:altLabel "Exegesis"@en ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/503> ;
