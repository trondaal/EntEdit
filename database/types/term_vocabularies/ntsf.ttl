<https://id.nb.no/vocabulary/ntsf/174> a skos:Concept ;
    dct:created "2019-03-06T12:20:30"^^xsd:dateTime ;
    dct:modified "2023-05-05T06:50:46"^^xsd:dateTime ;
    skos:altLabel "Licentiate dissertations"@en,
        "Licentiate thesis"@en,
        "Licensiatavhandlinger"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/19> ;
    skos:definition "Avhandling som ble levert for å oppnå lisensiatgraden, en tidligere brukt akademisk grad, omtrent på nivå med en doktorgrad [red.]."@nb ;
    skos:example """"Oppositionen" och ministeransvarigheten : parlamentariska strömningar i svensk politik 1809-1840 / Ivar Andersson.\r
Avhandling (licensiatgrad) - Uppsala universitet, 1917.\r
[kilde: 1814-bibliografi]."""@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Licentiate theses"@en,
        "Lisensiatavhandlinger"@nb,
        "Licensiatavhandlingar"@nn .

<https://id.nb.no/vocabulary/ntsf/1767> a skos:Concept ;
    dct:created "2022-11-14T12:26:42"^^xsd:dateTime ;
    skos:altLabel "Forskingsrapporter"@nb ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/1775> ;
    skos:definition "En forskningsrapport er en publikasjon som rapporterer om funnene fra et forskningsprosjekt eller alternativt vitenskapelige observasjoner om eller om et emne [Wikipedia]."@nb ;
    skos:example "Koreokrati : en evaluering av pilotprosjekt for utvikling av profesjonelle dansemiljøer."@nb,
        "Når det rokkes ved tradisjon og tilhørighet : nedgang i oppslutning om dåp i Oslo bispedømme."@nb,
        "Når porten gjøres vid : evaluering av trosopplæringens breddetiltak."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Research reports"@en,
        "Forskningsrapporter"@nb,
        "Forskingsrapportar"@nn .

<https://id.nb.no/vocabulary/ntsf/1772> a skos:Concept ;
