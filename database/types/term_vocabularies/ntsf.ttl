        "Horoskop"@nn .

<https://id.nb.no/vocabulary/ntsf/2956> a skos:Concept ;
    dct:created "2025-06-12T10:33:40"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "War songs"@en,
        "Krigssanger"@nb,
        "Krigssongar"@nn ;
    skos:broader <https://id.nb.no/vocabulary/ntsf/330> ;
    skos:definition "Sang av soldater eller sang bestemt til å synges av soldater [NAOB]."@nb ;
    skos:example "Ny Vise til Nytte, Lærdom og Fornøielse for rekrutter (1893)."@nb,
        "Når guttene kommer hjem / norsk tekst: Birger Madsen."@nb ;
    skos:inScheme <https://id.nb.no/resource/vocab/ntsf> ;
    skos:prefLabel "Soldiers' songs"@en,
        "Soldatsanger"@nb,
        "Soldatsongar"@nn ;
    skos:scopeNote "Brukes om tekster til soldatsanger."@nb .

<https://id.nb.no/vocabulary/ntsf/2962> a skos:Concept ;
    dct:created "2025-06-12T11:27:54"^^xsd:dateTime ;
    dct:modified "2025-06-27T16:41:54"^^xsd:dateTime ;
    skos:altLabel "Sirkusomtaler"@nb ;
