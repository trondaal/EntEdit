    skos:prefLabel "Diary fiction"@en,
        "Dagboksfortellinger"@nb,
        "Dagboksforteljingar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/532>,
        <https://id.nb.no/vocabulary/ntsf/54> ;
    skos:scopeNote "Brukes for skjønnlitteratur hvor handlingen er gjengitt i dagboksform."@nb .

<https://id.nb.no/vocabulary/ntsf/587> a skos:Concept ;
