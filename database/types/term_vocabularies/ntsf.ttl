        "Fotografisamlinger"@nb,
        "Fotografisamlingar"@nn ;
    skos:related <https://id.nb.no/vocabulary/ntsf/510> .

<https://id.nb.no/vocabulary/ntsf/510> a skos:Concept ;
    dct:created "2019-10-02T12:36:27"^^xsd:dateTime ;
    dct:modified "2026-02-17T11:35:12"^^xsd:dateTime ;
    skos:altLabel "Photography books"@en ;
