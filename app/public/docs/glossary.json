{
  "_comment": "Terminology glossary for translating EntEdit documentation. English is the source language. Property labels (marked with 'ui: true') are what the user sees in the application — use these exact terms in documentation. This file is maintained alongside the English docs and consulted when translating.",

  "classes": {
    "_policy": "WEMI class names are translated in each language. They appear in entity badges, prose, entity-tree diagrams, and example cards.",
    "Work":           { "no": "Verk" },
    "Expression":     { "no": "Uttrykk" },
    "Manifestation":  { "no": "Manifestasjon" },
    "Item":           { "no": "Eksemplar" },
    "Agent":          { "no": "Agent" }
  },

  "wemi_relationships": {
    "_policy": "These are the labels the user sees on relationship dropdowns in the UI. When the user has Norwegian selected, the database returns the Norwegian label. Documentation for each language should use the label the user actually sees.",
    "has expression of work":           { "no": "har uttrykk av verk",      "ui": true },
    "is expression of work":            { "no": "er uttrykk av verk",       "ui": true },
    "has expression manifested":        { "no": "har uttrykk",              "ui": true },
    "has manifestation of expression":  { "no": "har manifestasjon",        "ui": true }
  },

  "agent_relationships": {
    "_policy": "Same as WEMI relationships — use the label the user sees in the UI for the given language.",
    "has author":               { "no": "har forfatter",                "ui": true },
    "is author of":             { "no": "forfatter",                    "ui": true },
    "has translator":           { "no": "har oversetter",               "ui": true },
    "is translator of":         { "no": "er oversetter av",             "ui": true },
    "has performer":            { "no": "har utøver",                   "ui": true },
    "is performer of":          { "no": "er utøver i",                  "ui": true },
    "has narrator":             { "no": "har forteller",                "ui": true },
    "is narrator of":           { "no": "er forteller av",              "ui": true },
    "has publisher":            { "no": "har utgiver",                  "ui": true },
    "has creator":              { "no": "har skaper",                   "ui": true },
    "is creator of":            { "no": "er skaper av",                 "ui": true },
    "has editor":               { "no": "har redaktør",                 "ui": true },
    "is editor of":             { "no": "er redaktør av",               "ui": true },
    "has director":             { "no": "har regissør",                 "ui": true },
    "has film director":        { "no": "har filmregissør",             "ui": true },
    "has composer":             { "no": "har komponist for verk",       "ui": true },
    "has conductor":            { "no": "har dirigent",                 "ui": true },
    "has singer":               { "no": "har sanger",                   "ui": true },
    "has instrumentalist":      { "no": "har instrumentalist",          "ui": true },
    "has actor":                { "no": "har skuespiller",              "ui": true }
  },

  "work_relationships": {
    "is motion picture adaptation of":  { "no": "er filmatisering av",  "ui": true },
    "has subject (work)":               { "no": "har emne (verk)",      "ui": true },
    "has subject (agent)":              { "no": "har emne (agent)",     "ui": true }
  },

