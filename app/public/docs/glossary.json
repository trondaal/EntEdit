  "general_terms": {
    "_policy": "Domain terms used in descriptive text throughout the documentation.",
    "entity":               { "no": "entitet" },
    "entity (plural)":      { "no": "entiteter" },
    "class":                { "no": "klasse" },
    "class (plural)":       { "no": "klasser" },
    "property":             { "no": "egenskap" },
    "property (plural)":    { "no": "egenskaper" },
    "label":                { "no": "etikett" },
    "label (plural)":       { "no": "etiketter" },
    "relationship":         { "no": "relasjon" },
    "relationship (plural)":{ "no": "relasjoner" },
    "triple":               { "no": "trippel" },
    "graph database":       { "no": "grafdatabase" },
    "endpoint":             { "no": "endepunkt" },
    "ontology":             { "no": "ontologi" },
    "vocabulary":           { "no": "vokabular" },
    "translation":          { "no": "oversettelse" },
    "adaptation":           { "no": "tilpasning" },
    "omnibus":              { "no": "omnibus" },
    "anthology":            { "no": "antologi" },
    "cataloguing":          { "no": "katalogisering" },
    "format":               { "no": "format", "_note": "Neuter noun (et format). Use definite form 'formatet' when referring to a specific format, e.g. 'Turtle-formatet'." },
    "interoperability":     { "no": "interoperabilitet", "_note": "Always 'interoperabilitet', never 'samoperabilitet'." },
    "interaction logging":  { "no": "interaksjonslogging" },
    "application header":   { "no": "applikasjons-headeren", "_note": "Definite form as used in running text." },
    "repository (GraphDB)": { "no": "datalager", "_note": "Never 'repositorium' (not a proper Norwegian word). Add '(repository)' in parentheses at the first mention in a document so users can map the term to the English GraphDB Workbench UI. GraphDB UI labels like 'Repository ID' and menu paths stay in English." },
    "repository (Git)":     { "no": "prosjektet", "_note": "For the Git/GitHub repository, refer to 'prosjektet' or 'EntEdit-prosjektet' rather than 'repositoriet'." }
  }
}
