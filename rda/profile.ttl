@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

entedit:StatusLiteral a rdfs:Datatype ;
    owl:oneOf ("data property" "object property" "class" "deprecated" "not used") .

entedit:status a owl:DatatypeProperty ;
    rdfs:range entedit:StatusLiteral ;
    rdfs:label "has status (literal)" .

