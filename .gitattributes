# Normalize line endings across platforms.
# Without this, Windows checkouts get CRLF endings, which breaks shell scripts
# run inside Linux containers (e.g. docker/graphdb/import-types.sh fails with
# "/bin/sh^M: bad interpreter").
* text=auto eol=lf

# Explicitly enforce LF for files that must run or be parsed on Linux.
*.sh        text eol=lf
Dockerfile  text eol=lf
*.ttl       text eol=lf
*.nt        text eol=lf
*.rdf       text eol=lf
*.sparql    text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf

# Binary files — never touch these.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
