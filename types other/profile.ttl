@prefix abi: <http://oslomet.no/abi/vocab#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

abi:StatusLiteral a rdfs:Datatype ;
    owl:oneOf ("data property" "object property" "class" "deprecated" "not used") .

abi:status a owl:DatatypeProperty ;
    rdfs:range abi:StatusLiteral ;
    rdfs:label "has status (literal)" .

