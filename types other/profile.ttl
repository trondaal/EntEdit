@prefix abi: <http://oslomet.no/abi/vocab#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdaao: <http://rdaregistry.info/Elements/a/object/> .
@prefix rdawo: <http://rdaregistry.info/Elements/w/object/> .
@prefix rdaeo: <http://rdaregistry.info/Elements/e/object/> .
@prefix rdamo: <http://rdaregistry.info/Elements/m/object/> .

abi:StatusLiteral a rdfs:Datatype ;
    owl:oneOf ("core wemi property" "data property" "object property" "class" "controlled property" "deprecated" "not used") .

abi:status a owl:DatatypeProperty ;
    rdfs:range abi:StatusLiteral ;
    rdfs:label "has status (literal)" .

abi:order a owl:DatatypeProperty .

#Adding some classes for the vocabularies used since difficult to differentiate skos:Concept
abi:Contenttype a owl:Class .
abi:Contenttype rdfs:label "Innholdstyper"@no .
abi:Contenttype rdfs:label "Content types"@en .

#Adding some semantics to the data
abi:Carriertype a owl:Class .
abi:Carriertype rdfs:label "Bærertyper"@no .
abi:Carriertype rdfs:label "Carrier types"@en .

#Adding some semantics to the data
abi:Mediatype a owl:Class .
abi:Mediatype rdfs:label "Medietyper"@no .
abi:Mediatype rdfs:label "Media types"@en .

#Adding some semantics to the data
abi:Language a owl:Class .
abi:Language rdfs:label "Språk"@no .
abi:Language rdfs:label "Language"@en .

